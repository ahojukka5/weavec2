# Default: detect text, normalise line endings.
* text=auto eol=lf

# Source files: always text.
*.weave        text eol=lf
*.wir          text eol=lf
*.ll           text eol=lf
*.expected.ll  text eol=lf
*.expected.wir text eol=lf
*.c            text eol=lf
*.h            text eol=lf
*.sh           text eol=lf
*.py           text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.txt          text eol=lf

# Binary artefacts (should not be tracked, listed defensively).
*.bc          binary
*.o           binary
