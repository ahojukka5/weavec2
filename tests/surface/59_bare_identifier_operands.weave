; 59_bare_identifier_operands.weave
; purpose: verify bare local and parameter names are accepted as call operands.
; verifies: direct identifiers lower through the frontend and backend without
;           requiring explicit local_get or param_get wrappers at call sites.
; expected runtime behavior: returns 42.
; tags: syntax, identifier, call

(program
  (name "bare_identifier_operands")
  (version "0.1")
  (fn add_two
    (params (left i32) (right i32))
    (returns i32)
    (do
      (return (add_i32 left right))))
  (fn add_answer
    (params (base i32))
    (returns i32)
    (do
      (let extra i32 (const_i32 2))
      (return (call_i32 add_two base extra))))
  (entry main
    (params)
    (returns i32)
    (do
      (let start i32 (const_i32 40))
      (return (call_i32 add_answer start)))))
