; 49_string_escape.weave
; purpose: verify escape sequences in string literals: \n, \", \\.
; verifies: const_string with embedded newline, quote, and backslash escape sequences.
; expected runtime behavior: prints three lines, exits with code 42.
; tags: const_string, print, escape_sequences, smoke

(program
  (name "string_escape")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (print
        (const_string "hello\nworld"))
      (print
        (const_string "quote: \"weave\""))
      (print
        (const_string "backslash: \\"))
      (return
        (const_i32 42)))))
