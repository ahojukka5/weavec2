; 47_forward_function_call.weave
; purpose: verify that a function can be called before it is defined in the source.
; verifies: forward reference — main calls answer which is declared after main.
; expected runtime behavior: process exits with code 42.
; tags: forward_reference, call_i32, fn, smoke

(program
  (name "forward_function_call")
  (version "0.1")
  (entry main)
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (call_i32 answer))))
  (fn answer
    (params)
    (returns i32)
    (do
      (return
        (const_i32 42)))))
