; 37_mul_i32.weave
; purpose: verify mul_i32 multiplication operator.
; verifies: mul_i32 with constant operands in return position.
; expected runtime behavior: process exits with code 42 (6 * 7 = 42).
; tags: mul_i32, arithmetic, const_i32, smoke

(program
  (name "mul_i32")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (return
        (mul_i32
          (const_i32 6)
          (const_i32 7))))))
