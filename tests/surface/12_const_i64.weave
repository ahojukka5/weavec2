; 12_const_i64.weave
; purpose: verify that an i64 constant can be stored in a local and cast to i32 for return.
; verifies: const_i64, let with i64 type, local_get, cast_i64_to_i32.
; expected runtime behavior: process exits with code 42.
; tags: const_i64, let, local_get, cast_i64_to_i32, smoke

(program
  (name "const-i64")
  (version "0.1")
  (entry main)
  (fn main
    (params)
    (returns i32)
    (do
      (let x i64
        (const_i64 42))
      (return
        (cast_i64_to_i32
          (local_get x))))))
