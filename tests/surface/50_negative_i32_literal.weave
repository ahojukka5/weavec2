; 50_negative_i32_literal.weave
; purpose: verify that negative integer literals are parsed and handled correctly.
; verifies: const_i32 with negative value, add_i32 of negative and positive constants.
; expected runtime behavior: process exits with code 42 (-8 + 50 = 42).
; tags: const_i32, negative_literal, add_i32, smoke

(program
  (name "negative_i32_literal")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (return
        (add_i32
          (const_i32 -8)
          (const_i32 50))))))
