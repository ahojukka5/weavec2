; 09_while.weave
; purpose: verify that a while loop iterates and accumulates correctly.
; verifies: while, condition, set, local_get, lt_i32, add_i32 — basic loop pattern.
; expected runtime behavior: process exits with code 42 (6 * 7 = 42).
; tags: while, condition, set, local_get, lt_i32, control_flow, smoke

(program
  (name "while-loop")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let i i32
        (const_i32 0))
      (let sum i32
        (const_i32 0))
      (while
        (condition
          (lt_i32
            (local_get i)
            (const_i32 7)))
        (do
          (set sum
            (add_i32
              (local_get sum)
              (const_i32 6)))
          (set i
            (add_i32
              (local_get i)
              (const_i32 1)))))
      (return
        (local_get sum)))))
