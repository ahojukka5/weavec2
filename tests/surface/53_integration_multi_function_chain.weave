; 53_integration_multi_function_chain.weave
; purpose: integration test — three-function call chain with helper functions.
; verifies: calculate calls helper_double and helper_square; result = 5*2 + 5*5 = 35.
; expected runtime behavior: process exits with code 35.
; tags: call_i32, fn, mul_i32, add_i32, param_get, integration

(program
  (name "integration_multi_function_chain")
  (version "0.1")
  (entry main)
  (fn calculate
    (params
      (x i32))
    (returns i32)
    (do
      (return
        (add_i32
          (call_i32 helper_double (param_get x))
          (call_i32 helper_square (param_get x))))))
  (fn helper_double
    (params
      (n i32))
    (returns i32)
    (do
      (return
        (mul_i32
          (param_get n)
          (const_i32 2)))))
  (fn helper_square
    (params
      (n i32))
    (returns i32)
    (do
      (return
        (mul_i32
          (param_get n)
          (param_get n)))))
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (call_i32 calculate
          (const_i32 5))))))
