; 31_i64_sub_eq.weave
; purpose: verify sub_i64 and eq_i64 comparison operators.
; verifies: sub_i64, eq_i64 in condition, const_i64 operands.
; expected runtime behavior: process exits with code 42 (50 - 8 == 42).
; tags: sub_i64, eq_i64, const_i64, if, condition, smoke

(program
  (name "i64_sub_eq")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (eq_i64
            (sub_i64
              (const_i64 50)
              (const_i64 8))
            (const_i64 42)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
