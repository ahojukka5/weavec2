; 42_load_store_ptr.weave
; purpose: verify store_ptr and load_ptr for pointer-sized heap slots.
; verifies: store_ptr writes a ptr, load_ptr reads it back, then write i64 through loaded ptr.
; expected runtime behavior: process exits with code 42.
; tags: store_ptr, load_ptr, store_i64, load_i64, malloc, free, ptr, smoke

(program
  (name "load_store_ptr")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let slot ptr
        (call_ptr malloc
          (const_i64 8)))
      (if
        (condition
          (eq_ptr
            (local_get slot)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do)))
      (let data ptr
        (call_ptr malloc
          (const_i64 8)))
      (if
        (condition
          (eq_ptr
            (local_get data)
            (const_null)))
        (then
          (do
            (call_void free
              (local_get slot))
            (return
              (const_i32 0))))
        (else
          (do)))
      (store_ptr
        (local_get slot)
        (local_get data))
      (let loaded ptr
        (load_ptr
          (local_get slot)))
      (store_i64
        (local_get loaded)
        (const_i64 42))
      (let value i64
        (load_i64
          (local_get data)))
      (call_void free
        (local_get data))
      (call_void free
        (local_get slot))
      (return
        (cast_i64_to_i32
          (local_get value))))))
