; 28_three_arg_function.weave
; purpose: verify a function with three i32 parameters and a multi-arg call site.
; verifies: fn with three params, nested add_i32, call_i32 with three arguments.
; expected runtime behavior: process exits with code 42 (10 + 20 + 12 = 42).
; tags: fn, params, param_get, add_i32, call_i32, three-arg, smoke

(program
  (name "three_arg_function")
  (version "0.1")
  (entry main)
  (fn add3
    (params
      (a i32)
      (b i32)
      (c i32))
    (returns i32)
    (do
      (return
        (add_i32
          (add_i32
            (param_get a)
            (param_get b))
          (param_get c)))))
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (call_i32 add3
          (const_i32 10)
          (const_i32 20)
          (const_i32 12))))))
