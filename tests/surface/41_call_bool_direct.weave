; 41_call_bool_direct.weave
; purpose: verify call_bool — calling a fn that returns bool, used directly in condition.
; verifies: fn returning bool from an i32 comparison, call_bool in if condition.
; expected runtime behavior: process exits with code 42 (is_answer(42) is true).
; tags: call_bool, fn, bool, eq_i32, param_get, if, condition, smoke

(program
  (name "call_bool_direct")
  (version "0.1")
  (entry main)
  (fn is_answer
    (params
      (x i32))
    (returns bool)
    (do
      (return
        (eq_i32
          (param_get x)
          (const_i32 42)))))
  (fn main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (call_bool is_answer
            (const_i32 42)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
