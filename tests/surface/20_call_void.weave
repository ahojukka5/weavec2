; 20_call_void.weave
; purpose: verify call_void with an extern function that returns void.
; verifies: call_void with extern free on null (free(NULL) is a no-op per C standard).
; expected runtime behavior: process exits with code 42.
; tags: call_void, extern, free, smoke

(program
  (name "call-void")
  (version "0.1")
  (entry main)
  (extern free
    (params
      (p ptr))
    (returns void))
  (fn main
    (params)
    (returns i32)
    (do
      (call_void free
        (const_null))
      (return
        (const_i32 42)))))
