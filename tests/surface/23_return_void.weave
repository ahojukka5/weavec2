; 23_return_void.weave
; purpose: verify void-returning functions and call_void on user-defined functions.
; verifies: fn returns void, return_void, call_void calling a user function.
; expected runtime behavior: process exits with code 42.
; tags: return_void, fn, void, call_void, smoke

(program
  (name "return-void")
  (version "0.1")
  (entry main)
  (fn noop
    (params)
    (returns void)
    (do
      (return_void)))
  (fn main
    (params)
    (returns i32)
    (do
      (call_void noop)
      (return
        (const_i32 42)))))
