; 48_multiple_externs_used_subset.weave
; purpose: verify that only the externs actually called appear in output (no puts here).
; verifies: malloc and free used; implicit extern resolution via weavec1 fallback.
; expected runtime behavior: process exits with code 42.
; tags: call_ptr, call_void, malloc, free, if, smoke

(program
  (name "multiple_externs_used_subset")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr malloc
          (const_i64 8)))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do)))
      (call_void free
        (local_get p))
      (return
        (const_i32 42)))))
