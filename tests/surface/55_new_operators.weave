; 55_new_operators.weave
; purpose: verify extended operator set: div_i64, mod_i64, bitwise ops, shift ops.
; verifies: div_i64, mod_i64, shl_i32/i64, and_i32/i64, or_i32/i64, xor_i32/i64, shr_i32/i64.
; expected runtime behavior: process exits with the combined result of all sub-tests.
; tags: div_i64, mod_i64, shl_i32, shl_i64, and_i32, and_i64, or_i32, or_i64, xor_i32, xor_i64, shr_i32, shr_i64

(program
  (name "new_operators")
  (version "0.1")
  (entry main)
  (fn test_division
    (params)
    (returns i64)
    (do
      (return
        (add_i64
          (div_i64 (const_i64 42) (const_i64 10))
          (mod_i64 (const_i64 42) (const_i64 10))))))
  (fn test_bitwise_i32
    (params)
    (returns i32)
    (do
      (return
        (sub_i32
          (add_i32
            (shl_i32 (const_i32 1) (const_i32 3))
            (and_i32 (const_i32 12) (const_i32 10)))
          (add_i32
            (or_i32 (const_i32 1) (const_i32 2))
            (xor_i32 (const_i32 6) (const_i32 4)))))))
  (fn test_bitwise_i64
    (params)
    (returns i64)
    (do
      (return
        (sub_i64
          (add_i64
            (shl_i64 (const_i64 1) (const_i64 3))
            (and_i64 (const_i64 12) (const_i64 10)))
          (add_i64
            (or_i64 (const_i64 1) (const_i64 2))
            (xor_i64 (const_i64 6) (const_i64 4)))))))
  (fn test_shr
    (params)
    (returns i64)
    (do
      (return
        (add_i64
          (cast_i32_to_i64 (shr_i32 (const_i32 16) (const_i32 2)))
          (shr_i64 (const_i64 32) (const_i64 2))))))
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (cast_i64_to_i32
          (add_i64
            (add_i64
              (call_i64 test_division)
              (cast_i32_to_i64 (call_i32 test_bitwise_i32)))
            (add_i64
              (call_i64 test_bitwise_i64)
              (call_i64 test_shr))))))))
