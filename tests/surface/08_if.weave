; 08_if.weave
; purpose: verify that if/then/else branches lower correctly.
; verifies: if, condition, then, else, lt_i32, const_i32, return from branch.
; expected runtime behavior: process exits with code 42 (1 < 2 is true, takes then-branch).
; tags: if, condition, then, else, lt_i32, control_flow, smoke

(program
  (name "if-test")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (lt_i32
            (const_i32 1)
            (const_i32 2)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
