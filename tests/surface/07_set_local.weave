; 07_set_local.weave
; purpose: verify that a local variable can be mutated with set and read back.
; verifies: let, set, local_get, add_i32 — mutable local variable flow.
; expected runtime behavior: process exits with code 42 (x starts at 40, set to x+2=42).
; tags: let, set, local_get, mutation, smoke

(program
  (name "set-local")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let x i32
        (const_i32 40))
      (set x
        (add_i32
          (local_get x)
          (const_i32 2)))
      (return
        (local_get x)))))
