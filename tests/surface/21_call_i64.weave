; 21_call_i64.weave
; purpose: verify call_i64 — calling a user-defined function that returns i64.
; verifies: fn returning i64, call_i64, cast_i64_to_i32 at call site.
; expected runtime behavior: process exits with code 42.
; tags: call_i64, fn, i64, cast_i64_to_i32, smoke

(program
  (name "call-i64")
  (version "0.1")
  (entry main)
  (fn answer64
    (params)
    (returns i64)
    (do
      (return
        (const_i64 42))))
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (cast_i64_to_i32
          (call_i64 answer64))))))
