(core-module
  (core-version 1)
  (decls
    (extern malloc (params (size i64)) (returns ptr))
    (fn Buffer_new (params (data ptr) (len i64) (cap i64)) (returns ptr)
      (do
        (let self ptr (call_ptr malloc (const_i64 24)))
        (if (condition (eq_ptr (local_get self) (const_null)))
          (then (do (return (const_null))))
          (else (do)))
        (store_ptr (local_get self) (param_get data))
        (store_i64 (ptr_add (local_get self) (const_i64 8)) (param_get len))
        (store_i64 (ptr_add (local_get self) (const_i64 16)) (param_get cap))
        (return (local_get self))))
    (fn Buffer_get_data (params (self ptr)) (returns ptr)
      (do (return (load_ptr (param_get self)))))
    (fn Buffer_set_data (params (self ptr) (v ptr)) (returns void)
      (do (store_ptr (param_get self) (param_get v)) (return_void)))
    (fn Buffer_get_len (params (self ptr)) (returns i64)
      (do (return (load_i64 (ptr_add (param_get self) (const_i64 8))))))
    (fn Buffer_set_len (params (self ptr) (v i64)) (returns void)
      (do (store_i64 (ptr_add (param_get self) (const_i64 8)) (param_get v)) (return_void)))
    (fn Buffer_get_cap (params (self ptr)) (returns i64)
      (do (return (load_i64 (ptr_add (param_get self) (const_i64 16))))))
    (fn Buffer_set_cap (params (self ptr) (v i64)) (returns void)
      (do (store_i64 (ptr_add (param_get self) (const_i64 16)) (param_get v)) (return_void)))
    (fn main (params) (returns i32) (do (let buf ptr (call_ptr malloc (const_i64 24))) (call_void Buffer_set_data buf (const_null)) (call_void Buffer_set_len buf (const_i64 42)) (call_void Buffer_set_cap buf (const_i64 100)) (let result i64 (call_i64 Buffer_get_len buf)) (return (cast_i64_to_i32 (local_get result)))))
  )
)
