; 38_div_i32.weave
; purpose: verify div_i32 integer division operator.
; verifies: div_i32 with constant operands in return position.
; expected runtime behavior: process exits with code 42 (126 / 3 = 42).
; tags: div_i32, arithmetic, const_i32, smoke

(program
  (name "div_i32")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (return
        (div_i32
          (const_i32 126)
          (const_i32 3))))))
