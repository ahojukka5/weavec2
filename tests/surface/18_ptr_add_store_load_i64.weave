; 18_ptr_add_store_load_i64.weave
; purpose: verify pointer arithmetic, store_i64, load_i64 for heap-allocated buffer.
; verifies: ptr_add, store_i64, load_i64, add_i64, cast_i64_to_i32 chained together.
; expected runtime behavior: process exits with code 42 (load(p)=20, load(p+8)=22, sum=42).
; tags: ptr_add, store_i64, load_i64, add_i64, malloc, free, ptr, smoke

(program
  (name "ptr-add-store-load-i64")
  (version "0.1")
  (entry main)
  (extern malloc
    (params
      (size i64))
    (returns ptr))
  (extern free
    (params
      (p ptr))
    (returns void))
  (fn main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr malloc
          (const_i64 16)))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do)))
      (store_i64
        (local_get p)
        (const_i64 20))
      (store_i64
        (ptr_add
          (local_get p)
          (const_i64 8))
        (const_i64 22))
      (let a i64
        (load_i64
          (local_get p)))
      (let b i64
        (load_i64
          (ptr_add
            (local_get p)
            (const_i64 8))))
      (call_void free
        (local_get p))
      (return
        (cast_i64_to_i32
          (add_i64
            (local_get a)
            (local_get b)))))))
