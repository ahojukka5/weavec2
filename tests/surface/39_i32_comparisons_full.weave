; 39_i32_comparisons_full.weave
; purpose: verify all six i32 comparison operators in sequence.
; verifies: eq_i32, ne_i32, lt_i32, le_i32, gt_i32, ge_i32 — all must pass to reach 42.
; expected runtime behavior: process exits with code 42.
; tags: eq_i32, ne_i32, lt_i32, le_i32, gt_i32, ge_i32, if, condition, smoke

(program
  (name "i32_comparisons_full")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (eq_i32
            (const_i32 42)
            (const_i32 42)))
        (then
          (do))
        (else
          (do
            (return
              (const_i32 0)))))
      (if
        (condition
          (ne_i32
            (const_i32 42)
            (const_i32 0)))
        (then
          (do))
        (else
          (do
            (return
              (const_i32 0)))))
      (if
        (condition
          (lt_i32
            (const_i32 1)
            (const_i32 2)))
        (then
          (do))
        (else
          (do
            (return
              (const_i32 0)))))
      (if
        (condition
          (le_i32
            (const_i32 2)
            (const_i32 2)))
        (then
          (do))
        (else
          (do
            (return
              (const_i32 0)))))
      (if
        (condition
          (gt_i32
            (const_i32 3)
            (const_i32 2)))
        (then
          (do))
        (else
          (do
            (return
              (const_i32 0)))))
      (if
        (condition
          (ge_i32
            (const_i32 4)
            (const_i32 4)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
