; 35_ge_i32.weave
; purpose: verify ge_i32 (>=) comparison operator.
; verifies: ge_i32 with equal operands evaluates to true.
; expected runtime behavior: process exits with code 42.
; tags: ge_i32, if, condition, const_i32, smoke

(program
  (name "ge_i32")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (ge_i32
            (const_i32 42)
            (const_i32 42)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
