; 44_if_fallthrough_join.weave
; purpose: verify that both if branches fall through and join at a common continuation.
; verifies: if sets a let-bound variable in both branches; code after if reads the result.
; expected runtime behavior: process exits with code 42 (then-branch sets x=42).
; tags: if, then, else, set, local_get, join, smoke

(program
  (name "if_fallthrough_join")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let x i32
        (const_i32 0))
      (if
        (condition
          (lt_i32
            (const_i32 1)
            (const_i32 2)))
        (then
          (do
            (set x
              (const_i32 42))))
        (else
          (do
            (set x
              (const_i32 0)))))
      (return
        (local_get x)))))
