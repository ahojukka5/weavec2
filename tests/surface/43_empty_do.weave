; 43_empty_do.weave
; purpose: verify that empty (do) blocks in both if branches are handled correctly.
; verifies: if with (do) in then and else, code after the if still executes.
; expected runtime behavior: process exits with code 42.
; tags: if, then, else, empty_do, smoke

(program
  (name "empty_do")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (eq_i32
            (const_i32 1)
            (const_i32 2)))
        (then
          (do))
        (else
          (do)))
      (return
        (const_i32 42)))))
