; 56_extern_decl.weave
; purpose: verify that (extern ...) declarations are lowered to WIR output.
; verifies: extern nodes are copied before fn nodes in the (decls ...) list.
; expected runtime behavior: calls puts then exits with code 42.
; tags: extern, puts, smoke

(program
  (name "extern_decl")
  (version "0.1")
  (extern puts
    (params (s ptr))
    (returns i32))
  (entry main
    (params)
    (returns i32)
    (do
      (call_i32 puts
        (const_string_ptr "hello from extern_decl"))
      (return
        (const_i32 42)))))
