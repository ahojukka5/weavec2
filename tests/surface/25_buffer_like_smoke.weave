; 25_buffer_like_smoke.weave
; purpose: simulate a buffer struct using raw pointer arithmetic and store/load operations.
; verifies: store_ptr, load_ptr, ptr_add with i64 offsets, store_i8, load_u8 chained.
; expected runtime behavior: process exits with code 42.
; tags: store_ptr, load_ptr, ptr_add, store_i8, load_u8, malloc, free, smoke

(program
  (name "buffer-like-smoke")
  (version "0.1")
  (entry main)
  (extern malloc
    (params
      (size i64))
    (returns ptr))
  (extern free
    (params
      (p ptr))
    (returns void))
  (fn main
    (params)
    (returns i32)
    (do
      (let buffer ptr
        (call_ptr malloc
          (const_i64 24)))
      (if
        (condition
          (eq_ptr
            (local_get buffer)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do)))
      (let data ptr
        (call_ptr malloc
          (const_i64 8)))
      (if
        (condition
          (eq_ptr
            (local_get data)
            (const_null)))
        (then
          (do
            (call_void free
              (local_get buffer))
            (return
              (const_i32 0))))
        (else
          (do)))
      (store_ptr
        (local_get buffer)
        (local_get data))
      (store_i64
        (ptr_add
          (local_get buffer)
          (const_i64 8))
        (const_i64 1))
      (store_i64
        (ptr_add
          (local_get buffer)
          (const_i64 16))
        (const_i64 8))
      (store_i8
        (local_get data)
        (const_i32 42))
      (let data2 ptr
        (load_ptr
          (local_get buffer)))
      (let x i32
        (load_u8
          (local_get data2)))
      (call_void free
        (local_get data))
      (call_void free
        (local_get buffer))
      (return
        (local_get x)))))
