;; Test new operators: div_i64, mod_i64, and bitwise operators

(core-module
  (core-version 1)
  (decls

    ;; Test div_i64 and mod_i64
    (fn test_division
      (params)
      (returns i64)
      (do
        ;; 42 / 10 = 4, 42 % 10 = 2, so 4 + 2 = 6
        (return (add_i64
          (div_i64 (const_i64 42) (const_i64 10))
          (mod_i64 (const_i64 42) (const_i64 10))))))

    ;; Test i32 bitwise operators
    (fn test_bitwise_i32
      (params)
      (returns i32)
      (do
        ;; (1 << 3) + (12 & 10) - (1 | 2) - (6 ^ 4)
        ;; 8 + 8 - 3 - 2 = 11
        (return (sub_i32
          (add_i32
            (shl_i32 (const_i32 1) (const_i32 3))
            (and_i32 (const_i32 12) (const_i32 10)))
          (add_i32
            (or_i32 (const_i32 1) (const_i32 2))
            (xor_i32 (const_i32 6) (const_i32 4)))))))

    ;; Test i64 bitwise operators
    (fn test_bitwise_i64
      (params)
      (returns i64)
      (do
        ;; (1 << 3) + (12 & 10) - (1 | 2) - (6 ^ 4)
        ;; 8 + 8 - 3 - 2 = 11
        (return (sub_i64
          (add_i64
            (shl_i64 (const_i64 1) (const_i64 3))
            (and_i64 (const_i64 12) (const_i64 10)))
          (add_i64
            (or_i64 (const_i64 1) (const_i64 2))
            (xor_i64 (const_i64 6) (const_i64 4)))))))

    ;; Test shift right
    (fn test_shr
      (params)
      (returns i64)
      (do
        ;; (16 >> 2) + (32 >> 2) = 4 + 8 = 12
        (return (add_i64
          (cast_i32_to_i64 (shr_i32 (const_i32 16) (const_i32 2)))
          (shr_i64 (const_i64 32) (const_i64 2))))))

    ;; Main entry point - test all operators
    (fn main
      (params)
      (returns i32)
      (do
        ;; division: 6, bitwise_i32: 11, bitwise_i64: 11, shr: 12
        ;; Total: 6 + 11 + 11 + 12 = 40
        (return (cast_i64_to_i32
          (add_i64
            (add_i64
              (call_i64 test_division)
              (cast_i32_to_i64 (call_i32 test_bitwise_i32)))
            (add_i64
              (call_i64 test_bitwise_i64)
              (call_i64 test_shr)))))))))
