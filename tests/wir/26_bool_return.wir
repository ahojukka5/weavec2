(core-module
  (core-version 1)
  (decls
    (fn same
      (params
        (x bool)
      ) ;; params
      (returns bool)
      (do
        (return
          (param_get x)
        ) ;; return
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (call_bool same
              (const_bool true)
            ) ;; call_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
