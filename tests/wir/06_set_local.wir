(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 40)
        ) ;; let
        (set x
          (add_i32
            (local_get x)
            (const_i32 2)
          ) ;; add_i32
        ) ;; set
        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
