(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr malloc
            (const_i64 4)
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if
        (store_i32
          (local_get p)
          (div_i32
            (mul_i32
              (const_i32 21)
              (const_i32 4)
            ) ;; mul_i32
            (const_i32 2)
          ) ;; div_i32
        ) ;; store_i32
        (let x i32
          (load_i32
            (local_get p)
          ) ;; load_i32
        ) ;; let
        (call_void free
          (local_get p)
        ) ;; call_void
        (if
          (condition
            (and_bool
              (eq_i32
                (local_get x)
                (const_i32 42)
              ) ;; eq_i32
              (le_i32
                (cast_i64_to_i32
                  (cast_i32_to_i64
                    (const_i32 -1)
                  ) ;; cast_i32_to_i64
                ) ;; cast_i64_to_i32
                (const_i32 0)
              ) ;; le_i32
            ) ;; and_bool
          ) ;; condition
          (then
            (do
              (return
                (local_get x)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
