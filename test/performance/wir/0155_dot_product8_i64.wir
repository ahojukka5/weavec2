; Performance: 0155_dot_product8_i64
; tags = heap, i64, memory, stress
; Why hard: Dot product two length-8 i64 arrays.
; Reveals: array_i64_at, load_i64, mul_i64, add_i64.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0155_dot_product8_i64.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Uses i32 mul on loaded i64; alignment 4 on i64 load.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (a ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i64_at
            (param_get a)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i64_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn dot8
      (params
        (a ptr)
        (b ptr)
      ) ;; params
      (returns i64)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (let sum i64
          (const_i64 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 8)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let va i64
              (load_i64
                (call_ptr elem
                  (param_get a)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i64
            ) ;; let

            (let vb i64
              (load_i64
                (call_ptr elem
                  (param_get b)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i64
            ) ;; let

            (set sum
              (add_i64
                (local_get sum)
                (mul_i64
                  (local_get va)
                  (local_get vb)
                ) ;; mul_i64
              ) ;; add_i64
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (let b ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (or_bool
              (eq_ptr
                (local_get a)
                (const_null)
              ) ;; eq_ptr
              (eq_ptr
                (local_get b)
                (const_null)
              ) ;; eq_ptr
            ) ;; or_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i64 (call_ptr elem (local_get a) (const_i32 0)) (const_i64 1))
        (store_i64 (call_ptr elem (local_get a) (const_i32 1)) (const_i64 2))
        (store_i64 (call_ptr elem (local_get a) (const_i32 2)) (const_i64 3))
        (store_i64 (call_ptr elem (local_get a) (const_i32 3)) (const_i64 4))
        (store_i64 (call_ptr elem (local_get a) (const_i32 4)) (const_i64 5))
        (store_i64 (call_ptr elem (local_get a) (const_i32 5)) (const_i64 6))
        (store_i64 (call_ptr elem (local_get a) (const_i32 6)) (const_i64 7))
        (store_i64 (call_ptr elem (local_get a) (const_i32 7)) (const_i64 8))

        (store_i64 (call_ptr elem (local_get b) (const_i32 0)) (const_i64 8))
        (store_i64 (call_ptr elem (local_get b) (const_i32 1)) (const_i64 7))
        (store_i64 (call_ptr elem (local_get b) (const_i32 2)) (const_i64 6))
        (store_i64 (call_ptr elem (local_get b) (const_i32 3)) (const_i64 5))
        (store_i64 (call_ptr elem (local_get b) (const_i32 4)) (const_i64 4))
        (store_i64 (call_ptr elem (local_get b) (const_i32 5)) (const_i64 3))
        (store_i64 (call_ptr elem (local_get b) (const_i32 6)) (const_i64 2))
        (store_i64 (call_ptr elem (local_get b) (const_i32 7)) (const_i64 1))

        (let sum i64
          (call_i64 dot8
            (local_get a)
            (local_get b)
          ) ;; call_i64
        ) ;; let

        (call_void free
          (local_get a)
        ) ;; call_void

        (call_void free
          (local_get b)
        ) ;; call_void

        (return
          (cast_i64_to_i32
            (local_get sum)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
