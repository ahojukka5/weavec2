; Performance: 0168_newton_sqrt_f32
; tags = f32, float, stress
; Why hard: Newton sqrt(2) with eight f32 iterations.
; Reveals: fdiv/fmul/fadd in loop, call_f32 helper.
; Expected: main returns ~1414 (sqrt(2)*1000, fptosi; see golden). llvm-as
;   accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Guess not updated; fdiv by zero; comparison uses icmp.
(core-module
  (core-version 1)
  (decls
    (fn sqrt_newton
      (params
        (x f32)
      ) ;; params
      (returns f32)
      (do
        (let guess f32
          (div_f32
            (add_f32
              (param_get x)
              (const_f32 1)
            ) ;; add_f32
            (const_f32 2)
          ) ;; div_f32
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 8)
            ) ;; lt_i32
          ) ;; condition
          (do
            (set guess
              (div_f32
                (add_f32
                  (local_get guess)
                  (div_f32
                    (param_get x)
                    (local_get guess)
                  ) ;; div_f32
                ) ;; add_f32
                (const_f32 2)
              ) ;; div_f32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get guess)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (cast_f32_to_i32
            (mul_f32
              (call_f32 sqrt_newton
                (const_f32 2)
              ) ;; call_f32
              (const_f32 1000)
            ) ;; mul_f32
          ) ;; cast_f32_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
