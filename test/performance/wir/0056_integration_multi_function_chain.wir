; Performance: 0056_integration_multi_function_chain
; Why hard: Several small functions inlined by hand; call chain must preserve ABI.
; Reveals: call_i32 across three functions, args and returns threaded.
; If LLVM regresses: Broken tail call or wrong return value register at end of chain.
(core-module
  (core-version 1)
  (decls
    (fn calculate
      (params
        (x i32))
      (returns i32)
      (do
        (return
          (add_i32
            (call_i32
              helper_double
              (param_get x))
            (call_i32
              helper_square
              (param_get x))))))
    (fn helper_double
      (params
        (n i32))
      (returns i32)
      (do
        (return
          (mul_i32
            (param_get n)
            (const_i32 2)))))
    (fn helper_square
      (params
        (n i32))
      (returns i32)
      (do
        (return
          (mul_i32
            (param_get n)
            (param_get n)))))
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32
            calculate
            (const_i32 5)))))))
