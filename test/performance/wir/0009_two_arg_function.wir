; Performance: 0009_two_arg_function
; Why hard: Smoke baseline for two-parameter call. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: two param_get values into call
; If LLVM regresses: Second argument clobbers first or uses wrong attribute/sign.
(core-module
  (core-version 1)
  (decls
    (fn add
      (params
        (a i32)
        (b i32)
      ) ;; params
      (returns i32)
      (do
        (return
          (add_i32
            (param_get a)
            (param_get b)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 add
            (const_i32 20)
            (const_i32 22)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
