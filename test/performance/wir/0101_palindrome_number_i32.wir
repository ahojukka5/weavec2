; Performance: 0101_palindrome_number_i32
; tags = algorithm, i32
; Why hard: Palindrome check. Depends on reverse_digits correctness.
; Reveals: reverse then compare.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0101_palindrome_number_i32.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Always true; compares n to partial reverse.
(core-module
  (core-version 1)
  (decls
    (fn reverse_digits
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get n)
        ) ;; let

        (let rev i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (gt_i32
              (local_get x)
              (const_i32 0)
            ) ;; gt_i32
          ) ;; condition
          (do
            (set rev
              (add_i32
                (mul_i32
                  (local_get rev)
                  (const_i32 10)
                ) ;; mul_i32
                (mod_i32
                  (local_get x)
                  (const_i32 10)
                ) ;; mod_i32
              ) ;; add_i32
            ) ;; set

            (set x
              (div_i32
                (local_get x)
                (const_i32 10)
              ) ;; div_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get rev)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn is_palindrome
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (eq_i32
              (param_get n)
              (call_i32 reverse_digits
                (param_get n)
              ) ;; call_i32
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 1)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 is_palindrome
            (const_i32 1221)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
