; Performance: 0078_reverse_array4_i32
; tags = algorithm, heap, i32, memory
; Why hard: In-place reverse with two pointers.
; Reveals: Two indices, load/store swap on heap.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0078_reverse_array4_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Pointers cross without stopping; reads after free if paired
;   wrong.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn reverse4
      (params
        (items ptr)
      ) ;; params
      (returns i32)
      (do
        (let left i32
          (const_i32 0)
        ) ;; let

        (let right i32
          (const_i32 3)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get left)
              (local_get right)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let tmp i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get left)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (store_i32
              (call_ptr elem_ptr
                (param_get items)
                (local_get left)
              ) ;; call_ptr
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get right)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; store_i32

            (store_i32
              (call_ptr elem_ptr
                (param_get items)
                (local_get right)
              ) ;; call_ptr
              (local_get tmp)
            ) ;; store_i32

            (set left
              (add_i32
                (local_get left)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set

            (set right
              (sub_i32
                (local_get right)
                (const_i32 1)
              ) ;; sub_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (load_i32
            (call_ptr elem_ptr
              (param_get items)
              (const_i32 1)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 10))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 20))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 30))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 40))

        (let mid i32
          (call_i32 reverse4
            (local_get items)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (add_i32
            (local_get mid)
            (const_i32 5)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
