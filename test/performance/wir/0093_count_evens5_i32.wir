; Performance: 0093_count_evens5_i32
; tags = algorithm, i32, memory
; Why hard: Count evens in five elements. Mod 2 on loaded values.
; Reveals: load, mod, branch, add count.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0093_count_evens5_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Counts odds; mod lowered to and wrong.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn count_evens5
      (params
        (items ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (let evens i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 5)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (load_i32
                      (call_ptr elem_ptr
                        (param_get items)
                        (local_get i)
                      ) ;; call_ptr
                    ) ;; load_i32
                    (const_i32 2)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set evens
                    (add_i32
                      (local_get evens)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get evens)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 20)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 1))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 2))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 3))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 4))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 5))

        (let n i32
          (call_i32 count_evens5
            (local_get items)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get n)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
