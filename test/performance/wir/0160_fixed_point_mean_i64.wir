; Performance: 0160_fixed_point_mean_i64
; Why hard: Fixed-point mean of i64 samples (float proxy).
; Reveals: div_i64 after sum loop over heap array.
; If LLVM regresses: Division before sum complete; scale factor applied twice.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (a ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i64_at
            (param_get a)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i64_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn mean_scaled
      (params
        (a ptr)
        (count i32)
      ) ;; params
      (returns i64)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (let sum i64
          (const_i64 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (param_get count)
            ) ;; lt_i32
          ) ;; condition
          (do
            (set sum
              (add_i64
                (local_get sum)
                (load_i64
                  (call_ptr elem
                    (param_get a)
                    (local_get i)
                  ) ;; call_ptr
                ) ;; load_i64
              ) ;; add_i64
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (div_i64
            (local_get sum)
            (cast_i32_to_i64
              (param_get count)
            ) ;; cast_i32_to_i64
          ) ;; div_i64
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 48)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get a)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i64 (call_ptr elem (local_get a) (const_i32 0)) (const_i64 1500))
        (store_i64 (call_ptr elem (local_get a) (const_i32 1)) (const_i64 2500))
        (store_i64 (call_ptr elem (local_get a) (const_i32 2)) (const_i64 3500))
        (store_i64 (call_ptr elem (local_get a) (const_i32 3)) (const_i64 4500))
        (store_i64 (call_ptr elem (local_get a) (const_i32 4)) (const_i64 5500))
        (store_i64 (call_ptr elem (local_get a) (const_i32 5)) (const_i64 6500))

        (let avg i64
          (call_i64 mean_scaled
            (local_get a)
            (const_i32 6)
          ) ;; call_i64
        ) ;; let

        (call_void free
          (local_get a)
        ) ;; call_void

        (return
          (cast_i64_to_i32
            (div_i64
              (local_get avg)
              (const_i64 10)
            ) ;; div_i64
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
