; Algorithm: Collatz steps for a small integer
; Tests: branch-heavy scalar loop state and modulo condition lowering
(core-module
  (core-version 1)
  (decls
    (fn collatz_steps
      (params
        (start i32)
      ) ;; params
      (returns i32)
      (do
        (let n i32
          (param_get start)
        ) ;; let

        (let steps i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (ne_i32
              (local_get n)
              (const_i32 1)
            ) ;; ne_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (local_get n)
                    (const_i32 2)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set n
                    (div_i32
                      (local_get n)
                      (const_i32 2)
                    ) ;; div_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (set n
                    (add_i32
                      (mul_i32
                        (local_get n)
                        (const_i32 3)
                      ) ;; mul_i32
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if

            (set steps
              (add_i32
                (local_get steps)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get steps)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (add_i32
            (call_i32 collatz_steps
              (const_i32 13)
            ) ;; call_i32
            (const_i32 33)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
