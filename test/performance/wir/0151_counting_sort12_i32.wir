; Performance: 0151_counting_sort12_i32
; Why hard: Counting sort twelve values range 0..5.
; Reveals: Count array, prefix, scatter phases.
; If LLVM regresses: Prefix sum wrong; unstable scatter; count index off-by-one.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (a ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get a)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn counting_sort12
      (params
        (src ptr)
        (dst ptr)
      ) ;; params
      (returns i32)
      (do
        (let cnt ptr
          (call_ptr malloc
            (const_i64 24)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get cnt)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let z i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get z)
              (const_i32 6)
            ) ;; lt_i32
          ) ;; condition
          (do
            (store_i32
              (call_ptr elem
                (local_get cnt)
                (local_get z)
              ) ;; call_ptr
              (const_i32 0)
            ) ;; store_i32

            (set z
              (add_i32
                (local_get z)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 12)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let v i32
              (load_i32
                (call_ptr elem
                  (param_get src)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (let cptr ptr
              (call_ptr elem
                (local_get cnt)
                (local_get v)
              ) ;; call_ptr
            ) ;; let

            (store_i32
              (local_get cptr)
              (add_i32
                (load_i32
                  (local_get cptr)
                ) ;; load_i32
                (const_i32 1)
              ) ;; add_i32
            ) ;; store_i32

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (let total i32
          (const_i32 0)
        ) ;; let

        (let k i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get k)
              (const_i32 6)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let prev i32
              (load_i32
                (call_ptr elem
                  (local_get cnt)
                  (sub_i32
                    (local_get k)
                    (const_i32 1)
                  ) ;; sub_i32
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (let cur i32
              (load_i32
                (call_ptr elem
                  (local_get cnt)
                  (local_get k)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (store_i32
              (call_ptr elem
                (local_get cnt)
                (local_get k)
              ) ;; call_ptr
              (add_i32
                (local_get prev)
                (local_get cur)
              ) ;; add_i32
            ) ;; store_i32

            (set k
              (add_i32
                (local_get k)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (let j i32
          (const_i32 11)
        ) ;; let

        (while
          (condition
            (ge_i32
              (local_get j)
              (const_i32 0)
            ) ;; ge_i32
          ) ;; condition
          (do
            (let v2 i32
              (load_i32
                (call_ptr elem
                  (param_get src)
                  (local_get j)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (let pos i32
              (sub_i32
                (load_i32
                  (call_ptr elem
                    (local_get cnt)
                    (local_get v2)
                  ) ;; call_ptr
                ) ;; load_i32
                (const_i32 1)
              ) ;; sub_i32
            ) ;; let

            (store_i32
              (call_ptr elem
                (param_get dst)
                (local_get pos)
              ) ;; call_ptr
              (local_get v2)
            ) ;; store_i32

            (store_i32
              (call_ptr elem
                (local_get cnt)
                (local_get v2)
              ) ;; call_ptr
              (local_get pos)
            ) ;; store_i32

            (set total
              (add_i32
                (local_get total)
                (local_get v2)
              ) ;; add_i32
            ) ;; set

            (set j
              (sub_i32
                (local_get j)
                (const_i32 1)
              ) ;; sub_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (call_void free
          (local_get cnt)
        ) ;; call_void

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let src ptr
          (call_ptr malloc
            (const_i64 48)
          ) ;; call_ptr
        ) ;; let

        (let dst ptr
          (call_ptr malloc
            (const_i64 48)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (or_bool
              (eq_ptr
                (local_get src)
                (const_null)
              ) ;; eq_ptr
              (eq_ptr
                (local_get dst)
                (const_null)
              ) ;; eq_ptr
            ) ;; or_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem (local_get src) (const_i32 0)) (const_i32 3))
        (store_i32 (call_ptr elem (local_get src) (const_i32 1)) (const_i32 1))
        (store_i32 (call_ptr elem (local_get src) (const_i32 2)) (const_i32 4))
        (store_i32 (call_ptr elem (local_get src) (const_i32 3)) (const_i32 1))
        (store_i32 (call_ptr elem (local_get src) (const_i32 4)) (const_i32 5))
        (store_i32 (call_ptr elem (local_get src) (const_i32 5)) (const_i32 0))
        (store_i32 (call_ptr elem (local_get src) (const_i32 6)) (const_i32 2))
        (store_i32 (call_ptr elem (local_get src) (const_i32 7)) (const_i32 4))
        (store_i32 (call_ptr elem (local_get src) (const_i32 8)) (const_i32 5))
        (store_i32 (call_ptr elem (local_get src) (const_i32 9)) (const_i32 3))
        (store_i32 (call_ptr elem (local_get src) (const_i32 10)) (const_i32 5))
        (store_i32 (call_ptr elem (local_get src) (const_i32 11)) (const_i32 1))

        (let sum i32
          (call_i32 counting_sort12
            (local_get src)
            (local_get dst)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get src)
        ) ;; call_void

        (call_void free
          (local_get dst)
        ) ;; call_void

        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
