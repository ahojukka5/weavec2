; Performance: 0036_mul_i32
; Why hard: Smoke baseline for multiplication. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: mul_i32
; If LLVM regresses: mul lowered to shifts incorrectly for non-power-of-two.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (mul_i32
            (const_i32 6)
            (const_i32 7)
          ) ;; mul_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
