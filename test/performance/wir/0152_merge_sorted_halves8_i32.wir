; Stress: merge two sorted halves (4+4) into output buffer
; Reveals: twin-pointer loop, compare branches, heap stores
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (a ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get a)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn merge8
      (params
        (left ptr)
        (right ptr)
        (out ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (let j i32
          (const_i32 0)
        ) ;; let

        (let k i32
          (const_i32 0)
        ) ;; let

        (let checksum i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get k)
              (const_i32 8)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (and_bool
                  (lt_i32
                    (local_get i)
                    (const_i32 4)
                  ) ;; lt_i32
                  (or_bool
                    (ge_i32
                      (local_get j)
                      (const_i32 4)
                    ) ;; ge_i32
                    (le_i32
                      (load_i32
                        (call_ptr elem
                          (param_get left)
                          (local_get i)
                        ) ;; call_ptr
                      ) ;; load_i32
                      (load_i32
                        (call_ptr elem
                          (param_get right)
                          (local_get j)
                        ) ;; call_ptr
                      ) ;; load_i32
                    ) ;; le_i32
                  ) ;; or_bool
                ) ;; and_bool
              ) ;; condition
              (then
                (do
                  (let v i32
                    (load_i32
                      (call_ptr elem
                        (param_get left)
                        (local_get i)
                      ) ;; call_ptr
                    ) ;; load_i32
                  ) ;; let

                  (store_i32
                    (call_ptr elem
                      (param_get out)
                      (local_get k)
                    ) ;; call_ptr
                    (local_get v)
                  ) ;; store_i32

                  (set checksum
                    (add_i32
                      (local_get checksum)
                      (local_get v)
                    ) ;; add_i32
                  ) ;; set

                  (set i
                    (add_i32
                      (local_get i)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (let w i32
                    (load_i32
                      (call_ptr elem
                        (param_get right)
                        (local_get j)
                      ) ;; call_ptr
                    ) ;; load_i32
                  ) ;; let

                  (store_i32
                    (call_ptr elem
                      (param_get out)
                      (local_get k)
                    ) ;; call_ptr
                    (local_get w)
                  ) ;; store_i32

                  (set checksum
                    (add_i32
                      (local_get checksum)
                      (local_get w)
                    ) ;; add_i32
                  ) ;; set

                  (set j
                    (add_i32
                      (local_get j)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if

            (set k
              (add_i32
                (local_get k)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get checksum)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let left ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (let right ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (let out ptr
          (call_ptr malloc
            (const_i64 32)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (or_bool
              (eq_ptr
                (local_get left)
                (const_null)
              ) ;; eq_ptr
              (or_bool
                (eq_ptr
                  (local_get right)
                  (const_null)
                ) ;; eq_ptr
                (eq_ptr
                  (local_get out)
                  (const_null)
                ) ;; eq_ptr
              ) ;; or_bool
            ) ;; or_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem (local_get left) (const_i32 0)) (const_i32 1))
        (store_i32 (call_ptr elem (local_get left) (const_i32 1)) (const_i32 5))
        (store_i32 (call_ptr elem (local_get left) (const_i32 2)) (const_i32 9))
        (store_i32 (call_ptr elem (local_get left) (const_i32 3)) (const_i32 13))

        (store_i32 (call_ptr elem (local_get right) (const_i32 0)) (const_i32 2))
        (store_i32 (call_ptr elem (local_get right) (const_i32 1)) (const_i32 6))
        (store_i32 (call_ptr elem (local_get right) (const_i32 2)) (const_i32 10))
        (store_i32 (call_ptr elem (local_get right) (const_i32 3)) (const_i32 14))

        (let sum i32
          (call_i32 merge8
            (local_get left)
            (local_get right)
            (local_get out)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get left)
        ) ;; call_void

        (call_void free
          (local_get right)
        ) ;; call_void

        (call_void free
          (local_get out)
        ) ;; call_void

        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
