; Algorithm: trace of a 2x2 i32 matrix stored row-major on heap
; Tests: small fixed-size array addressing
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn trace2x2
      (params
        (m ptr)
      ) ;; params
      (returns i32)
      (do
        (return
          (add_i32
            (load_i32
              (call_ptr elem_ptr
                (param_get m)
                (const_i32 0)
              ) ;; call_ptr
            ) ;; load_i32
            (load_i32
              (call_ptr elem_ptr
                (param_get m)
                (const_i32 3)
              ) ;; call_ptr
            ) ;; load_i32
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let m ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get m)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get m) (const_i32 0)) (const_i32 11))
        (store_i32 (call_ptr elem_ptr (local_get m) (const_i32 1)) (const_i32 2))
        (store_i32 (call_ptr elem_ptr (local_get m) (const_i32 2)) (const_i32 3))
        (store_i32 (call_ptr elem_ptr (local_get m) (const_i32 3)) (const_i32 17))

        (let t i32
          (call_i32 trace2x2
            (local_get m)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get m)
        ) ;; call_void

        (return
          (local_get t)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
