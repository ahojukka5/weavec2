; Performance: 0015_ptr_null
; tags = i32, smoke
; Why hard: Smoke baseline for null pointer. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: const_null, eq_ptr
; Expected: Golden LLVM matches test/performance/expected-llvm/0015_ptr_null.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: null not typed as pointer; comparison lowered to integer
;   eq.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (eq_ptr
              (const_null)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (if
                (condition
                  (ne_ptr
                    (const_null)
                    (const_null)
                  ) ;; ne_ptr
                ) ;; condition
                (then
                  (do
                    (return
                      (const_i32 0)
                    ) ;; return
                  ) ;; do
                ) ;; then
                (else
                  (do
                    (return
                      (const_i32 42)
                    ) ;; return
                  ) ;; do
                ) ;; else
              ) ;; if
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
