; Performance: 0121_second_max5_i32
; Why hard: Second largest of five. Two-pass reduction.
; Reveals: two linear scans.
; If LLVM regresses: Returns max not second; first pass wrong.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn max5
      (params
        (items ptr)
      ) ;; params
      (returns i32)
      (do
        (let m i32
          (load_i32
            (call_ptr elem_ptr
              (param_get items)
              (const_i32 0)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; let

        (let i i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 5)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let v i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (if
              (condition
                (gt_i32
                  (local_get v)
                  (local_get m)
                ) ;; gt_i32
              ) ;; condition
              (then
                (do
                  (set m
                    (local_get v)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get m)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn second_below_max5
      (params
        (items ptr)
        (maxv i32)
      ) ;; params
      (returns i32)
      (do
        (let second i32
          (const_i32 -2147483648)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 5)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let v i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (if
              (condition
                (and_bool
                  (lt_i32
                    (local_get v)
                    (param_get maxv)
                  ) ;; lt_i32
                  (gt_i32
                    (local_get v)
                    (local_get second)
                  ) ;; gt_i32
                ) ;; and_bool
              ) ;; condition
              (then
                (do
                  (set second
                    (local_get v)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get second)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 20)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 3))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 9))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 5))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 9))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 1))

        (let maxv i32
          (call_i32 max5
            (local_get items)
          ) ;; call_i32
        ) ;; let

        (let s i32
          (call_i32 second_below_max5
            (local_get items)
            (local_get maxv)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get s)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
