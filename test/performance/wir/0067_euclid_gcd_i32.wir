; Performance: 0067_euclid_gcd_i32
; Why hard: Euclidean GCD; mod in tight while.
; Reveals: mod_i32, carried x/y until y==0.
; If LLVM regresses: Uses subtraction loop wrong; mod with div by zero guard missing.
(core-module
  (core-version 1)
  (decls
    (fn gcd
      (params
        (a i32)
        (b i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get a)
        ) ;; let

        (let y i32
          (param_get b)
        ) ;; let

        (while
          (condition
            (ne_i32
              (local_get y)
              (const_i32 0)
            ) ;; ne_i32
          ) ;; condition
          (do
            (let r i32
              (mod_i32
                (local_get x)
                (local_get y)
              ) ;; mod_i32
            ) ;; let

            (set x
              (local_get y)
            ) ;; set

            (set y
              (local_get r)
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (add_i32
            (call_i32 gcd
              (const_i32 462)
              (const_i32 1071)
            ) ;; call_i32
            (const_i32 21)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
