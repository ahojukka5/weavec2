; Performance: 0165_const_f32_add
; tags = f32, float, stress
; Why hard: f32 smoke: literal add and fptosi return.
; Reveals: const_f32, fadd, cast_f32_to_i32.
; Expected: main returns 5 (float 2+3, fptosi). llvm-as accepts emitted IR; opt
;   -passes=mem2reg is an optional extra check.
; If LLVM regresses: fadd typed as double add; literal parsed as integer; cast
;   omitted.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (cast_f32_to_i32
            (add_f32
              (const_f32 2)
              (const_f32 3)
            ) ;; add_f32
          ) ;; cast_f32_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
