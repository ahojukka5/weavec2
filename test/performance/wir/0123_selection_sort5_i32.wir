; Algorithm: selection sort on five heap-backed i32 values
; Tests: nested loops finding minimum index and swapping
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn selection_sort5
      (params
        (items ptr)
      ) ;; params
      (returns void)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let min_idx i32
              (local_get i)
            ) ;; let

            (let j i32
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; let

            (while
              (condition
                (lt_i32
                  (local_get j)
                  (const_i32 5)
                ) ;; lt_i32
              ) ;; condition
              (do
                (if
                  (condition
                    (lt_i32
                      (load_i32
                        (call_ptr elem_ptr
                          (param_get items)
                          (local_get j)
                        ) ;; call_ptr
                      ) ;; load_i32
                      (load_i32
                        (call_ptr elem_ptr
                          (param_get items)
                          (local_get min_idx)
                        ) ;; call_ptr
                      ) ;; load_i32
                    ) ;; lt_i32
                  ) ;; condition
                  (then
                    (do
                      (set min_idx
                        (local_get j)
                      ) ;; set
                    ) ;; do
                  ) ;; then
                  (else
                    (do)
                  ) ;; else
                ) ;; if

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (let tmp i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (store_i32
              (call_ptr elem_ptr
                (param_get items)
                (local_get i)
              ) ;; call_ptr
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get min_idx)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; store_i32

            (store_i32
              (call_ptr elem_ptr
                (param_get items)
                (local_get min_idx)
              ) ;; call_ptr
              (local_get tmp)
            ) ;; store_i32

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 20)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 9))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 2))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 7))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 1))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 5))

        (call_void selection_sort5
          (local_get items)
        ) ;; call_void

        (let mid i32
          (load_i32
            (call_ptr elem_ptr
              (local_get items)
              (const_i32 2)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get mid)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
