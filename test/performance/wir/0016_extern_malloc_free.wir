; Performance: 0016_extern_malloc_free
; tags = call, heap, i32, smoke
; Why hard: Smoke baseline for extern calls. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: declare malloc/free, call_ptr/call_void
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0016_extern_malloc_free.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Missing declare; wrong signature; call not marked
;   correctly.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr malloc
            (const_i64 8)
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (call_void free
                (local_get p)
              ) ;; call_void
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
