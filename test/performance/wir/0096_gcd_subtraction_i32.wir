; Performance: 0096_gcd_subtraction_i32
; Why hard: GCD by subtraction. Many iterations vs modulo GCD.
; Reveals: sub in loop until equal.
; If LLVM regresses: Infinite loop when equal case not handled.
(core-module
  (core-version 1)
  (decls
    (fn gcd_sub
      (params
        (a i32)
        (b i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get a)
        ) ;; let

        (let y i32
          (param_get b)
        ) ;; let

        (while
          (condition
            (ne_i32
              (local_get x)
              (local_get y)
            ) ;; ne_i32
          ) ;; condition
          (do
            (if
              (condition
                (gt_i32
                  (local_get x)
                  (local_get y)
                ) ;; gt_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (sub_i32
                      (local_get x)
                      (local_get y)
                    ) ;; sub_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (set y
                    (sub_i32
                      (local_get y)
                      (local_get x)
                    ) ;; sub_i32
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 gcd_sub
            (const_i32 54)
            (const_i32 24)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
