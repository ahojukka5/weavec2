; Performance: 0003_add
; tags = i32, smoke
; Why hard: Smoke baseline for binary add. Failures here usually indicate broken
;   lowering shared by every later fixture.
; Reveals: add_i32 of two constants
; Expected: main returns 42 (20 + 22). llvm-as accepts emitted IR; opt
;   -passes=mem2reg
;   is an optional extra check.
; If LLVM regresses: Uses sub/mul or leaves add in wrong width (i64 vs i32).
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (add_i32
            (const_i32 20)
            (const_i32 22)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
