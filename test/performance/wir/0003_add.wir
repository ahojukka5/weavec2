; Performance: 0003_add
; Why hard: Smoke baseline for binary add. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: add_i32 of two constants
; If LLVM regresses: Uses sub/mul or leaves add in wrong width (i64 vs i32).
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (add_i32
            (const_i32 20)
            (const_i32 22)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
