; Performance: 0087_popcount_i32
; tags = algorithm, bitwise, i32
; Why hard: Population count by halving. Repeated div/mod 2 until zero.
; Reveals: shr or div by 2, add to count.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0087_popcount_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Counts one extra; uses arithmetic shift on negative.
(core-module
  (core-version 1)
  (decls
    (fn popcount
      (params
        (v i32)
      ) ;; params
      (returns i32)
      (do
        (let n i32
          (param_get v)
        ) ;; let

        (let bits i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (gt_i32
              (local_get n)
              (const_i32 0)
            ) ;; gt_i32
          ) ;; condition
          (do
            (if
              (condition
                (ne_i32
                  (mod_i32
                    (local_get n)
                    (const_i32 2)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; ne_i32
              ) ;; condition
              (then
                (do
                  (set bits
                    (add_i32
                      (local_get bits)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set n
              (div_i32
                (local_get n)
                (const_i32 2)
              ) ;; div_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get bits)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 popcount
            (const_i32 29)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
