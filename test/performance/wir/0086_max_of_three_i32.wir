; Performance: 0086_max_of_three_i32
; tags = algorithm, i32
; Why hard: Max of three without loop. Nested compares only—joins must be clean.
; Reveals: Chained if/compare, no loop.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0086_max_of_three_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Wrong compare polarity picks min instead of max.
(core-module
  (core-version 1)
  (decls
    (fn max3
      (params
        (a i32)
        (b i32)
        (c i32)
      ) ;; params
      (returns i32)
      (do
        (let m i32
          (param_get a)
        ) ;; let

        (if
          (condition
            (gt_i32
              (param_get b)
              (local_get m)
            ) ;; gt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get b)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (gt_i32
              (param_get c)
              (local_get m)
            ) ;; gt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get c)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (local_get m)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 max3
            (const_i32 17)
            (const_i32 42)
            (const_i32 23)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
