; Performance: 0041_load_store_ptr
; tags = i32, memory, smoke
; Why hard: Smoke baseline for ptr load/store. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: load_i32 through ptr
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0041_load_store_ptr.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Missing align on load; TBAA broken for heap slot.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn main
      (params)
      (returns i32)
      (do
        (let slot ptr
          (call_ptr malloc
            (const_i64 8)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get slot)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let data ptr
          (call_ptr malloc
            (const_i64 8)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get data)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (call_void free
                (local_get slot)
              ) ;; call_void
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_ptr
          (local_get slot)
          (local_get data)
        ) ;; store_ptr

        (let loaded ptr
          (load_ptr
            (local_get slot)
          ) ;; load_ptr
        ) ;; let

        (store_i64
          (local_get loaded)
          (const_i64 42)
        ) ;; store_i64

        (let value i64
          (load_i64
            (local_get data)
          ) ;; load_i64
        ) ;; let

        (call_void free
          (local_get data)
        ) ;; call_void

        (call_void free
          (local_get slot)
        ) ;; call_void

        (return
          (cast_i64_to_i32
            (local_get value)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
