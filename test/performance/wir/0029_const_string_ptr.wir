; Performance: 0029_const_string_ptr
; Why hard: Smoke baseline for string in expr. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: const_string_ptr as value
; If LLVM regresses: Double indirection or string not merged as constant.
(core-module
  (core-version 1)
  (decls
    (extern puts
      (params
        (s ptr)
      ) ;; params
      (returns i32)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (call_i32 puts
          (const_string_ptr "hello from const_string_ptr")
        ) ;; call_i32
        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
