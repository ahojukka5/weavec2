; Performance: 0171_factorial12_i64
; tags = i64, stress
; Why hard: Factorial 12 with i64 product (phi gap vs i32 factorial).
; Reveals: mul_i64, cast_i32_to_i64, mod_i64.
; Expected: main returns 12! mod 1_000_000_007 as i32. llvm-as accepts emitted
;   IR; opt
;   -passes=mem2reg is an optional extra check.
; If LLVM regresses: Redundant alloca traffic: repeated load/store of the same
;   slot each
;   iteration instead of keeping values in registers after mem2reg.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32 (const_i32 2))
        (let acc i64 (const_i64 1))
        (while
          (condition (le_i32 (local_get i) (const_i32 12)))
          (do
            (set acc
              (mul_i64
                (local_get acc)
                (cast_i32_to_i64 (local_get i))
              )
            )
            (set i (add_i32 (local_get i) (const_i32 1)))
          )
        )
        (return
          (cast_i64_to_i32
            (mod_i64 (local_get acc) (const_i64 1000000007))
          )
        )
      )
    )
  )
)
