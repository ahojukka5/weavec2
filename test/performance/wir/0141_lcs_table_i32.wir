; Performance: 0141_lcs_table_i32
; tags = dp, heap, i32, stress
; Why hard: LCS DP 9x9 table on two length-8 strings.
; Reveals: 2D heap DP, max of three predecessors, nested loops.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0141_lcs_table_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Table fill order wrong; max of three paths broken; stride
;   errors.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn at
      (params
        (t ptr)
        (i i32)
        (j i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get t)
            (cast_i32_to_i64
              (add_i32
                (mul_i32
                  (param_get i)
                  (const_i32 9)
                ) ;; mul_i32
                (param_get j)
              ) ;; add_i32
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn lcs8
      (params
        (t ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 8)
            ) ;; le_i32
          ) ;; condition
          (do
            (let j i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (le_i32
                  (local_get j)
                  (const_i32 8)
                ) ;; le_i32
              ) ;; condition
              (do
                (if
                  (condition
                    (or_bool
                      (eq_i32
                        (local_get i)
                        (const_i32 0)
                      ) ;; eq_i32
                      (eq_i32
                        (local_get j)
                        (const_i32 0)
                      ) ;; eq_i32
                    ) ;; or_bool
                  ) ;; condition
                  (then
                    (do
                      (store_i32
                        (call_ptr at
                          (param_get t)
                          (local_get i)
                          (local_get j)
                        ) ;; call_ptr
                        (const_i32 0)
                      ) ;; store_i32
                    ) ;; do
                  ) ;; then
                  (else
                    (do
                      (let up i32
                        (load_i32
                          (call_ptr at
                            (param_get t)
                            (sub_i32
                              (local_get i)
                              (const_i32 1)
                            ) ;; sub_i32
                            (local_get j)
                          ) ;; call_ptr
                        ) ;; load_i32
                      ) ;; let

                      (let left i32
                        (load_i32
                          (call_ptr at
                            (param_get t)
                            (local_get i)
                            (sub_i32
                              (local_get j)
                              (const_i32 1)
                            ) ;; sub_i32
                          ) ;; call_ptr
                        ) ;; load_i32
                      ) ;; let

                      (let diag i32
                        (load_i32
                          (call_ptr at
                            (param_get t)
                            (sub_i32
                              (local_get i)
                              (const_i32 1)
                            ) ;; sub_i32
                            (sub_i32
                              (local_get j)
                              (const_i32 1)
                            ) ;; sub_i32
                          ) ;; call_ptr
                        ) ;; load_i32
                      ) ;; let

                      (let cand i32
                        (add_i32
                          (local_get diag)
                          (const_i32 1)
                        ) ;; add_i32
                      ) ;; let

                      (if
                        (condition
                          (gt_i32
                            (local_get cand)
                            (local_get up)
                          ) ;; gt_i32
                        ) ;; condition
                        (then
                          (do
                            (if
                              (condition
                                (gt_i32
                                  (local_get cand)
                                  (local_get left)
                                ) ;; gt_i32
                              ) ;; condition
                              (then
                                (do
                                  (store_i32
                                    (call_ptr at
                                      (param_get t)
                                      (local_get i)
                                      (local_get j)
                                    ) ;; call_ptr
                                    (local_get cand)
                                  ) ;; store_i32
                                ) ;; do
                              ) ;; then
                              (else
                                (do
                                  (store_i32
                                    (call_ptr at
                                      (param_get t)
                                      (local_get i)
                                      (local_get j)
                                    ) ;; call_ptr
                                    (local_get left)
                                  ) ;; store_i32
                                ) ;; do
                              ) ;; else
                            ) ;; if
                          ) ;; do
                        ) ;; then
                        (else
                          (do
                            (if
                              (condition
                                (gt_i32
                                  (local_get left)
                                  (local_get up)
                                ) ;; gt_i32
                              ) ;; condition
                              (then
                                (do
                                  (store_i32
                                    (call_ptr at
                                      (param_get t)
                                      (local_get i)
                                      (local_get j)
                                    ) ;; call_ptr
                                    (local_get left)
                                  ) ;; store_i32
                                ) ;; do
                              ) ;; then
                              (else
                                (do
                                  (store_i32
                                    (call_ptr at
                                      (param_get t)
                                      (local_get i)
                                      (local_get j)
                                    ) ;; call_ptr
                                    (local_get up)
                                  ) ;; store_i32
                                ) ;; do
                              ) ;; else
                            ) ;; if
                          ) ;; do
                        ) ;; else
                      ) ;; if
                    ) ;; do
                  ) ;; else
                ) ;; if

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (load_i32
            (call_ptr at
              (param_get t)
              (const_i32 8)
              (const_i32 8)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let t ptr
          (call_ptr malloc
            (const_i64 324)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get t)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let ans i32
          (call_i32 lcs8
            (local_get t)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get t)
        ) ;; call_void

        (return
          (local_get ans)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
