; Performance: 0065_mandelbrot_escape_i32
; tags = algorithm, i32
; Why hard: Iterative complex escape; many mul/add in inner loop.
; Reveals: Nested loops, div/mul on i32 iterates.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0065_mandelbrot_escape_i32.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Inner loop never exits; escape count wrong due to div
;   rounding.
(core-module
  (core-version 1)
  (decls
    (fn escape_count
      (params
        (cx i32)
        (cy i32)
        (max_iter i32)
      ) ;; params
      (returns i32)
      (do
        (let zx i32
          (const_i32 0)
        ) ;; let

        (let zy i32
          (const_i32 0)
        ) ;; let

        (let iter i32
          (const_i32 0)
        ) ;; let

        (let active i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (and_bool
              (lt_i32
                (local_get iter)
                (param_get max_iter)
              ) ;; lt_i32
              (ne_i32
                (local_get active)
                (const_i32 0)
              ) ;; ne_i32
            ) ;; and_bool
          ) ;; condition
          (do
            (let zx2 i32
              (div_i32
                (mul_i32
                  (local_get zx)
                  (local_get zx)
                ) ;; mul_i32
                (const_i32 1000)
              ) ;; div_i32
            ) ;; let

            (let zy2 i32
              (div_i32
                (mul_i32
                  (local_get zy)
                  (local_get zy)
                ) ;; mul_i32
                (const_i32 1000)
              ) ;; div_i32
            ) ;; let

            (let radius2 i32
              (add_i32
                (local_get zx2)
                (local_get zy2)
              ) ;; add_i32
            ) ;; let

            (if
              (condition
                (gt_i32
                  (local_get radius2)
                  (const_i32 4000)
                ) ;; gt_i32
              ) ;; condition
              (then
                (do
                  (set active
                    (const_i32 0)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (let two_zx_zy i32
                    (div_i32
                      (mul_i32
                        (mul_i32
                          (const_i32 2)
                          (local_get zx)
                        ) ;; mul_i32
                        (local_get zy)
                      ) ;; mul_i32
                      (const_i32 1000)
                    ) ;; div_i32
                  ) ;; let

                  (set zy
                    (add_i32
                      (local_get two_zx_zy)
                      (param_get cy)
                    ) ;; add_i32
                  ) ;; set

                  (set zx
                    (add_i32
                      (sub_i32
                        (local_get zx2)
                        (local_get zy2)
                      ) ;; sub_i32
                      (param_get cx)
                    ) ;; add_i32
                  ) ;; set

                  (set iter
                    (add_i32
                      (local_get iter)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return
          (local_get iter)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 escape_count
            (const_i32 1000)
            (const_i32 0)
            (const_i32 16)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
