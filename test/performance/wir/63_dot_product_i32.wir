; Algorithm: dot product over four i32 values
; Tests: loop-carried accumulator, pointer arithmetic, load/store, and calls
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn i32_at
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (ptr_add
            (param_get base)
            (mul_i64
              (cast_i32_to_i64
                (param_get index)
              ) ;; cast_i32_to_i64
              (const_i64 4)
            ) ;; mul_i64
          ) ;; ptr_add
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn dot4
      (params
        (a ptr)
        (b ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (let sum i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let av i32
              (load_i32
                (call_ptr i32_at
                  (param_get a)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (let bv i32
              (load_i32
                (call_ptr i32_at
                  (param_get b)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (set sum
              (add_i32
                (local_get sum)
                (mul_i32
                  (local_get av)
                  (local_get bv)
                ) ;; mul_i32
              ) ;; add_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (let b ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (or_bool
              (eq_ptr
                (local_get a)
                (const_null)
              ) ;; eq_ptr
              (eq_ptr
                (local_get b)
                (const_null)
              ) ;; eq_ptr
            ) ;; or_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr i32_at (local_get a) (const_i32 0)) (const_i32 1))
        (store_i32 (call_ptr i32_at (local_get a) (const_i32 1)) (const_i32 2))
        (store_i32 (call_ptr i32_at (local_get a) (const_i32 2)) (const_i32 3))
        (store_i32 (call_ptr i32_at (local_get a) (const_i32 3)) (const_i32 4))
        (store_i32 (call_ptr i32_at (local_get b) (const_i32 0)) (const_i32 5))
        (store_i32 (call_ptr i32_at (local_get b) (const_i32 1)) (const_i32 6))
        (store_i32 (call_ptr i32_at (local_get b) (const_i32 2)) (const_i32 7))
        (store_i32 (call_ptr i32_at (local_get b) (const_i32 3)) (const_i32 8))

        (let result i32
          (call_i32 dot4
            (local_get a)
            (local_get b)
          ) ;; call_i32
        ) ;; let

        (call_void free (local_get b))
        (call_void free (local_get a))

        (return
          (local_get result)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
