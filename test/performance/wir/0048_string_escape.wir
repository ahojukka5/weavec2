(core-module
  (core-version 1)
  (decls
    (extern puts
      (params
        (text ptr)
      ) ;; params
      (returns i32)
    ) ;; extern

    (fn main
      (params)
      (returns i32)
      (do
        (print
          (const_string "hello\nworld")
        ) ;; print

        (print
          (const_string "quote: \"weave\"")
        ) ;; print

        (print
          (const_string "backslash: \\")
        ) ;; print

        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
