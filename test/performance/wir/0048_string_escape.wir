; Performance: 0048_string_escape
; tags = i32, smoke
; Why hard: Smoke baseline for escaped string. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: special chars in literal
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0048_string_escape.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Broken escape in .ll string constant.
(core-module
  (core-version 1)
  (decls
    (extern puts
      (params
        (text ptr)
      ) ;; params
      (returns i32)
    ) ;; extern

    (fn main
      (params)
      (returns i32)
      (do
        (print
          (const_string "hello\nworld")
        ) ;; print

        (print
          (const_string "quote: \"weave\"")
        ) ;; print

        (print
          (const_string "backslash: \\")
        ) ;; print

        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
