; Performance: 0037_div_i32
; Why hard: Smoke baseline for signed division. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: div_i32 -> sdiv
; If LLVM regresses: Uses udiv or divides before sign extension.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (div_i32
            (const_i32 126)
            (const_i32 3)
          ) ;; div_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
