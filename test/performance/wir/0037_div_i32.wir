; Performance: 0037_div_i32
; tags = i32, smoke
; Why hard: Smoke baseline for signed division. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: div_i32 -> sdiv
; Expected: Golden LLVM matches test/performance/expected-llvm/0037_div_i32.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Uses udiv or divides before sign extension.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (div_i32
            (const_i32 126)
            (const_i32 3)
          ) ;; div_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
