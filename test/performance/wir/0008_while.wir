; Performance: 0008_while
; tags = i32, loop, loop-phi, smoke
; Why hard: Smoke baseline for while loop. Failures here usually indicate broken
;   lowering shared by every later fixture.
; Reveals: condition block, backedge, carried i
; Expected: main returns sum 0..n for configured n (see golden). llvm-as accepts
;   emitted
;   IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: No backedge to header, phi missing for i, or body executed
;   one extra time.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let
        (let sum i32
          (const_i32 0)
        ) ;; let
        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 7)
            ) ;; lt_i32
          ) ;; condition
          (do
            (set sum
              (add_i32
                (local_get sum)
                (const_i32 6)
              ) ;; add_i32
            ) ;; set
            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while
        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
