; Performance: 0139_loop_twin_parallel_if_i32
; Why hard: Two parallel if ladders (i==0 and i==1) each update x in one iteration.
; Reveals: sequential sibling if merges, loop header phi for x, merge suffix preds.
; If LLVM regresses: missing .merge after first if; second set clobbers phi; wrong latch edge.
(core-module
  (core-version 1)
  (decls
    (fn run
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 0)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (local_get i)
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (add_i32
                      (local_get x)
                      (const_i32 10)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (if
              (condition
                (eq_i32
                  (local_get i)
                  (const_i32 1)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (add_i32
                      (local_get x)
                      (const_i32 100)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 run
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
