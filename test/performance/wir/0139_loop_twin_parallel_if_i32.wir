; Performance: 0139_loop_twin_parallel_if_i32
; tags = i32, if-merge, loop, loop-phi, stress
; Why hard: Twin parallel if ladders updating x when i is 0 and 1 in same trip.
; Reveals: Sibling if merges, loop phi on x, merge/latch operand wiring.
; Expected: main returns 110 (x+=10 at i=0, +=100 at i=1). llvm-as accepts
;   emitted IR;
;   opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Broken loop header phis or missing .merge blocks: carried
;   locals reload from
;   stack every iteration, wrong backedge operands, or SSA violations after
;   llvm-as.
(core-module
  (core-version 1)
  (decls
    (fn run
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 0)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (local_get i)
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (add_i32
                      (local_get x)
                      (const_i32 10)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (if
              (condition
                (eq_i32
                  (local_get i)
                  (const_i32 1)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (add_i32
                      (local_get x)
                      (const_i32 100)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 run
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
