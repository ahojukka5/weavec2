; Performance: 0175_sum_squares_i64
; tags = i64, loop, stress
; Why hard: Sum i*i for i=1..100 in i64; index promoted, acc on phi.
; Reveals: mul_i64, cast_i32_to_i64, add_i64 carried accumulator.
; Expected: main returns 338350 (sum of squares 1..100). llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: i64 acc stays on stack; redundant add-zero on set chain.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32 (const_i32 1))
        (let sum i64 (const_i64 0))
        (while
          (condition (le_i32 (local_get i) (const_i32 100)))
          (do
            (let sq i64
              (mul_i64
                (cast_i32_to_i64 (local_get i))
                (cast_i32_to_i64 (local_get i))))
            (set sum
              (add_i64 (local_get sum) (local_get sq)))
            (set i (add_i32 (local_get i) (const_i32 1)))
          )
        )
        (return (cast_i64_to_i32 (local_get sum)))
      )
    )
  )
)
