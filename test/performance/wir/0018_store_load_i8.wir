; Performance: 0018_store_load_i8
; tags = i32, memory, smoke
; Why hard: Smoke baseline for i8 memory. Failures here usually indicate broken
;   lowering
;   shared by every later fixture.
; Reveals: store_i8/load_i8
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0018_store_load_i8.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Extends/truncates wrong around i8 access.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr malloc
            (const_i64 1)
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if
        (store_i8
          (local_get p)
          (const_i32 42)
        ) ;; store_i8
        (let x i32
          (load_u8
            (local_get p)
          ) ;; load_u8
        ) ;; let
        (call_void free
          (local_get p)
        ) ;; call_void
        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
