; Performance: 0146_collatz_stats_i32
; tags = i32, loop, loop-phi, stress
; Why hard: Collatz for n=1..80 with max steps and sum.
; Reveals: Inner collatz while + outer batch, multiple carried locals.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0146_collatz_stats_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Broken loop header phis or missing .merge blocks: carried
;   locals reload from
;   stack every iteration, wrong backedge operands, or SSA violations after
;   llvm-as.
(core-module
  (core-version 1)
  (decls
    (fn collatz_steps
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get n)
        ) ;; let

        (let steps i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (ne_i32
              (local_get x)
              (const_i32 1)
            ) ;; ne_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (local_get x)
                    (const_i32 2)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (div_i32
                      (local_get x)
                      (const_i32 2)
                    ) ;; div_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (set x
                    (add_i32
                      (mul_i32
                        (local_get x)
                        (const_i32 3)
                      ) ;; mul_i32
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if

            (set steps
              (add_i32
                (local_get steps)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get steps)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let n i32
          (const_i32 1)
        ) ;; let

        (let max_steps i32
          (const_i32 0)
        ) ;; let

        (let sum_steps i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get n)
              (const_i32 80)
            ) ;; le_i32
          ) ;; condition
          (do
            (let s i32
              (call_i32 collatz_steps
                (local_get n)
              ) ;; call_i32
            ) ;; let

            (if
              (condition
                (gt_i32
                  (local_get s)
                  (local_get max_steps)
                ) ;; gt_i32
              ) ;; condition
              (then
                (do
                  (set max_steps
                    (local_get s)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set sum_steps
              (add_i32
                (local_get sum_steps)
                (local_get s)
              ) ;; add_i32
            ) ;; set

            (set n
              (add_i32
                (local_get n)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (add_i32
            (local_get max_steps)
            (local_get sum_steps)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
