; Performance: 0007_if
; Why hard: Smoke baseline for conditional branch. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: if with then/else joining
; If LLVM regresses: Missing join block, wrong branch condition polarity, or divergent types at merge.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (lt_i32
              (const_i32 1)
              (const_i32 2)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
