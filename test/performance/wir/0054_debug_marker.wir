; Performance: 0054_debug_marker
; Why hard: Ensures debug/provenance metadata does not perturb codegen shape.
; Reveals: Minimal body with marker-friendly structure.
; If LLVM regresses: Extra instructions inserted in every block; metadata becomes semantic by accident.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 40)
        ) ;; let

        (debug "this is my debug zone"
          (do
            (set x
              (add_i32
                (local_get x)
                (const_i32 2)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; debug

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
