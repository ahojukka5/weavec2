; Performance: 0130_harmonic_sum_i32
; Why hard: Truncated harmonic sum with int div. div_i32 each step—rounding sensitive.
; Reveals: div in accumulating loop.
; If LLVM regresses: Uses fp div; sum uses mul instead of div.
(core-module
  (core-version 1)
  (decls
    (fn harmonic_scaled
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (set total
              (add_i32
                (local_get total)
                (div_i32
                  (const_i32 1000)
                  (local_get i)
                ) ;; div_i32
              ) ;; add_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 harmonic_scaled
            (const_i32 10)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
