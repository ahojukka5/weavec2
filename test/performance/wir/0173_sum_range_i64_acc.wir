; Performance: 0173_sum_range_i64_acc
; tags = i64, loop, stress
; Why hard: Sum 1..200 into i64 total; i32 index only promoted.
; Reveals: add_i64, cast_i32_to_i64, wide accumulator.
; Expected: main returns 20100 (sum 1..200 as i32). llvm-as accepts emitted IR;
;   opt
;   -passes=mem2reg is an optional extra check.
; If LLVM regresses: Redundant alloca traffic: repeated load/store of the same
;   slot each
;   iteration instead of keeping values in registers after mem2reg.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32 (const_i32 1))
        (let total i64 (const_i64 0))
        (while
          (condition (le_i32 (local_get i) (const_i32 200)))
          (do
            (set total
              (add_i64
                (local_get total)
                (cast_i32_to_i64 (local_get i))
              )
            )
            (set i (add_i32 (local_get i) (const_i32 1)))
          )
        )
        (return (cast_i64_to_i32 (local_get total)))
      )
    )
  )
)
