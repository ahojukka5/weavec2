; Performance: 0044_while_zero_iterations
; tags = i32, loop, smoke
; Why hard: Smoke baseline for zero-trip loop. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: while with false initial condition
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0044_while_zero_iterations.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Header executes body once anyway.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32
          (const_i32 10)
        ) ;; let

        (let sum i32
          (const_i32 42)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 5)
            ) ;; lt_i32
          ) ;; condition
          (do
            (set sum
              (const_i32 0)
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
