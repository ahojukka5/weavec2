; Performance: 0131_loop_triple_if_carried_i32
; Why hard: One loop, three nested if levels, three loop-carried i32 locals—deep merge graph.
; Reveals: Nested if inside while; multiple carried locals; merge/phi suffix chain.
; If LLVM regresses: Broken loop header phis or missing .merge blocks: carried locals reload from stack every iteration, wrong backedge operands, or SSA violations after llvm-as.
(core-module
  (core-version 1)
  (decls
    (fn run
      (params)
      (returns i32)
      (do
        (let a i32
          (const_i32 0)
        ) ;; let

        (let b i32
          (const_i32 0)
        ) ;; let

        (let c i32
          (const_i32 0)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 24)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (local_get i)
                    (const_i32 3)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (if
                    (condition
                      (eq_i32
                        (mod_i32
                          (local_get i)
                          (const_i32 6)
                        ) ;; mod_i32
                        (const_i32 0)
                      ) ;; eq_i32
                    ) ;; condition
                    (then
                      (do
                        (if
                          (condition
                            (eq_i32
                              (mod_i32
                                (local_get i)
                                (const_i32 9)
                              ) ;; mod_i32
                              (const_i32 0)
                            ) ;; eq_i32
                          ) ;; condition
                          (then
                            (do
                              (set a
                                (add_i32
                                  (local_get a)
                                  (const_i32 3)
                                ) ;; add_i32
                              ) ;; set
                              (set b
                                (add_i32
                                  (local_get b)
                                  (const_i32 2)
                                ) ;; add_i32
                              ) ;; set
                              (set c
                                (add_i32
                                  (local_get c)
                                  (const_i32 1)
                                ) ;; add_i32
                              ) ;; set
                            ) ;; do
                          ) ;; then
                          (else
                            (do
                              (set b
                                (add_i32
                                  (local_get b)
                                  (const_i32 5)
                                ) ;; add_i32
                              ) ;; set
                            ) ;; do
                          ) ;; else
                        ) ;; if
                      ) ;; do
                    ) ;; then
                    (else
                      (do
                        (set c
                          (add_i32
                            (local_get c)
                            (const_i32 4)
                          ) ;; add_i32
                        ) ;; set
                      ) ;; do
                    ) ;; else
                  ) ;; if
                ) ;; do
              ) ;; then
              (else
                (do
                  (if
                    (condition
                      (eq_i32
                        (mod_i32
                          (local_get i)
                          (const_i32 2)
                        ) ;; mod_i32
                        (const_i32 0)
                      ) ;; eq_i32
                    ) ;; condition
                    (then
                      (do
                        (set a
                          (add_i32
                            (local_get a)
                            (const_i32 1)
                          ) ;; add_i32
                        ) ;; set
                      ) ;; do
                    ) ;; then
                    (else
                      (do)
                    ) ;; else
                  ) ;; if
                ) ;; do
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (add_i32
            (add_i32
              (local_get a)
              (local_get b)
            ) ;; add_i32
            (local_get c)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 run)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
