; Performance: 0039_i64_ge_gt
; tags = i64, smoke
; Why hard: Smoke baseline for i64 ordered compares. Failures here usually
;   indicate
;   broken lowering shared by every later fixture.
; Reveals: ge_i64/gt_i64
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0039_i64_ge_gt.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Treats i64 compares as unsigned incorrectly.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do

        (if
          (condition
            (gt_i64
              (const_i64 10)
              (const_i64 9)
            ) ;; gt_i64
          ) ;; condition
          (then
            (do)
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

        (if
          (condition
            (ge_i64
              (const_i64 10)
              (const_i64 10)
            ) ;; ge_i64
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
