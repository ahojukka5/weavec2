; Performance: 0169_const_f64_add
; tags = float, i32, stress
; Why hard: f64 smoke: literal add and fptosi return.
; Reveals: const_f64, fadd, cast_f64_to_i32.
; Expected: main returns 5 (double 2+3, fptosi). llvm-as accepts emitted IR; opt
;   -passes=mem2reg is an optional extra check.
; If LLVM regresses: fadd typed as double; sitofp used where f64 literal
;   expected.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (cast_f64_to_i32
            (add_f64
              (const_f64 2)
              (const_f64 3)
            )
          )
        )
      )
    )
  )
)
