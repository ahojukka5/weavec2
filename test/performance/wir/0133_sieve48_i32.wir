; Performance: 0133_sieve48_i32
; tags = heap, i32, memory, stress
; Why hard: Sieve to 48 with inner marking loop—store-heavy.
; Reveals: Nested loops, flag array stores, branch on flags.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0133_sieve48_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Marks composites wrong; inner loop starts at wrong
;   multiple.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn flag_ptr
      (params
        (flags ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get flags)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn count_primes48
      (params
        (flags ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 48)
            ) ;; le_i32
          ) ;; condition
          (do
            (store_i32
              (call_ptr flag_ptr
                (param_get flags)
                (local_get i)
              ) ;; call_ptr
              (const_i32 1)
            ) ;; store_i32

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (store_i32 (call_ptr flag_ptr (param_get flags) (const_i32 0)) (const_i32 0))
        (store_i32 (call_ptr flag_ptr (param_get flags) (const_i32 1)) (const_i32 0))

        (let p i32
          (const_i32 2)
        ) ;; let

        (while
          (condition
            (le_i32
              (mul_i32
                (local_get p)
                (local_get p)
              ) ;; mul_i32
              (const_i32 48)
            ) ;; le_i32
          ) ;; condition
          (do
            (if
              (condition
                (ne_i32
                  (load_i32
                    (call_ptr flag_ptr
                      (param_get flags)
                      (local_get p)
                    ) ;; call_ptr
                  ) ;; load_i32
                  (const_i32 0)
                ) ;; ne_i32
              ) ;; condition
              (then
                (do
                  (let m i32
                    (mul_i32
                      (local_get p)
                      (local_get p)
                    ) ;; mul_i32
                  ) ;; let

                  (let j i32
                    (local_get m)
                  ) ;; let

                  (while
                    (condition
                      (le_i32
                        (local_get j)
                        (const_i32 48)
                      ) ;; le_i32
                    ) ;; condition
                    (do
                      (store_i32
                        (call_ptr flag_ptr
                          (param_get flags)
                          (local_get j)
                        ) ;; call_ptr
                        (const_i32 0)
                      ) ;; store_i32

                      (set j
                        (add_i32
                          (local_get j)
                          (local_get p)
                        ) ;; add_i32
                      ) ;; set
                    ) ;; do
                  ) ;; while
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set p
              (add_i32
                (local_get p)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (let k i32
          (const_i32 0)
        ) ;; let

        (let count i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get k)
              (const_i32 48)
            ) ;; le_i32
          ) ;; condition
          (do
            (if
              (condition
                (ne_i32
                  (load_i32
                    (call_ptr flag_ptr
                      (param_get flags)
                      (local_get k)
                    ) ;; call_ptr
                  ) ;; load_i32
                  (const_i32 0)
                ) ;; ne_i32
              ) ;; condition
              (then
                (do
                  (set count
                    (add_i32
                      (local_get count)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set k
              (add_i32
                (local_get k)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get count)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let flags ptr
          (call_ptr malloc
            (const_i64 196)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get flags)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let n i32
          (call_i32 count_primes48
            (local_get flags)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get flags)
        ) ;; call_void

        (return
          (local_get n)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
