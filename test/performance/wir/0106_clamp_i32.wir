; Algorithm: clamp value to [lo, hi] inclusive
; Tests: chained comparisons without loops
(core-module
  (core-version 1)
  (decls
    (fn clamp
      (params
        (v i32)
        (lo i32)
        (hi i32)
      ) ;; params
      (returns i32)
      (do
        (let out i32
          (param_get v)
        ) ;; let

        (if
          (condition
            (lt_i32
              (local_get out)
              (param_get lo)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (set out
                (param_get lo)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (gt_i32
              (local_get out)
              (param_get hi)
            ) ;; gt_i32
          ) ;; condition
          (then
            (do
              (set out
                (param_get hi)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (local_get out)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 clamp
            (const_i32 150)
            (const_i32 10)
            (const_i32 99)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
