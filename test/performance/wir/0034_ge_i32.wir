; Performance: 0034_ge_i32
; tags = i32, smoke
; Why hard: Smoke baseline for signed compare ge. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: ge_i32 predicate
; Expected: Golden LLVM matches test/performance/expected-llvm/0034_ge_i32.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Uses uge or swaps operands silently.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (ge_i32
              (const_i32 42)
              (const_i32 42)
            ) ;; ge_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
