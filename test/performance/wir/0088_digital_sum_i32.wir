; Performance: 0088_digital_sum_i32
; tags = algorithm, i32
; Why hard: Sum of decimal digits. Mod/div loop until n=0.
; Reveals: mod 10, div 10, accumulate.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0088_digital_sum_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Loses high digits; infinite loop if div wrong.
(core-module
  (core-version 1)
  (decls
    (fn digital_sum
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get n)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (gt_i32
              (local_get x)
              (const_i32 0)
            ) ;; gt_i32
          ) ;; condition
          (do
            (set total
              (add_i32
                (local_get total)
                (mod_i32
                  (local_get x)
                  (const_i32 10)
                ) ;; mod_i32
              ) ;; add_i32
            ) ;; set

            (set x
              (div_i32
                (local_get x)
                (const_i32 10)
              ) ;; div_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 digital_sum
            (const_i32 9876)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
