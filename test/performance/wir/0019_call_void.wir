; Performance: 0019_call_void
; Why hard: Smoke baseline for void return call. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: call_void side effect only
; If LLVM regresses: Treats void call as value-producing; dead ret of undefined.
(core-module
  (core-version 1)
  (decls
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (call_void free
          (const_null)
        ) ;; call_void
        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
