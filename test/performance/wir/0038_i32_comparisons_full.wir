; Performance: 0038_i32_comparisons_full
; Why hard: Smoke baseline for full icmp set. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: eq/ne/lt/le/gt/ge i32
; If LLVM regresses: Any one icmp kind wrong breaks all later branchy code.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do

        (if
          (condition
            (eq_i32
              (const_i32 42)
              (const_i32 42)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do)
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

        (if
          (condition
            (ne_i32
              (const_i32 42)
              (const_i32 0)
            ) ;; ne_i32
          ) ;; condition
          (then
            (do)
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

        (if
          (condition
            (lt_i32
              (const_i32 1)
              (const_i32 2)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do)
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

        (if
          (condition
            (le_i32
              (const_i32 2)
              (const_i32 2)
            ) ;; le_i32
          ) ;; condition
          (then
            (do)
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

        (if
          (condition
            (gt_i32
              (const_i32 3)
              (const_i32 2)
            ) ;; gt_i32
          ) ;; condition
          (then
            (do)
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

        (if
          (condition
            (ge_i32
              (const_i32 4)
              (const_i32 4)
            ) ;; ge_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if

      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
