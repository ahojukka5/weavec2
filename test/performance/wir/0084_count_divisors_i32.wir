; Performance: 0084_count_divisors_i32
; tags = algorithm, i32
; Why hard: Count divisors by trial. Many mod operations on growing trial.
; Reveals: mod_i32 in loop with increment.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0084_count_divisors_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Counts wrong divisor; includes n twice.
(core-module
  (core-version 1)
  (decls
    (fn count_divisors
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let d i32
          (const_i32 1)
        ) ;; let

        (let count i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (mul_i32
                (local_get d)
                (local_get d)
              ) ;; mul_i32
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (param_get n)
                    (local_get d)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set count
                    (add_i32
                      (local_get count)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set d
              (add_i32
                (local_get d)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get count)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 count_divisors
            (const_i32 36)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
