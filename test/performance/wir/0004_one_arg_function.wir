; Performance: 0004_one_arg_function
; Why hard: Smoke baseline for single-parameter call. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: param_get, call_i32, small function
; If LLVM regresses: Argument passed in wrong register/stack slot; broken calling convention.
(core-module
  (core-version 1)
  (decls
    (fn inc
      (params
        (x i32)
      ) ;; params
      (returns i32)
      (do
        (return
          (add_i32
            (param_get x)
            (const_i32 1)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 inc
            (const_i32 41)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
