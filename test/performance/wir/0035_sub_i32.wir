; Performance: 0035_sub_i32
; tags = i32, smoke
; Why hard: Smoke baseline for subtraction. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: sub_i32
; Expected: Golden LLVM matches test/performance/expected-llvm/0035_sub_i32.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Becomes add with negative wrong; nsw missing where
;   expected.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (sub_i32
            (const_i32 50)
            (const_i32 8)
          ) ;; sub_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
