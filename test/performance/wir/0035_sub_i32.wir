; Performance: 0035_sub_i32
; Why hard: Smoke baseline for subtraction. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: sub_i32
; If LLVM regresses: Becomes add with negative wrong; nsw missing where expected.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (sub_i32
            (const_i32 50)
            (const_i32 8)
          ) ;; sub_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
