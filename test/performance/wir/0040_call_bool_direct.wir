; Performance: 0040_call_bool_direct
; Why hard: Smoke baseline for bool call. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: call_bool + branch
; If LLVM regresses: Caller compares i32 instead of i1.
(core-module
  (core-version 1)
  (decls
    (fn is_answer
      (params
        (x i32)
      ) ;; params
      (returns bool)
      (do
        (return
          (eq_i32
            (param_get x)
            (const_i32 42)
          ) ;; eq_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (call_bool is_answer
              (const_i32 42)
            ) ;; call_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
