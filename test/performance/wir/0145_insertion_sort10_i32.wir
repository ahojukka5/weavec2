; Performance: 0145_insertion_sort10_i32
; tags = i32, memory, sort, stress
; Why hard: Insertion sort ten elements.
; Reveals: Inner shift while with many stores.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0145_insertion_sort10_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Redundant alloca traffic: repeated load/store of the same
;   slot each
;   iteration instead of keeping values in registers after mem2reg.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (a ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get a)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn insertion_sort10
      (params
        (a ptr)
      ) ;; params
      (returns void)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 10)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let key i32
              (load_i32
                (call_ptr elem
                  (param_get a)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (let j i32
              (sub_i32
                (local_get i)
                (const_i32 1)
              ) ;; sub_i32
            ) ;; let

            (while
              (condition
                (and_bool
                  (ge_i32
                    (local_get j)
                    (const_i32 0)
                  ) ;; ge_i32
                  (gt_i32
                    (load_i32
                      (call_ptr elem
                        (param_get a)
                        (local_get j)
                      ) ;; call_ptr
                    ) ;; load_i32
                    (local_get key)
                  ) ;; gt_i32
                ) ;; and_bool
              ) ;; condition
              (do
                (store_i32
                  (call_ptr elem
                    (param_get a)
                    (add_i32
                      (local_get j)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; call_ptr
                  (load_i32
                    (call_ptr elem
                      (param_get a)
                      (local_get j)
                    ) ;; call_ptr
                  ) ;; load_i32
                ) ;; store_i32

                (set j
                  (sub_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; sub_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (store_i32
              (call_ptr elem
                (param_get a)
                (add_i32
                  (local_get j)
                  (const_i32 1)
                ) ;; add_i32
              ) ;; call_ptr
              (local_get key)
            ) ;; store_i32

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 40)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get a)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem (local_get a) (const_i32 0)) (const_i32 10))
        (store_i32 (call_ptr elem (local_get a) (const_i32 1)) (const_i32 3))
        (store_i32 (call_ptr elem (local_get a) (const_i32 2)) (const_i32 8))
        (store_i32 (call_ptr elem (local_get a) (const_i32 3)) (const_i32 1))
        (store_i32 (call_ptr elem (local_get a) (const_i32 4)) (const_i32 9))
        (store_i32 (call_ptr elem (local_get a) (const_i32 5)) (const_i32 2))
        (store_i32 (call_ptr elem (local_get a) (const_i32 6)) (const_i32 7))
        (store_i32 (call_ptr elem (local_get a) (const_i32 7)) (const_i32 4))
        (store_i32 (call_ptr elem (local_get a) (const_i32 8)) (const_i32 6))
        (store_i32 (call_ptr elem (local_get a) (const_i32 9)) (const_i32 5))

        (call_void insertion_sort10
          (local_get a)
        ) ;; call_void

        (let first i32
          (load_i32
            (call_ptr elem
              (local_get a)
              (const_i32 0)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; let

        (call_void free
          (local_get a)
        ) ;; call_void

        (return
          (local_get first)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
