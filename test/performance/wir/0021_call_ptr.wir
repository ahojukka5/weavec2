; Performance: 0021_call_ptr
; tags = call, i32, smoke
; Why hard: Smoke baseline for ptr return call. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: call_ptr
; Expected: Golden LLVM matches test/performance/expected-llvm/0021_call_ptr.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Pointer return not marked noalias where needed; typed as
;   i64.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn make_ptr
      (params)
      (returns ptr)
      (do
        (return
          (call_ptr malloc
            (const_i64 8)
          ) ;; call_ptr
        ) ;; return
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr make_ptr)
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (call_void free
                (local_get p)
              ) ;; call_void
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
