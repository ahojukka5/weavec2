; Performance: 0073_factorial_iter_i32
; Why hard: Factorial product loop; classic benchmark shape.
; Reveals: mul_i32 on carried fact, i32 index.
; If LLVM regresses: Product resets each iteration; off-by-one on range.
(core-module
  (core-version 1)
  (decls
    (fn factorial
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 2)
        ) ;; let

        (let acc i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (set acc
              (mul_i32
                (local_get acc)
                (local_get i)
              ) ;; mul_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get acc)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 factorial
            (const_i32 7)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
