; Performance: 0070_horner_polynomial_i32
; Why hard: Horner scheme; mul-add chain per coefficient.
; Reveals: mul_i32/add_i32 recurrence in loop.
; If LLVM regresses: Polynomial evaluated in wrong order; acc not updated.
(core-module
  (core-version 1)
  (decls
    (fn horner3
      (params
        (x i32)
      ) ;; params
      (returns i32)
      (do
        (let acc i32
          (const_i32 1)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 3)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let next i32
              (add_i32
                (mul_i32
                  (local_get acc)
                  (param_get x)
                ) ;; mul_i32
                (const_i32 2)
              ) ;; add_i32
            ) ;; let

            (set acc
              (local_get next)
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get acc)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (sub_i32
            (call_i32 horner3
              (const_i32 3)
            ) ;; call_i32
            (const_i32 11)
          ) ;; sub_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
