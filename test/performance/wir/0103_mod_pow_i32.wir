; Performance: 0103_mod_pow_i32
; tags = algorithm, i32, numeric
; Why hard: Modular exponentiation. Square-and-multiply with mod each step.
; Reveals: mul+mod in loop on bits of exp.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0103_mod_pow_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Forgot mod; overflow changes semantic mod result.
(core-module
  (core-version 1)
  (decls
    (fn mod_pow
      (params
        (base0 i32)
        (exp0 i32)
        (modv i32)
      ) ;; params
      (returns i32)
      (do
        (let result i32
          (const_i32 1)
        ) ;; let

        (let base i32
          (mod_i32
            (param_get base0)
            (param_get modv)
          ) ;; mod_i32
        ) ;; let

        (let exp i32
          (param_get exp0)
        ) ;; let

        (while
          (condition
            (gt_i32
              (local_get exp)
              (const_i32 0)
            ) ;; gt_i32
          ) ;; condition
          (do
            (if
              (condition
                (ne_i32
                  (mod_i32
                    (local_get exp)
                    (const_i32 2)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; ne_i32
              ) ;; condition
              (then
                (do
                  (set result
                    (mod_i32
                      (mul_i32
                        (local_get result)
                        (local_get base)
                      ) ;; mul_i32
                      (param_get modv)
                    ) ;; mod_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set base
              (mod_i32
                (mul_i32
                  (local_get base)
                  (local_get base)
                ) ;; mul_i32
                (param_get modv)
              ) ;; mod_i32
            ) ;; set

            (set exp
              (div_i32
                (local_get exp)
                (const_i32 2)
              ) ;; div_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get result)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 mod_pow
            (const_i32 2)
            (const_i32 10)
            (const_i32 1000)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
