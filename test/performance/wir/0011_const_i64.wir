; Performance: 0011_const_i64
; tags = i64, smoke
; Why hard: Smoke baseline for i64 constant. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: const_i64 materialization
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0011_const_i64.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Truncation/extension errors; i64 value wrong in IR.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let x i64
          (const_i64 42)
        ) ;; let
        (return
          (cast_i64_to_i32
            (local_get x)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
