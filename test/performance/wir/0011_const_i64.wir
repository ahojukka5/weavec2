; Performance: 0011_const_i64
; Why hard: Smoke baseline for i64 constant. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: const_i64 materialization
; If LLVM regresses: Truncation/extension errors; i64 value wrong in IR.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let x i64
          (const_i64 42)
        ) ;; let
        (return
          (cast_i64_to_i32
            (local_get x)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
