; Performance: 0014_bool_ops
; tags = i32, smoke
; Why hard: Smoke baseline for boolean logic. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: and_bool/or_bool/not_bool
; Expected: Golden LLVM matches test/performance/expected-llvm/0014_bool_ops.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: i1 values widened to i32 incorrectly; short-circuit broken.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (and_bool
              (const_bool true)
              (or_bool
                (const_bool false)
                (const_bool true)
              ) ;; or_bool
            ) ;; and_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
