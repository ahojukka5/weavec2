; Stress: Collatz on i64 starting values, track peak (i64 arithmetic)
; Reveals: div_i64, mod_i64, mul_i64, gt_i64, nested if
(core-module
  (core-version 1)
  (decls
    (fn collatz_peak
      (params
        (start i64)
      ) ;; params
      (returns i64)
      (do
        (let n i64
          (param_get start)
        ) ;; let

        (let peak i64
          (param_get start)
        ) ;; let

        (let steps i64
          (const_i64 0)
        ) ;; let

        (while
          (condition
            (and_bool
              (ne_i64
                (local_get n)
                (const_i64 1)
              ) ;; ne_i64
              (lt_i64
                (local_get steps)
                (const_i64 200)
              ) ;; lt_i64
            ) ;; and_bool
          ) ;; condition
          (do
            (if
              (condition
                (eq_i64
                  (mod_i64
                    (local_get n)
                    (const_i64 2)
                  ) ;; mod_i64
                  (const_i64 0)
                ) ;; eq_i64
              ) ;; condition
              (then
                (do
                  (set n
                    (div_i64
                      (local_get n)
                      (const_i64 2)
                    ) ;; div_i64
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (set n
                    (add_i64
                      (mul_i64
                        (local_get n)
                        (const_i64 3)
                      ) ;; mul_i64
                      (const_i64 1)
                    ) ;; add_i64
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if

            (if
              (condition
                (gt_i64
                  (local_get n)
                  (local_get peak)
                ) ;; gt_i64
              ) ;; condition
              (then
                (do
                  (set peak
                    (local_get n)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set steps
              (add_i64
                (local_get steps)
                (const_i64 1)
              ) ;; add_i64
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get peak)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let k i32
          (const_i32 1)
        ) ;; let

        (let acc i64
          (const_i64 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get k)
              (const_i32 40)
            ) ;; le_i32
          ) ;; condition
          (do
            (let start i64
              (add_i64
                (mul_i64
                  (cast_i32_to_i64
                    (local_get k)
                  ) ;; cast_i32_to_i64
                  (const_i64 37)
                ) ;; mul_i64
                (const_i64 100)
              ) ;; add_i64
            ) ;; let

            (set acc
              (add_i64
                (local_get acc)
                (call_i64 collatz_peak
                  (local_get start)
                ) ;; call_i64
              ) ;; add_i64
            ) ;; set

            (set k
              (add_i32
                (local_get k)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (cast_i64_to_i32
            (mod_i64
              (local_get acc)
              (const_i64 1000000007)
            ) ;; mod_i64
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
