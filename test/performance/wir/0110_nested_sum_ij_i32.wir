; Algorithm: sum of i*j for 1 <= i,j <= n (nested loops)
; Tests: doubly nested loop with multiply-add inner body
(core-module
  (core-version 1)
  (decls
    (fn nested_sum
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (let j i32
              (const_i32 1)
            ) ;; let

            (while
              (condition
                (le_i32
                  (local_get j)
                  (param_get n)
                ) ;; le_i32
              ) ;; condition
              (do
                (set total
                  (add_i32
                    (local_get total)
                    (mul_i32
                      (local_get i)
                      (local_get j)
                    ) ;; mul_i32
                  ) ;; add_i32
                ) ;; set

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 nested_sum
            (const_i32 4)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
