            (local_get buffer)
            (const_i64 16)
          ) ;; ptr_add
          (const_i64 8)
        ) ;; store_i64
        (store_i8
          (local_get data)
          (const_i32 42)
        ) ;; store_i8
        (let data2 ptr
          (load_ptr
            (local_get buffer)
          ) ;; load_ptr
        ) ;; let
        (let x i32
          (load_u8
            (local_get data2)
          ) ;; load_u8
        ) ;; let
        (call_void free
          (local_get data)
        ) ;; call_void
        (call_void free
