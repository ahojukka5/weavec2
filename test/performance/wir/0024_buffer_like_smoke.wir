        (store_ptr
          (local_get buffer)
          (local_get data)
        ) ;; store_ptr
        (store_i64
          (ptr_add
            (local_get buffer)
            (const_i64 8)
          ) ;; ptr_add
          (const_i64 1)
        ) ;; store_i64
        (store_i64
