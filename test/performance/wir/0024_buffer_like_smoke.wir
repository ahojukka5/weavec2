    (fn main
      (params)
      (returns i32)
      (do
        (let buffer ptr
          (call_ptr malloc
            (const_i64 24)
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get buffer)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if
        (let data ptr
          (call_ptr malloc
            (const_i64 8)
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get data)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
