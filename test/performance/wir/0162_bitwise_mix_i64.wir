; Stress: i64 bitwise ops in a tight loop (xor/and/shl/shr)
; Reveals: shl_i64, shr_i64, and_i64, xor_i64 lowering
(core-module
  (core-version 1)
  (decls
    (fn mix64
      (params
        (seed i64)
      ) ;; params
      (returns i64)
      (do
        (let x i64
          (param_get seed)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 64)
            ) ;; lt_i32
          ) ;; condition
          (do
            (set x
              (xor_i64
                (shl_i64
                  (and_i64
                    (local_get x)
                    (const_i64 255)
                  ) ;; and_i64
                  (const_i64 3)
                ) ;; shl_i64
                (shr_i64
                  (local_get x)
                  (const_i64 5)
                ) ;; shr_i64
              ) ;; xor_i64
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (cast_i64_to_i32
            (mod_i64
              (call_i64 mix64
                (const_i64 0x123456789ABCDEF0)
              ) ;; call_i64
              (const_i64 1000000007)
            ) ;; mod_i64
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
