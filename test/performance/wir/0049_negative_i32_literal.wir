; Performance: 0049_negative_i32_literal
; Why hard: Smoke baseline for negative literal. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: const_i32 negative
; If LLVM regresses: Parsed as large unsigned or missing minus.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (add_i32
            (const_i32 -8)
            (const_i32 50)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
