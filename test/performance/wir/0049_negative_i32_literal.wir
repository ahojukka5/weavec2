; Performance: 0049_negative_i32_literal
; tags = i32, loop, smoke
; Why hard: Smoke baseline for negative literal. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: const_i32 negative
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0049_negative_i32_literal.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Parsed as large unsigned or missing minus.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (add_i32
            (const_i32 -8)
            (const_i32 50)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
