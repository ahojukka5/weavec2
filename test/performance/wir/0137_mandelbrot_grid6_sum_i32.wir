; Performance: 0137_mandelbrot_grid6_sum_i32
; tags = dp, i32, stress
; Why hard: 6x6 grid Mandelbrot escape sum—heavy inner kernel.
; Reveals: Nested pixel loops, div/mul in escape loop.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0137_mandelbrot_grid6_sum_i32.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Escape count wrong; inner loop never advances z.
(core-module
  (core-version 1)
  (decls
    (fn escape_count
      (params
        (cx i32)
        (cy i32)
        (max_iter i32)
      ) ;; params
      (returns i32)
      (do
        (let zx i32
          (const_i32 0)
        ) ;; let

        (let zy i32
          (const_i32 0)
        ) ;; let

        (let iter i32
          (const_i32 0)
        ) ;; let

        (let active i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (and_bool
              (lt_i32
                (local_get iter)
                (param_get max_iter)
              ) ;; lt_i32
              (ne_i32
                (local_get active)
                (const_i32 0)
              ) ;; ne_i32
            ) ;; and_bool
          ) ;; condition
          (do
            (let zx2 i32
              (div_i32
                (mul_i32
                  (local_get zx)
                  (local_get zx)
                ) ;; mul_i32
                (const_i32 1000)
              ) ;; div_i32
            ) ;; let

            (let zy2 i32
              (div_i32
                (mul_i32
                  (local_get zy)
                  (local_get zy)
                ) ;; mul_i32
                (const_i32 1000)
              ) ;; div_i32
            ) ;; let

            (let radius2 i32
              (add_i32
                (local_get zx2)
                (local_get zy2)
              ) ;; add_i32
            ) ;; let

            (if
              (condition
                (gt_i32
                  (local_get radius2)
                  (const_i32 4000)
                ) ;; gt_i32
              ) ;; condition
              (then
                (do
                  (set active
                    (const_i32 0)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (let two_zx_zy i32
                    (div_i32
                      (mul_i32
                        (mul_i32
                          (const_i32 2)
                          (local_get zx)
                        ) ;; mul_i32
                        (local_get zy)
                      ) ;; mul_i32
                      (const_i32 1000)
                    ) ;; div_i32
                  ) ;; let

                  (set zy
                    (add_i32
                      (local_get two_zx_zy)
                      (param_get cy)
                    ) ;; add_i32
                  ) ;; set

                  (set zx
                    (add_i32
                      (sub_i32
                        (local_get zx2)
                        (local_get zy2)
                      ) ;; sub_i32
                      (param_get cx)
                    ) ;; add_i32
                  ) ;; set

                  (set iter
                    (add_i32
                      (local_get iter)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return
          (local_get iter)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn grid_sum
      (params)
      (returns i32)
      (do
        (let py i32
          (const_i32 0)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get py)
              (const_i32 6)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let px i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (lt_i32
                  (local_get px)
                  (const_i32 6)
                ) ;; lt_i32
              ) ;; condition
              (do
                (let cx i32
                  (sub_i32
                    (mul_i32
                      (local_get px)
                      (const_i32 500)
                    ) ;; mul_i32
                    (const_i32 1500)
                  ) ;; sub_i32
                ) ;; let

                (let cy i32
                  (sub_i32
                    (mul_i32
                      (local_get py)
                      (const_i32 500)
                    ) ;; mul_i32
                    (const_i32 1500)
                  ) ;; sub_i32
                ) ;; let

                (let esc i32
                  (call_i32 escape_count
                    (local_get cx)
                    (local_get cy)
                    (const_i32 32)
                  ) ;; call_i32
                ) ;; let

                (set total
                  (add_i32
                    (local_get total)
                    (local_get esc)
                  ) ;; add_i32
                ) ;; set

                (set px
                  (add_i32
                    (local_get px)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set py
              (add_i32
                (local_get py)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 grid_sum)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
