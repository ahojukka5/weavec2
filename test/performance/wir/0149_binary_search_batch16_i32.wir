; Performance: 0149_binary_search_batch16_i32
; Why hard: Sixteen sorted values, twelve binary searches in loop.
; Reveals: Nested if in search, low/high/found carried, outer sum.
; If LLVM regresses: Search returns wrong index; outer sum double-counts.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn search16
      (params
        (items ptr)
        (target i32)
      ) ;; params
      (returns i32)
      (do
        (let low i32
          (const_i32 0)
        ) ;; let

        (let high i32
          (const_i32 15)
        ) ;; let

        (let found i32
          (const_i32 -1)
        ) ;; let

        (while
          (condition
            (and_bool
              (le_i32
                (local_get low)
                (local_get high)
              ) ;; le_i32
              (eq_i32
                (local_get found)
                (const_i32 -1)
              ) ;; eq_i32
            ) ;; and_bool
          ) ;; condition
          (do
            (let mid i32
              (div_i32
                (add_i32
                  (local_get low)
                  (local_get high)
                ) ;; add_i32
                (const_i32 2)
              ) ;; div_i32
            ) ;; let

            (let mid_val i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get mid)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (if
              (condition
                (eq_i32
                  (local_get mid_val)
                  (param_get target)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set found
                    (local_get mid)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (if
                    (condition
                      (lt_i32
                        (local_get mid_val)
                        (param_get target)
                      ) ;; lt_i32
                    ) ;; condition
                    (then
                      (do
                        (set low
                          (add_i32
                            (local_get mid)
                            (const_i32 1)
                          ) ;; add_i32
                        ) ;; set
                      ) ;; do
                    ) ;; then
                    (else
                      (do
                        (set high
                          (sub_i32
                            (local_get mid)
                            (const_i32 1)
                          ) ;; sub_i32
                        ) ;; set
                      ) ;; do
                    ) ;; else
                  ) ;; if
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return
          (local_get found)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 -1)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 2))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 4))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 6))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 8))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 10))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 5)) (const_i32 12))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 6)) (const_i32 14))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 7)) (const_i32 16))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 8)) (const_i32 18))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 9)) (const_i32 20))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 10)) (const_i32 22))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 11)) (const_i32 24))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 12)) (const_i32 26))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 13)) (const_i32 28))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 14)) (const_i32 30))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 15)) (const_i32 32))

        (let t i32
          (const_i32 0)
        ) ;; let

        (let sum i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get t)
              (const_i32 12)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let target i32
              (add_i32
                (mul_i32
                  (local_get t)
                  (const_i32 3)
                ) ;; mul_i32
                (const_i32 7)
              ) ;; add_i32
            ) ;; let

            (let idx i32
              (call_i32 search16
                (local_get items)
                (local_get target)
              ) ;; call_i32
            ) ;; let

            (set sum
              (add_i32
                (local_get sum)
                (local_get idx)
              ) ;; add_i32
            ) ;; set

            (set t
              (add_i32
                (local_get t)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
