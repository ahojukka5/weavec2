; Performance: 0094_min_of_three_i32
; tags = algorithm, i32
; Why hard: Min of three. Branch-only like max_of_three.
; Reveals: Nested compares.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0094_min_of_three_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Returns middle value always.
(core-module
  (core-version 1)
  (decls
    (fn min3
      (params
        (a i32)
        (b i32)
        (c i32)
      ) ;; params
      (returns i32)
      (do
        (let m i32
          (param_get a)
        ) ;; let

        (if
          (condition
            (lt_i32
              (param_get b)
              (local_get m)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get b)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (lt_i32
              (param_get c)
              (local_get m)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get c)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (local_get m)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 min3
            (const_i32 17)
            (const_i32 4)
            (const_i32 23)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
