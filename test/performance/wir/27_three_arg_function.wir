(core-module
  (core-version 1)
  (decls
    (fn add3
      (params
        (a i32)
        (b i32)
        (c i32)
      ) ;; params
      (returns i32)
      (do
        (return
          (add_i32
            (add_i32
              (param_get a)
              (param_get b)
            ) ;; add_i32
            (param_get c)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 add3
            (const_i32 10)
            (const_i32 20)
            (const_i32 12)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
