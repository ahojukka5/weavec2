; Performance: 0134_floyd_warshall4_i32
; Why hard: All-pairs shortest paths—triple loop with relax.
; Reveals: k,i,j loops, min relax on heap matrix.
; If LLVM regresses: Relax uses max not min; k/i/j order wrong for FW.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn at
      (params
        (dist ptr)
        (i i32)
        (j i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get dist)
            (cast_i32_to_i64
              (add_i32
                (mul_i32
                  (param_get i)
                  (const_i32 4)
                ) ;; mul_i32
                (param_get j)
              ) ;; add_i32
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn floyd4
      (params
        (dist ptr)
      ) ;; params
      (returns void)
      (do
        (let k i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get k)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let i i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (lt_i32
                  (local_get i)
                  (const_i32 4)
                ) ;; lt_i32
              ) ;; condition
              (do
                (let j i32
                  (const_i32 0)
                ) ;; let

                (while
                  (condition
                    (lt_i32
                      (local_get j)
                      (const_i32 4)
                    ) ;; lt_i32
                  ) ;; condition
                  (do
                    (let via i32
                      (add_i32
                        (load_i32
                          (call_ptr at
                            (param_get dist)
                            (local_get i)
                            (local_get k)
                          ) ;; call_ptr
                        ) ;; load_i32
                        (load_i32
                          (call_ptr at
                            (param_get dist)
                            (local_get k)
                            (local_get j)
                          ) ;; call_ptr
                        ) ;; load_i32
                      ) ;; add_i32
                    ) ;; let

                    (let cur i32
                      (load_i32
                        (call_ptr at
                          (param_get dist)
                          (local_get i)
                          (local_get j)
                        ) ;; call_ptr
                      ) ;; load_i32
                    ) ;; let

                    (if
                      (condition
                        (lt_i32
                          (local_get via)
                          (local_get cur)
                        ) ;; lt_i32
                      ) ;; condition
                      (then
                        (do
                          (store_i32
                            (call_ptr at
                              (param_get dist)
                              (local_get i)
                              (local_get j)
                            ) ;; call_ptr
                            (local_get via)
                          ) ;; store_i32
                        ) ;; do
                      ) ;; then
                      (else
                        (do)
                      ) ;; else
                    ) ;; if

                    (set j
                      (add_i32
                        (local_get j)
                        (const_i32 1)
                      ) ;; add_i32
                    ) ;; set
                  ) ;; do
                ) ;; while

                (set i
                  (add_i32
                    (local_get i)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set k
              (add_i32
                (local_get k)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let dist ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get dist)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr at (local_get dist) (const_i32 0) (const_i32 0)) (const_i32 0))
        (store_i32 (call_ptr at (local_get dist) (const_i32 0) (const_i32 1)) (const_i32 5))
        (store_i32 (call_ptr at (local_get dist) (const_i32 0) (const_i32 2)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 0) (const_i32 3)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 1) (const_i32 0)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 1) (const_i32 1)) (const_i32 0))
        (store_i32 (call_ptr at (local_get dist) (const_i32 1) (const_i32 2)) (const_i32 1))
        (store_i32 (call_ptr at (local_get dist) (const_i32 1) (const_i32 3)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 2) (const_i32 0)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 2) (const_i32 1)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 2) (const_i32 2)) (const_i32 0))
        (store_i32 (call_ptr at (local_get dist) (const_i32 2) (const_i32 3)) (const_i32 2))
        (store_i32 (call_ptr at (local_get dist) (const_i32 3) (const_i32 0)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 3) (const_i32 1)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 3) (const_i32 2)) (const_i32 9999))
        (store_i32 (call_ptr at (local_get dist) (const_i32 3) (const_i32 3)) (const_i32 0))

        (call_void floyd4
          (local_get dist)
        ) ;; call_void

        (let ans i32
          (load_i32
            (call_ptr at
              (local_get dist)
              (const_i32 0)
              (const_i32 3)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; let

        (call_void free
          (local_get dist)
        ) ;; call_void

        (return
          (local_get ans)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
