; Performance: 0083_lcm_i32
; tags = algorithm, i32
; Why hard: LCM via GCD. Combines two algorithms and reuse of mod state.
; Reveals: GCD loop then div/mul combine.
; Expected: Golden LLVM matches test/performance/expected-llvm/0083_lcm_i32.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: LCM formula uses wrong GCD; division by zero.
(core-module
  (core-version 1)
  (decls
    (fn gcd
      (params
        (a i32)
        (b i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get a)
        ) ;; let

        (let y i32
          (param_get b)
        ) ;; let

        (while
          (condition
            (ne_i32
              (local_get y)
              (const_i32 0)
            ) ;; ne_i32
          ) ;; condition
          (do
            (let r i32
              (mod_i32
                (local_get x)
                (local_get y)
              ) ;; mod_i32
            ) ;; let

            (set x
              (local_get y)
            ) ;; set

            (set y
              (local_get r)
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn lcm
      (params
        (a i32)
        (b i32)
      ) ;; params
      (returns i32)
      (do
        (let g i32
          (call_i32 gcd
            (param_get a)
            (param_get b)
          ) ;; call_i32
        ) ;; let

        (return
          (div_i32
            (mul_i32
              (param_get a)
              (param_get b)
            ) ;; mul_i32
            (local_get g)
          ) ;; div_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 lcm
            (const_i32 12)
            (const_i32 18)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
