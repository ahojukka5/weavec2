; Performance: 0095_abs_i32
; tags = algorithm, i32
; Why hard: Absolute value. Sign test without overflow edge (MIN).
; Reveals: compare + select pattern via if.
; Expected: Golden LLVM matches test/performance/expected-llvm/0095_abs_i32.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Negates MIN incorrectly or always negative path.
(core-module
  (core-version 1)
  (decls
    (fn abs_i32
      (params
        (x i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (lt_i32
              (param_get x)
              (const_i32 0)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (return
                (sub_i32
                  (const_i32 0)
                  (param_get x)
                ) ;; sub_i32
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (param_get x)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 abs_i32
            (const_i32 -123)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
