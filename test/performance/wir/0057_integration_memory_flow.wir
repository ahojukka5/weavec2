; Integration test: memory flow with malloc/free
; Tests: malloc, ptr_add, store/load, function call with ptr parameter, free

(core-module
  (core-version 1)
  (decls
    (extern
      malloc
      (params
        (size i64))
      (returns ptr))
    (extern
      free
      (params
        (p ptr))
      (returns void))
    (fn write_values
      (params
        (buffer ptr)
        (count i32))
      (returns void)
      (do
        (let
          i
          i32
          (const_i32 0))
        (while
          (condition
            (lt_i32
              (local_get i)
              (param_get count)))
          (do
            (store_i32
              (ptr_add
                (param_get buffer)
                (mul_i64
                  (cast_i32_to_i64
                    (local_get i))
                  (const_i64 4)))
              (mul_i32
                (local_get i)
                (const_i32 10)))
            (set
              i
              (add_i32
                (local_get i)
                (const_i32 1)))))
        (return_void)))
    (fn sum_values
      (params
        (buffer ptr)
        (count i32))
      (returns i32)
      (do
        (let
          sum
          i32
          (const_i32 0))
        (let
          i
          i32
          (const_i32 0))
        (while
          (condition
            (lt_i32
              (local_get i)
              (param_get count)))
          (do
            (set
              sum
              (add_i32
                (local_get sum)
                (load_i32
                  (ptr_add
                    (param_get buffer)
                    (mul_i64
                      (cast_i32_to_i64
                        (local_get i))
                      (const_i64 4))))))
            (set
              i
              (add_i32
                (local_get i)
                (const_i32 1)))))
        (return
          (local_get sum))))
    (fn main
      (params)
      (returns i32)
      (do
        (let
          buffer
          ptr
          (call_ptr
            malloc
            (const_i64 20)))
        (call_void
          write_values
          (local_get buffer)
          (const_i32 5))
        (let
          result
          i32
          (call_i32
            sum_values
            (local_get buffer)
            (const_i32 5)))
        (call_void
          free
          (local_get buffer))
        (return
          (local_get result))))))
