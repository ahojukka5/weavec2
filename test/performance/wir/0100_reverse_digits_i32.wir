; Performance: 0100_reverse_digits_i32
; tags = algorithm, i32
; Why hard: Reverse decimal digits. Build reversed with mod/div.
; Reveals: mod 10, div 10, accumulate rev.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0100_reverse_digits_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Digits appended wrong order.
(core-module
  (core-version 1)
  (decls
    (fn reverse_digits
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get n)
        ) ;; let

        (let rev i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (gt_i32
              (local_get x)
              (const_i32 0)
            ) ;; gt_i32
          ) ;; condition
          (do
            (set rev
              (add_i32
                (mul_i32
                  (local_get rev)
                  (const_i32 10)
                ) ;; mul_i32
                (mod_i32
                  (local_get x)
                  (const_i32 10)
                ) ;; mod_i32
              ) ;; add_i32
            ) ;; set

            (set x
              (div_i32
                (local_get x)
                (const_i32 10)
              ) ;; div_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get rev)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 reverse_digits
            (const_i32 12034)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
