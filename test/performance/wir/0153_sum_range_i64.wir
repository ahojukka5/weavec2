; Performance: 0153_sum_range_i64
; tags = i64, loop, stress
; Why hard: Sum 1..120 in i64—wide accumulator with i32 index.
; Reveals: cast_i32_to_i64, add_i64, i32 loop index only.
; Expected: main returns triangular sum 1..120 as i32 cast. llvm-as accepts
;   emitted IR;
;   opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Accumulator truncated to i32; i64 add uses i32 ops.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let acc i64
          (const_i64 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 120)
            ) ;; le_i32
          ) ;; condition
          (do
            (set acc
              (add_i64
                (local_get acc)
                (cast_i32_to_i64
                  (local_get i)
                ) ;; cast_i32_to_i64
              ) ;; add_i64
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (cast_i64_to_i32
            (local_get acc)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
