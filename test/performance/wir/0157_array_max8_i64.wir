; Performance: 0157_array_max8_i64
; tags = heap, i64, memory, stress
; Why hard: Max of eight i64 heap values.
; Reveals: gt_i64, load_i64, conditional set maxv.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0157_array_max8_i64.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Max not updated in loop (let shadowing); compares signed as
;   unsigned.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (a ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i64_at
            (param_get a)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i64_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn max8
      (params
        (a ptr)
      ) ;; params
      (returns i64)
      (do
        (let maxv i64
          (load_i64
            (call_ptr elem
              (param_get a)
              (const_i32 0)
            ) ;; call_ptr
          ) ;; load_i64
        ) ;; let

        (let i i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 8)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let v i64
              (load_i64
                (call_ptr elem
                  (param_get a)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i64
            ) ;; let

            (if
              (condition
                (gt_i64
                  (local_get v)
                  (local_get maxv)
                ) ;; gt_i64
              ) ;; condition
              (then
                (do
                  (set maxv
                    (local_get v)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get maxv)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get a)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i64 (call_ptr elem (local_get a) (const_i32 0)) (const_i64 12))
        (store_i64 (call_ptr elem (local_get a) (const_i32 1)) (const_i64 3))
        (store_i64 (call_ptr elem (local_get a) (const_i32 2)) (const_i64 45))
        (store_i64 (call_ptr elem (local_get a) (const_i32 3)) (const_i64 7))
        (store_i64 (call_ptr elem (local_get a) (const_i32 4)) (const_i64 99))
        (store_i64 (call_ptr elem (local_get a) (const_i32 5)) (const_i64 18))
        (store_i64 (call_ptr elem (local_get a) (const_i32 6)) (const_i64 2))
        (store_i64 (call_ptr elem (local_get a) (const_i32 7)) (const_i64 56))

        (let m i64
          (call_i64 max8
            (local_get a)
          ) ;; call_i64
        ) ;; let

        (call_void free
          (local_get a)
        ) ;; call_void

        (return
          (cast_i64_to_i32
            (local_get m)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
