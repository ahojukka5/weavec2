; Performance: 0154_factorial20_i64
; tags = i64, stress
; Why hard: 20! in i64—large product recurrence.
; Reveals: mul_i64 loop on stack-carried fact.
; Expected: main returns 20! mod 1_000_000_007 as i32. llvm-as accepts emitted
;   IR; opt
;   -passes=mem2reg is an optional extra check.
; If LLVM regresses: Product width wrong; mul overflows silently in IR type.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let n i32
          (const_i32 1)
        ) ;; let

        (let fact i64
          (const_i64 1)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get n)
              (const_i32 20)
            ) ;; le_i32
          ) ;; condition
          (do
            (set fact
              (mul_i64
                (local_get fact)
                (cast_i32_to_i64
                  (local_get n)
                ) ;; cast_i32_to_i64
              ) ;; mul_i64
            ) ;; set

            (set n
              (add_i32
                (local_get n)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (cast_i64_to_i32
            (mod_i64
              (local_get fact)
              (const_i64 1000000007)
            ) ;; mod_i64
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
