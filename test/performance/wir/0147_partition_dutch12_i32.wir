; Performance: 0147_partition_dutch12_i32
; Why hard: Dutch-flag partition on twelve 0/1/2 values.
; Reveals: Three indices, many compare-branches, in-place swaps.
; If LLVM regresses: Pointers cross; elements not grouped; infinite loop on indices.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (a ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get a)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn partition012
      (params
        (a ptr)
      ) ;; params
      (returns i32)
      (do
        (let lo i32
          (const_i32 0)
        ) ;; let

        (let mid i32
          (const_i32 0)
        ) ;; let

        (let hi i32
          (const_i32 11)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get mid)
              (local_get hi)
            ) ;; le_i32
          ) ;; condition
          (do
            (let v i32
              (load_i32
                (call_ptr elem
                  (param_get a)
                  (local_get mid)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (if
              (condition
                (eq_i32
                  (local_get v)
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (let tmp i32
                    (load_i32
                      (call_ptr elem
                        (param_get a)
                        (local_get lo)
                      ) ;; call_ptr
                    ) ;; load_i32
                  ) ;; let

                  (store_i32
                    (call_ptr elem
                      (param_get a)
                      (local_get lo)
                    ) ;; call_ptr
                    (local_get v)
                  ) ;; store_i32

                  (store_i32
                    (call_ptr elem
                      (param_get a)
                      (local_get mid)
                    ) ;; call_ptr
                    (local_get tmp)
                  ) ;; store_i32

                  (set lo
                    (add_i32
                      (local_get lo)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set

                  (set mid
                    (add_i32
                      (local_get mid)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (if
                    (condition
                      (eq_i32
                        (local_get v)
                        (const_i32 2)
                      ) ;; eq_i32
                    ) ;; condition
                    (then
                      (do
                        (let tmp2 i32
                          (load_i32
                            (call_ptr elem
                              (param_get a)
                              (local_get hi)
                            ) ;; call_ptr
                          ) ;; load_i32
                        ) ;; let

                        (store_i32
                          (call_ptr elem
                            (param_get a)
                            (local_get hi)
                          ) ;; call_ptr
                          (local_get v)
                        ) ;; store_i32

                        (store_i32
                          (call_ptr elem
                            (param_get a)
                            (local_get mid)
                          ) ;; call_ptr
                          (local_get tmp2)
                        ) ;; store_i32

                        (set hi
                          (sub_i32
                            (local_get hi)
                            (const_i32 1)
                          ) ;; sub_i32
                        ) ;; set
                      ) ;; do
                    ) ;; then
                    (else
                      (do
                        (set mid
                          (add_i32
                            (local_get mid)
                            (const_i32 1)
                          ) ;; add_i32
                        ) ;; set
                      ) ;; do
                    ) ;; else
                  ) ;; if
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return
          (local_get lo)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 48)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get a)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem (local_get a) (const_i32 0)) (const_i32 2))
        (store_i32 (call_ptr elem (local_get a) (const_i32 1)) (const_i32 0))
        (store_i32 (call_ptr elem (local_get a) (const_i32 2)) (const_i32 1))
        (store_i32 (call_ptr elem (local_get a) (const_i32 3)) (const_i32 2))
        (store_i32 (call_ptr elem (local_get a) (const_i32 4)) (const_i32 0))
        (store_i32 (call_ptr elem (local_get a) (const_i32 5)) (const_i32 1))
        (store_i32 (call_ptr elem (local_get a) (const_i32 6)) (const_i32 2))
        (store_i32 (call_ptr elem (local_get a) (const_i32 7)) (const_i32 0))
        (store_i32 (call_ptr elem (local_get a) (const_i32 8)) (const_i32 1))
        (store_i32 (call_ptr elem (local_get a) (const_i32 9)) (const_i32 2))
        (store_i32 (call_ptr elem (local_get a) (const_i32 10)) (const_i32 0))
        (store_i32 (call_ptr elem (local_get a) (const_i32 11)) (const_i32 1))

        (let zeros i32
          (call_i32 partition012
            (local_get a)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get a)
        ) ;; call_void

        (return
          (local_get zeros)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
