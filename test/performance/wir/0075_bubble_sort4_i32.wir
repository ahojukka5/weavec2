; Performance: 0075_bubble_sort4_i32
; tags = algorithm, i32, memory, sort
; Why hard: O(n^2) compare-swap on four elements.
; Reveals: Nested loops, load/compare/store swap.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0075_bubble_sort4_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Swap stores to wrong indices; inner loop bound wrong.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn bubble4
      (params
        (items ptr)
      ) ;; params
      (returns i32)
      (do
        (let pass i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get pass)
              (const_i32 3)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let j i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (lt_i32
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                  (sub_i32
                    (const_i32 3)
                    (local_get pass)
                  ) ;; sub_i32
                ) ;; lt_i32
              ) ;; condition
              (do
                (let left i32
                  (load_i32
                    (call_ptr elem_ptr
                      (param_get items)
                      (local_get j)
                    ) ;; call_ptr
                  ) ;; load_i32
                ) ;; let

                (let right i32
                  (load_i32
                    (call_ptr elem_ptr
                      (param_get items)
                      (add_i32
                        (local_get j)
                        (const_i32 1)
                      ) ;; add_i32
                    ) ;; call_ptr
                  ) ;; load_i32
                ) ;; let

                (if
                  (condition
                    (gt_i32
                      (local_get left)
                      (local_get right)
                    ) ;; gt_i32
                  ) ;; condition
                  (then
                    (do
                      (store_i32
                        (call_ptr elem_ptr
                          (param_get items)
                          (local_get j)
                        ) ;; call_ptr
                        (local_get right)
                      ) ;; store_i32

                      (store_i32
                        (call_ptr elem_ptr
                          (param_get items)
                          (add_i32
                            (local_get j)
                            (const_i32 1)
                          ) ;; add_i32
                        ) ;; call_ptr
                        (local_get left)
                      ) ;; store_i32
                    ) ;; do
                  ) ;; then
                  (else
                    (do)
                  ) ;; else
                ) ;; if

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set pass
              (add_i32
                (local_get pass)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (load_i32
            (call_ptr elem_ptr
              (param_get items)
              (const_i32 3)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 4))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 2))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 3))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 1))

        (let last i32
          (call_i32 bubble4
            (local_get items)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (add_i32
            (local_get last)
            (const_i32 40)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
