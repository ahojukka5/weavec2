; Performance: 0108_hailstone_peak_i32
; Why hard: Collatz peak tracking. Inner while + max on carried peak.
; Reveals: div/mod branch, gt update.
; If LLVM regresses: Broken loop header phis or missing .merge blocks: carried locals reload from stack every iteration, wrong backedge operands, or SSA violations after llvm-as.
(core-module
  (core-version 1)
  (decls
    (fn hailstone_peak
      (params
        (start i32)
      ) ;; params
      (returns i32)
      (do
        (let n i32
          (param_get start)
        ) ;; let

        (let peak i32
          (param_get start)
        ) ;; let

        (while
          (condition
            (ne_i32
              (local_get n)
              (const_i32 1)
            ) ;; ne_i32
          ) ;; condition
          (do
            (if
              (condition
                (gt_i32
                  (local_get n)
                  (local_get peak)
                ) ;; gt_i32
              ) ;; condition
              (then
                (do
                  (set peak
                    (local_get n)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (if
              (condition
                (eq_i32
                  (mod_i32
                    (local_get n)
                    (const_i32 2)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set n
                    (div_i32
                      (local_get n)
                      (const_i32 2)
                    ) ;; div_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (set n
                    (add_i32
                      (mul_i32
                        (local_get n)
                        (const_i32 3)
                      ) ;; mul_i32
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return
          (local_get peak)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 hailstone_peak
            (const_i32 27)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
