; Performance: 0097_product_range_i32
; Why hard: Factorial-shaped product. mul recurrence like 0073.
; Reveals: mul_i32 carried product.
; If LLVM regresses: Product zeroed each trip; starts at 0.
(core-module
  (core-version 1)
  (decls
    (fn product_range
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let acc i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (set acc
              (mul_i32
                (local_get acc)
                (local_get i)
              ) ;; mul_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get acc)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 product_range
            (const_i32 6)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
