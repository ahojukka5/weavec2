; Algorithm: minimum of five heap-backed i32 values
; Tests: reduction loop with conditional min update
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn min5
      (params
        (items ptr)
      ) ;; params
      (returns i32)
      (do
        (let m i32
          (load_i32
            (call_ptr elem_ptr
              (param_get items)
              (const_i32 0)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; let

        (let i i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 5)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let v i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (if
              (condition
                (lt_i32
                  (local_get v)
                  (local_get m)
                ) ;; lt_i32
              ) ;; condition
              (then
                (do
                  (set m
                    (local_get v)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get m)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 20)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 8))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 3))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 11))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 1))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 6))

        (let m i32
          (call_i32 min5
            (local_get items)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get m)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
