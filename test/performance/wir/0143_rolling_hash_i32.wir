; Performance: 0143_rolling_hash_i32
; tags = bitwise, i32, stress
; Why hard: Polynomial rolling hash over 64 bytes.
; Reveals: mul/add/mod recurrence each byte.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0143_rolling_hash_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Hash forgets to subtract outgoing term; mod applied once
;   not per step.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn hash64
      (params
        (data ptr)
      ) ;; params
      (returns i32)
      (do
        (let h i32
          (const_i32 0)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 64)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let b i32
              (load_i32
                (array_i32_at
                  (param_get data)
                  (cast_i32_to_i64
                    (local_get i)
                  ) ;; cast_i32_to_i64
                ) ;; array_i32_at
              ) ;; load_i32
            ) ;; let

            (set h
              (mod_i32
                (add_i32
                  (add_i32
                    (mul_i32
                      (local_get h)
                      (const_i32 31)
                    ) ;; mul_i32
                    (local_get b)
                  ) ;; add_i32
                  (const_i32 1)
                ) ;; add_i32
                (const_i32 1000003)
              ) ;; mod_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get h)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let data ptr
          (call_ptr malloc
            (const_i64 256)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get data)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let k i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get k)
              (const_i32 64)
            ) ;; lt_i32
          ) ;; condition
          (do
            (store_i32
              (array_i32_at
                (local_get data)
                (cast_i32_to_i64
                  (local_get k)
                ) ;; cast_i32_to_i64
              ) ;; array_i32_at
              (add_i32
                (mul_i32
                  (local_get k)
                  (const_i32 7)
                ) ;; mul_i32
                (const_i32 13)
              ) ;; add_i32
            ) ;; store_i32

            (set k
              (add_i32
                (local_get k)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (let ans i32
          (call_i32 hash64
            (local_get data)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get data)
        ) ;; call_void

        (return
          (local_get ans)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
