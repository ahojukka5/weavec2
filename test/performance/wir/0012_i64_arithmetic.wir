; Performance: 0012_i64_arithmetic
; tags = i64, smoke
; Why hard: Smoke baseline for i64 add/sub. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: add_i64/sub_i64
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0012_i64_arithmetic.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: 32-bit ops used where i64 required; nsw flags inconsistent.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let a i64
          (const_i64 20)
        ) ;; let
        (let b i64
          (const_i64 2)
        ) ;; let
        (let c i64
          (mul_i64
            (local_get b)
            (const_i64 11)
          ) ;; mul_i64
        ) ;; let
        (let d i64
          (add_i64
            (local_get a)
            (local_get c)
          ) ;; add_i64
        ) ;; let
        (return
          (cast_i64_to_i32
            (local_get d)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
