; Performance: 0090_floor_sqrt_i32
; tags = algorithm, i32
; Why hard: Integer sqrt by trial. Compare i*i <= n each step.
; Reveals: mul_i32 for square, carried root.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0090_floor_sqrt_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Off-by-one sqrt; square overflows silently in i32.
(core-module
  (core-version 1)
  (decls
    (fn floor_sqrt
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let r i32
          (const_i32 0)
        ) ;; let

        (let t i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (le_i32
              (mul_i32
                (local_get t)
                (local_get t)
              ) ;; mul_i32
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (set r
              (local_get t)
            ) ;; set

            (set t
              (add_i32
                (local_get t)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get r)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 floor_sqrt
            (const_i32 200)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
