; Stress: bubble sort on eight heap elements
; Reveals: O(n^2) compare-swap, redundant loads, inner branch on every pair
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn bubble_sort8
      (params
        (items ptr)
      ) ;; params
      (returns void)
      (do
        (let pass i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get pass)
              (const_i32 7)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let j i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (lt_i32
                  (local_get j)
                  (sub_i32
                    (const_i32 7)
                    (local_get pass)
                  ) ;; sub_i32
                ) ;; lt_i32
              ) ;; condition
              (do
                (let a i32
                  (load_i32
                    (call_ptr elem_ptr
                      (param_get items)
                      (local_get j)
                    ) ;; call_ptr
                  ) ;; load_i32
                ) ;; let

                (let b i32
                  (load_i32
                    (call_ptr elem_ptr
                      (param_get items)
                      (add_i32
                        (local_get j)
                        (const_i32 1)
                      ) ;; add_i32
                    ) ;; call_ptr
                  ) ;; load_i32
                ) ;; let

                (if
                  (condition
                    (gt_i32
                      (local_get a)
                      (local_get b)
                    ) ;; gt_i32
                  ) ;; condition
                  (then
                    (do
                      (store_i32
                        (call_ptr elem_ptr
                          (param_get items)
                          (local_get j)
                        ) ;; call_ptr
                        (local_get b)
                      ) ;; store_i32

                      (store_i32
                        (call_ptr elem_ptr
                          (param_get items)
                          (add_i32
                            (local_get j)
                            (const_i32 1)
                          ) ;; add_i32
                        ) ;; call_ptr
                        (local_get a)
                      ) ;; store_i32
                    ) ;; do
                  ) ;; then
                  (else
                    (do)
                  ) ;; else
                ) ;; if

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set pass
              (add_i32
                (local_get pass)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 32)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 8))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 3))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 7))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 1))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 6))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 5)) (const_i32 2))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 6)) (const_i32 5))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 7)) (const_i32 4))

        (call_void bubble_sort8
          (local_get items)
        ) ;; call_void

        (let sum i32
          (add_i32
            (load_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)))
            (load_i32 (call_ptr elem_ptr (local_get items) (const_i32 7)))
          ) ;; add_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get sum)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
