; Performance: 0089_tribonacci_iter_i32
; tags = algorithm, i32, loop
; Why hard: Three-term recurrence. Three carried locals—phi arity 3.
; Reveals: Three updates per iteration.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0089_tribonacci_iter_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Terms rotate wrong; T(n) drift.
(core-module
  (core-version 1)
  (decls
    (fn trib
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (le_i32
              (param_get n)
              (const_i32 1)
            ) ;; le_i32
          ) ;; condition
          (then
            (do
              (return
                (param_get n)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (eq_i32
              (param_get n)
              (const_i32 2)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 1)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let a i32
          (const_i32 0)
        ) ;; let

        (let b i32
          (const_i32 1)
        ) ;; let

        (let c i32
          (const_i32 1)
        ) ;; let

        (let i i32
          (const_i32 3)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (let next i32
              (add_i32
                (add_i32
                  (local_get a)
                  (local_get b)
                ) ;; add_i32
                (local_get c)
              ) ;; add_i32
            ) ;; let

            (set a
              (local_get b)
            ) ;; set

            (set b
              (local_get c)
            ) ;; set

            (set c
              (local_get next)
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get c)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 trib
            (const_i32 10)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
