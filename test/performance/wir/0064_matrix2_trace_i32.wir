; Algorithm: 2x2 matrix multiply trace
; Tests: tensor-style arithmetic with immutable scalar intermediates
(core-module
  (core-version 1)
  (decls
    (fn trace_mul2
      (params
        (a00 i32)
        (a01 i32)
        (a10 i32)
        (a11 i32)
        (b00 i32)
        (b01 i32)
        (b10 i32)
        (b11 i32)
      ) ;; params
      (returns i32)
      (do
        (let c00 i32
          (add_i32
            (mul_i32
              (param_get a00)
              (param_get b00)
            ) ;; mul_i32
            (mul_i32
              (param_get a01)
              (param_get b10)
            ) ;; mul_i32
          ) ;; add_i32
        ) ;; let

        (let c11 i32
          (add_i32
            (mul_i32
              (param_get a10)
              (param_get b01)
            ) ;; mul_i32
            (mul_i32
              (param_get a11)
              (param_get b11)
            ) ;; mul_i32
          ) ;; add_i32
        ) ;; let

        (return
          (add_i32
            (local_get c00)
            (local_get c11)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 trace_mul2
            (const_i32 1)
            (const_i32 2)
            (const_i32 3)
            (const_i32 4)
            (const_i32 5)
            (const_i32 6)
            (const_i32 7)
            (const_i32 8)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
