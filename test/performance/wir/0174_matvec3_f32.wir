; Performance: 0174_matvec3_f32
; tags = f32, float, memory, stress
; Why hard: 3x3 by 3 f32 matvec on heap; identity matrix smoke.
; Reveals: load_f32/store_f32, ptr_add, call_f32.
; Expected: main returns 1 (identity matvec, first component). llvm-as accepts
;   emitted
;   IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: GEP stride 4 vs 8; row/column major swap in loads.
(core-module
  (core-version 1)
  (decls
    (extern malloc (params (size i64)) (returns ptr))
    (extern free (params (p ptr)) (returns void))
    (fn matvec3
      (params (m ptr) (v ptr))
      (returns f32)
      (do
        (let r0 f32
          (add_f32
            (mul_f32 (load_f32 (ptr_add m (const_i64 0))) (load_f32 (ptr_add v (const_i64 0))))
            (add_f32
              (mul_f32 (load_f32 (ptr_add m (const_i64 4))) (load_f32 (ptr_add v (const_i64 4))))
              (mul_f32 (load_f32 (ptr_add m (const_i64 8))) (load_f32 (ptr_add v (const_i64 8))))
            )
          )
        )
        (return (local_get r0))
      )
    )
    (fn main
      (params)
      (returns i32)
      (do
        (let m ptr (call_ptr malloc (const_i64 36)))
        (let v ptr (call_ptr malloc (const_i64 12)))
        (if
          (condition (eq_ptr (local_get m) (const_null)))
          (then (do (return (const_i32 0))))
          (else (do))
        )
        (if
          (condition (eq_ptr (local_get v) (const_null)))
          (then (do
            (call_void free (local_get m))
            (return (const_i32 0))
          ))
          (else (do))
        )
        (store_f32 (ptr_add (local_get m) (const_i64 0)) (const_f32 1))
        (store_f32 (ptr_add (local_get m) (const_i64 4)) (const_f32 0))
        (store_f32 (ptr_add (local_get m) (const_i64 8)) (const_f32 0))
        (store_f32 (ptr_add (local_get m) (const_i64 12)) (const_f32 0))
        (store_f32 (ptr_add (local_get m) (const_i64 16)) (const_f32 1))
        (store_f32 (ptr_add (local_get m) (const_i64 20)) (const_f32 0))
        (store_f32 (ptr_add (local_get m) (const_i64 24)) (const_f32 0))
        (store_f32 (ptr_add (local_get m) (const_i64 28)) (const_f32 0))
        (store_f32 (ptr_add (local_get m) (const_i64 32)) (const_f32 1))
        (store_f32 (ptr_add (local_get v) (const_i64 0)) (const_f32 1))
        (store_f32 (ptr_add (local_get v) (const_i64 4)) (const_f32 2))
        (store_f32 (ptr_add (local_get v) (const_i64 8)) (const_f32 3))
        (let out f32 (call_f32 matvec3 (local_get m) (local_get v)))
        (call_void free (local_get m))
        (call_void free (local_get v))
        (return (cast_f32_to_i32 (local_get out)))
      )
    )
  )
)
