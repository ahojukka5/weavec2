; Performance: 0005_let_local
; tags = i32, smoke
; Why hard: Smoke baseline for local binding. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: let + local_get without control flow
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0005_let_local.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Local name maps to wrong SSA name or duplicate alloca for
;   one binding.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 40)
        ) ;; let
        (return
          (add_i32
            (local_get x)
            (const_i32 2)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
