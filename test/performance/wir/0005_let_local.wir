; Performance: 0005_let_local
; Why hard: Smoke baseline for local binding. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: let + local_get without control flow
; If LLVM regresses: Local name maps to wrong SSA name or duplicate alloca for one binding.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 40)
        ) ;; let
        (return
          (add_i32
            (local_get x)
            (const_i32 2)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
