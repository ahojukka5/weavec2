; Stress: Levenshtein DP 7x7 table (strings length 6)
; Reveals: min of three paths, 2D heap, nested loops
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn at
      (params
        (t ptr)
        (i i32)
        (j i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get t)
            (cast_i32_to_i64
              (add_i32
                (mul_i32
                  (param_get i)
                  (const_i32 7)
                ) ;; mul_i32
                (param_get j)
              ) ;; add_i32
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn cost
      (params
        (i i32)
        (j i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (eq_i32
              (mod_i32
                (add_i32
                  (param_get i)
                  (param_get j)
                ) ;; add_i32
                (const_i32 3)
              ) ;; mod_i32
              (const_i32 0)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 1)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn

    (fn edit6
      (params
        (t ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 6)
            ) ;; le_i32
          ) ;; condition
          (do
            (let j i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (le_i32
                  (local_get j)
                  (const_i32 6)
                ) ;; le_i32
              ) ;; condition
              (do
                (if
                  (condition
                    (or_bool
                      (eq_i32
                        (local_get i)
                        (const_i32 0)
                      ) ;; eq_i32
                      (eq_i32
                        (local_get j)
                        (const_i32 0)
                      ) ;; eq_i32
                    ) ;; or_bool
                  ) ;; condition
                  (then
                    (do
                      (store_i32
                        (call_ptr at
                          (param_get t)
                          (local_get i)
                          (local_get j)
                        ) ;; call_ptr
                        (add_i32
                          (local_get i)
                          (local_get j)
                        ) ;; add_i32
                      ) ;; store_i32
                    ) ;; do
                  ) ;; then
                  (else
                    (do
                      (let del i32
                        (add_i32
                          (load_i32
                            (call_ptr at
                              (param_get t)
                              (sub_i32
                                (local_get i)
                                (const_i32 1)
                              ) ;; sub_i32
                              (local_get j)
                            ) ;; call_ptr
                          ) ;; load_i32
                          (const_i32 1)
                        ) ;; add_i32
                      ) ;; let

                      (let ins i32
                        (add_i32
                          (load_i32
                            (call_ptr at
                              (param_get t)
                              (local_get i)
                              (sub_i32
                                (local_get j)
                                (const_i32 1)
                              ) ;; sub_i32
                            ) ;; call_ptr
                          ) ;; load_i32
                          (const_i32 1)
                        ) ;; add_i32
                      ) ;; let

                      (let sub_cost i32
                        (call_i32 cost
                          (local_get i)
                          (local_get j)
                        ) ;; call_i32
                      ) ;; let

                      (let rep i32
                        (add_i32
                          (add_i32
                            (load_i32
                              (call_ptr at
                                (param_get t)
                                (sub_i32
                                  (local_get i)
                                  (const_i32 1)
                                ) ;; sub_i32
                                (sub_i32
                                  (local_get j)
                                  (const_i32 1)
                                ) ;; sub_i32
                              ) ;; call_ptr
                            ) ;; load_i32
                            (local_get sub_cost)
                          ) ;; add_i32
                          (const_i32 0)
                        ) ;; add_i32
                      ) ;; let

                      (let best i32
                        (local_get del)
                      ) ;; let

                      (if
                        (condition
                          (gt_i32
                            (local_get ins)
                            (local_get best)
                          ) ;; gt_i32
                        ) ;; condition
                        (then
                          (do
                            (let best i32
                              (local_get ins)
                            ) ;; let
                          ) ;; do
                        ) ;; then
                        (else
                          (do
                            (if
                              (condition
                                (gt_i32
                                  (local_get rep)
                                  (local_get best)
                                ) ;; gt_i32
                              ) ;; condition
                              (then
                                (do
                                  (let best i32
                                    (local_get rep)
                                  ) ;; let
                                ) ;; do
                              ) ;; then
                              (else
                                (do)
                              ) ;; else
                            ) ;; if
                          ) ;; do
                        ) ;; else
                      ) ;; if

                      (store_i32
                        (call_ptr at
                          (param_get t)
                          (local_get i)
                          (local_get j)
                        ) ;; call_ptr
                        (local_get best)
                      ) ;; store_i32
                    ) ;; do
                  ) ;; else
                ) ;; if

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (load_i32
            (call_ptr at
              (param_get t)
              (const_i32 6)
              (const_i32 6)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let t ptr
          (call_ptr malloc
            (const_i64 196)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get t)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let dist i32
          (call_i32 edit6
            (local_get t)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get t)
        ) ;; call_void

        (return
          (local_get dist)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
