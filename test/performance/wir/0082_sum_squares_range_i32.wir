; Performance: 0082_sum_squares_range_i32
; Why hard: Sum of squares 1^2+..+n^2. Mul inside add recurrence stresses licm/prevent hoisting bugs.
; Reveals: mul_i32 then add_i32 each step.
; If LLVM regresses: Square not squared (add instead of mul); sum uses stale i.
(core-module
  (core-version 1)
  (decls
    (fn sum_squares
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (set total
              (add_i32
                (local_get total)
                (mul_i32
                  (local_get i)
                  (local_get i)
                ) ;; mul_i32
              ) ;; add_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 sum_squares
            (const_i32 7)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
