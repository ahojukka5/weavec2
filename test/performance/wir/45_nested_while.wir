(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let outer i32
          (const_i32 0)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get outer)
              (const_i32 2)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let inner i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (lt_i32
                  (local_get inner)
                  (const_i32 3)
                ) ;; lt_i32
              ) ;; condition
              (do
                (set total
                  (add_i32
                    (local_get total)
                    (const_i32 7)
                  ) ;; add_i32
                ) ;; set

                (set inner
                  (add_i32
                    (local_get inner)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set outer
              (add_i32
                (local_get outer)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
