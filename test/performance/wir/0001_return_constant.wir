; Performance: 0001_return_constant
; tags = i32, smoke
; Why hard: Smoke baseline for minimal return. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: const_i32 return, empty prologue
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0001_return_constant.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Wrong return type or extra unreachable blocks after ret.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (const_i32 0)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
