; Algorithm: count primes up to 16 with a small sieve
; Tests: nested memory loops, branchy loop bodies, and typed array addressing
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn count_primes16
      (params
        (flags ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 16)
            ) ;; le_i32
          ) ;; condition
          (do
            (store_i32
              (call_ptr elem_ptr
                (param_get flags)
                (local_get i)
              ) ;; call_ptr
              (const_i32 1)
            ) ;; store_i32

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (store_i32 (call_ptr elem_ptr (param_get flags) (const_i32 0)) (const_i32 0))
        (store_i32 (call_ptr elem_ptr (param_get flags) (const_i32 1)) (const_i32 0))

        (let p i32
          (const_i32 2)
        ) ;; let

        (while
          (condition
            (le_i32
              (mul_i32
                (local_get p)
                (local_get p)
              ) ;; mul_i32
              (const_i32 16)
            ) ;; le_i32
          ) ;; condition
          (do
            (if
              (condition
                (ne_i32
                  (load_i32
                    (call_ptr elem_ptr
                      (param_get flags)
                      (local_get p)
                    ) ;; call_ptr
                  ) ;; load_i32
                  (const_i32 0)
                ) ;; ne_i32
              ) ;; condition
              (then
                (do
                  (let multiple i32
                    (mul_i32
                      (local_get p)
                      (local_get p)
                    ) ;; mul_i32
                  ) ;; let

                  (while
                    (condition
                      (le_i32
                        (local_get multiple)
                        (const_i32 16)
                      ) ;; le_i32
                    ) ;; condition
                    (do
                      (store_i32
                        (call_ptr elem_ptr
                          (param_get flags)
                          (local_get multiple)
                        ) ;; call_ptr
                        (const_i32 0)
                      ) ;; store_i32

                      (set multiple
                        (add_i32
                          (local_get multiple)
                          (local_get p)
                        ) ;; add_i32
                      ) ;; set
                    ) ;; do
                  ) ;; while
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set p
              (add_i32
                (local_get p)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (let count i32
          (const_i32 0)
        ) ;; let

        (set i
          (const_i32 0)
        ) ;; set

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 16)
            ) ;; le_i32
          ) ;; condition
          (do
            (set count
              (add_i32
                (local_get count)
                (load_i32
                  (call_ptr elem_ptr
                    (param_get flags)
                    (local_get i)
                  ) ;; call_ptr
                ) ;; load_i32
              ) ;; add_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get count)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let flags ptr
          (call_ptr malloc
            (const_i64 68)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get flags)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let count i32
          (call_i32 count_primes16
            (local_get flags)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get flags)
        ) ;; call_void

        (return
          (add_i32
            (local_get count)
            (const_i32 36)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
