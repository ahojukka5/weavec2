; Performance: 0156_gcd_i64
; tags = i64, numeric, stress
; Why hard: Euclidean GCD on i64 pair.
; Reveals: mod_i64, carried x/y on stack slots.
; Expected: Golden LLVM matches test/performance/expected-llvm/0156_gcd_i64.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: mod uses i32 remainder; swap order wrong.
(core-module
  (core-version 1)
  (decls
    (fn gcd_i64
      (params
        (a i64)
        (b i64)
      ) ;; params
      (returns i64)
      (do
        (let x i64
          (param_get a)
        ) ;; let

        (let y i64
          (param_get b)
        ) ;; let

        (while
          (condition
            (ne_i64
              (local_get y)
              (const_i64 0)
            ) ;; ne_i64
          ) ;; condition
          (do
            (let r i64
              (mod_i64
                (local_get x)
                (local_get y)
              ) ;; mod_i64
            ) ;; let

            (set x
              (local_get y)
            ) ;; set

            (set y
              (local_get r)
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (cast_i64_to_i32
            (call_i64 gcd_i64
              (const_i64 462)
              (const_i64 1071)
            ) ;; call_i64
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
