; Performance: 0002_return_42
; Why hard: Smoke baseline for constant 42. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: named literal return
; If LLVM regresses: Returns wrong constant or emits dead allocas before ret.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
