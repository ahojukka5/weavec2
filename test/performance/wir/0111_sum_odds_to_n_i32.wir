; Performance: 0111_sum_odds_to_n_i32
; Why hard: Sum odd numbers. Stride-2 style loop.
; Reveals: add with i+=2 or equivalent.
; If LLVM regresses: Includes evens; starts at wrong parity.
(core-module
  (core-version 1)
  (decls
    (fn sum_odds_to
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let v i32
          (const_i32 1)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get v)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (set total
              (add_i32
                (local_get total)
                (local_get v)
              ) ;; add_i32
            ) ;; set

            (set v
              (add_i32
                (local_get v)
                (const_i32 2)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 sum_odds_to
            (const_i32 15)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
