; Performance: 0091_linear_search5_i32
; tags = algorithm, i32, memory, search
; Why hard: Linear search five elements. Early-exit index pattern.
; Reveals: load, compare, break index.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0091_linear_search5_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Always returns last index; never finds match.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn find5
      (params
        (items ptr)
        (target i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (let found i32
          (const_i32 -1)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 5)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (and_bool
                  (eq_i32
                    (load_i32
                      (call_ptr elem_ptr
                        (param_get items)
                        (local_get i)
                      ) ;; call_ptr
                    ) ;; load_i32
                    (param_get target)
                  ) ;; eq_i32
                  (eq_i32
                    (local_get found)
                    (const_i32 -1)
                  ) ;; eq_i32
                ) ;; and_bool
              ) ;; condition
              (then
                (do
                  (set found
                    (local_get i)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get found)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 20)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 -1)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 11))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 22))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 33))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 44))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 55))

        (let idx i32
          (call_i32 find5
            (local_get items)
            (const_i32 33)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get idx)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
