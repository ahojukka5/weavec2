(core-module
  (core-version 1)
  (decls
    (fn same_ptr
      (params
        (a ptr)
        (b ptr)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (eq_ptr
              (param_get a)
              (param_get b)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 same_ptr
            (const_null)
            (const_null)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
