; Performance: 0055_integration_nested_control_flow
; Why hard: Combines nested if/while; easy to mis-wire merge edges.
; Reveals: Nested if inside while, multiple join points.
; If LLVM regresses: Broken loop header phis or missing .merge blocks: carried locals reload from stack every iteration, wrong backedge operands, or SSA violations after llvm-as.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let
          sum
          i64
          (const_i64 0))
        (let
          i
          i64
          (const_i64 0))
        (while
          (condition
            (lt_i64
              (local_get i)
              (const_i64 10)))
          (do
            (if
              (condition
                (gt_i64
                  (local_get i)
                  (const_i64 5)))
              (then
                (do
                  (set
                    sum
                    (add_i64
                      (local_get sum)
                      (mul_i64
                        (local_get i)
                        (const_i64 2))))))
              (else
                (do
                  (set
                    sum
                    (add_i64
                      (local_get sum)
                      (local_get i))))))
            (set
              i
              (add_i64
                (local_get i)
                (const_i64 1)))))
        (return
          (cast_i64_to_i32
            (local_get sum)))))))
