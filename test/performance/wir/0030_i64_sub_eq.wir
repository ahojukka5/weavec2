; Performance: 0030_i64_sub_eq
; Why hard: Smoke baseline for i64 compare chain. Failures here usually indicate broken lowering shared by every later fixture.
; Reveals: sub_i64 then eq_i64
; If LLVM regresses: Compare uses truncated subresult.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (eq_i64
              (sub_i64
                (const_i64 50)
                (const_i64 8)
              ) ;; sub_i64
              (const_i64 42)
            ) ;; eq_i64
          ) ;; condition
          (then
            (do
              (return
                (const_i32 42)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
