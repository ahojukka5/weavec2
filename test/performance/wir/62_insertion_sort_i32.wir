; Algorithm: insertion sort over four heap-backed i32 values
; Tests: nested loops, pointer arithmetic, load/store, and branch exits
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (ptr_add
            (param_get base)
            (mul_i64
              (cast_i32_to_i64
                (param_get index)
              ) ;; cast_i32_to_i64
              (const_i64 4)
            ) ;; mul_i64
          ) ;; ptr_add
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn sort4
      (params
        (items ptr)
      ) ;; params
      (returns void)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let key i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get i)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (let j i32
              (sub_i32
                (local_get i)
                (const_i32 1)
              ) ;; sub_i32
            ) ;; let

            (let done i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (and_bool
                  (ge_i32
                    (local_get j)
                    (const_i32 0)
                  ) ;; ge_i32
                  (eq_i32
                    (local_get done)
                    (const_i32 0)
                  ) ;; eq_i32
                ) ;; and_bool
              ) ;; condition
              (do
                (let current i32
                  (load_i32
                    (call_ptr elem_ptr
                      (param_get items)
                      (local_get j)
                    ) ;; call_ptr
                  ) ;; load_i32
                ) ;; let

                (if
                  (condition
                    (gt_i32
                      (local_get current)
                      (local_get key)
                    ) ;; gt_i32
                  ) ;; condition
                  (then
                    (do
                      (store_i32
                        (call_ptr elem_ptr
                          (param_get items)
                          (add_i32
                            (local_get j)
                            (const_i32 1)
                          ) ;; add_i32
                        ) ;; call_ptr
                        (local_get current)
                      ) ;; store_i32

                      (set j
                        (sub_i32
                          (local_get j)
                          (const_i32 1)
                        ) ;; sub_i32
                      ) ;; set
                    ) ;; do
                  ) ;; then
                  (else
                    (do
                      (set done
                        (const_i32 1)
                      ) ;; set
                    ) ;; do
                  ) ;; else
                ) ;; if
              ) ;; do
            ) ;; while

            (store_i32
              (call_ptr elem_ptr
                (param_get items)
                (add_i32
                  (local_get j)
                  (const_i32 1)
                ) ;; add_i32
              ) ;; call_ptr
              (local_get key)
            ) ;; store_i32

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn sorted_checksum4
      (params
        (items ptr)
      ) ;; params
      (returns i32)
      (do
        (return
          (add_i32
            (add_i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (const_i32 0)
                ) ;; call_ptr
              ) ;; load_i32
              (mul_i32
                (load_i32
                  (call_ptr elem_ptr
                    (param_get items)
                    (const_i32 1)
                  ) ;; call_ptr
                ) ;; load_i32
                (const_i32 2)
              ) ;; mul_i32
            ) ;; add_i32
            (add_i32
              (mul_i32
                (load_i32
                  (call_ptr elem_ptr
                    (param_get items)
                    (const_i32 2)
                  ) ;; call_ptr
                ) ;; load_i32
                (const_i32 3)
              ) ;; mul_i32
              (mul_i32
                (load_i32
                  (call_ptr elem_ptr
                    (param_get items)
                    (const_i32 3)
                  ) ;; call_ptr
                ) ;; load_i32
                (const_i32 4)
              ) ;; mul_i32
            ) ;; add_i32
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32
          (call_ptr elem_ptr
            (local_get items)
            (const_i32 0)
          ) ;; call_ptr
          (const_i32 4)
        ) ;; store_i32

        (store_i32
          (call_ptr elem_ptr
            (local_get items)
            (const_i32 1)
          ) ;; call_ptr
          (const_i32 1)
        ) ;; store_i32

        (store_i32
          (call_ptr elem_ptr
            (local_get items)
            (const_i32 2)
          ) ;; call_ptr
          (const_i32 3)
        ) ;; store_i32

        (store_i32
          (call_ptr elem_ptr
            (local_get items)
            (const_i32 3)
          ) ;; call_ptr
          (const_i32 2)
        ) ;; store_i32

        (call_void sort4
          (local_get items)
        ) ;; call_void

        (let total i32
          (call_i32 sorted_checksum4
            (local_get items)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
