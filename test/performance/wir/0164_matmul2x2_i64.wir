; Stress: 2x2 matrix multiply row-major on heap (i64)
; Reveals: triple nested loops, mul_i64/add_i64, array_i64_at
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn at
      (params
        (m ptr)
        (r i32)
        (c i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i64_at
            (param_get m)
            (cast_i32_to_i64
              (add_i32
                (mul_i32
                  (param_get r)
                  (const_i32 2)
                ) ;; mul_i32
                (param_get c)
              ) ;; add_i32
            ) ;; cast_i32_to_i64
          ) ;; array_i64_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn matmul2
      (params
        (a ptr)
        (b ptr)
        (out ptr)
      ) ;; params
      (returns void)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 2)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let j i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (lt_i32
                  (local_get j)
                  (const_i32 2)
                ) ;; lt_i32
              ) ;; condition
              (do
                (let sum i64
                  (const_i64 0)
                ) ;; let

                (let k i32
                  (const_i32 0)
                ) ;; let

                (while
                  (condition
                    (lt_i32
                      (local_get k)
                      (const_i32 2)
                    ) ;; lt_i32
                  ) ;; condition
                  (do
                    (set sum
                      (add_i64
                        (local_get sum)
                        (mul_i64
                          (load_i64
                            (call_ptr at
                              (param_get a)
                              (local_get i)
                              (local_get k)
                            ) ;; call_ptr
                          ) ;; load_i64
                          (load_i64
                            (call_ptr at
                              (param_get b)
                              (local_get k)
                              (local_get j)
                            ) ;; call_ptr
                          ) ;; load_i64
                        ) ;; mul_i64
                      ) ;; add_i64
                    ) ;; set

                    (set k
                      (add_i32
                        (local_get k)
                        (const_i32 1)
                      ) ;; add_i32
                    ) ;; set
                  ) ;; do
                ) ;; while

                (store_i64
                  (call_ptr at
                    (param_get out)
                    (local_get i)
                    (local_get j)
                  ) ;; call_ptr
                  (local_get sum)
                ) ;; store_i64

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 32)
          ) ;; call_ptr
        ) ;; let

        (let b ptr
          (call_ptr malloc
            (const_i64 32)
          ) ;; call_ptr
        ) ;; let

        (let out ptr
          (call_ptr malloc
            (const_i64 32)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (or_bool
              (eq_ptr
                (local_get a)
                (const_null)
              ) ;; eq_ptr
              (or_bool
                (eq_ptr
                  (local_get b)
                  (const_null)
                ) ;; eq_ptr
                (eq_ptr
                  (local_get out)
                  (const_null)
                ) ;; eq_ptr
              ) ;; or_bool
            ) ;; or_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i64 (call_ptr at (local_get a) (const_i32 0) (const_i32 0)) (const_i64 1))
        (store_i64 (call_ptr at (local_get a) (const_i32 0) (const_i32 1)) (const_i64 2))
        (store_i64 (call_ptr at (local_get a) (const_i32 1) (const_i32 0)) (const_i64 3))
        (store_i64 (call_ptr at (local_get a) (const_i32 1) (const_i32 1)) (const_i64 4))

        (store_i64 (call_ptr at (local_get b) (const_i32 0) (const_i32 0)) (const_i64 5))
        (store_i64 (call_ptr at (local_get b) (const_i32 0) (const_i32 1)) (const_i64 6))
        (store_i64 (call_ptr at (local_get b) (const_i32 1) (const_i32 0)) (const_i64 7))
        (store_i64 (call_ptr at (local_get b) (const_i32 1) (const_i32 1)) (const_i64 8))

        (call_void matmul2
          (local_get a)
          (local_get b)
          (local_get out)
        ) ;; call_void

        (let ans i64
          (load_i64
            (call_ptr at
              (local_get out)
              (const_i32 1)
              (const_i32 1)
            ) ;; call_ptr
          ) ;; load_i64
        ) ;; let

        (call_void free
          (local_get a)
        ) ;; call_void
        (call_void free
          (local_get b)
        ) ;; call_void
        (call_void free
          (local_get out)
        ) ;; call_void

        (return
          (cast_i64_to_i32
            (mod_i64
              (local_get ans)
              (const_i64 1000000007)
            ) ;; mod_i64
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
