(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr malloc
            (const_i64 1)
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if
        (let value i32
          (const_i32 42)
        ) ;; let
        (store_i8
          (local_get p)
          (local_get value)
        ) ;; store_i8
        (let loaded i32
          (load_u8
            (local_get p)
          ) ;; load_u8
        ) ;; let
        (call_void free
          (local_get p)
        ) ;; call_void
        (return
          (local_get loaded)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
