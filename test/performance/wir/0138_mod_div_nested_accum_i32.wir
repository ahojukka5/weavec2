; Performance: 0138_mod_div_nested_accum_i32
; Why hard: 200 steps with mod/div in nested if on residues.
; Reveals: sdiv/srem in branchy loop, carried acc.
; If LLVM regresses: Uses udiv/urem; acc updated on wrong branch only.
(core-module
  (core-version 1)
  (decls
    (fn run
      (params)
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let acc i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 200)
            ) ;; le_i32
          ) ;; condition
          (do
            (let r7 i32
              (mod_i32
                (local_get i)
                (const_i32 7)
              ) ;; mod_i32
            ) ;; let

            (let q7 i32
              (div_i32
                (local_get i)
                (const_i32 7)
              ) ;; div_i32
            ) ;; let

            (let r13 i32
              (mod_i32
                (local_get i)
                (const_i32 13)
              ) ;; mod_i32
            ) ;; let

            (if
              (condition
                (eq_i32
                  (local_get r7)
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set acc
                    (add_i32
                      (local_get acc)
                      (local_get q7)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (if
                    (condition
                      (eq_i32
                        (local_get r13)
                        (const_i32 0)
                      ) ;; eq_i32
                    ) ;; condition
                    (then
                      (do
                        (set acc
                          (sub_i32
                            (local_get acc)
                            (local_get r7)
                          ) ;; sub_i32
                        ) ;; set
                      ) ;; do
                    ) ;; then
                    (else
                      (do
                        (set acc
                          (add_i32
                            (local_get acc)
                            (add_i32
                              (local_get r7)
                              (local_get r13)
                            ) ;; add_i32
                          ) ;; add_i32
                        ) ;; set
                      ) ;; do
                    ) ;; else
                  ) ;; if
                ) ;; do
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get acc)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 run)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
