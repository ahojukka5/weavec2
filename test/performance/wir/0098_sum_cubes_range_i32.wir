; Performance: 0098_sum_cubes_range_i32
; Why hard: Sum of cubes. Two muls per iteration.
; Reveals: cube via mul twice, add.
; If LLVM regresses: Cube computed as i*i+i wrong.
(core-module
  (core-version 1)
  (decls
    (fn sum_cubes
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (let sq i32
              (mul_i32
                (local_get i)
                (local_get i)
              ) ;; mul_i32
            ) ;; let

            (set total
              (add_i32
                (local_get total)
                (mul_i32
                  (local_get sq)
                  (local_get i)
                ) ;; mul_i32
              ) ;; add_i32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 sum_cubes
            (const_i32 4)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
