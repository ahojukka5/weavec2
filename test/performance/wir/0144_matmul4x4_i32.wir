; Performance: 0144_matmul4x4_i32
; tags = heap, i32, stress
; Why hard: 4x4 matrix multiply on heap.
; Reveals: O(n^3) loops, 2D indexing like 0132 at larger n.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0144_matmul4x4_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Same indexing failures as 0132; result cell wrong.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn at
      (params
        (m ptr)
        (r i32)
        (c i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get m)
            (cast_i32_to_i64
              (add_i32
                (mul_i32
                  (param_get r)
                  (const_i32 4)
                ) ;; mul_i32
                (param_get c)
              ) ;; add_i32
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn matmul4
      (params
        (a ptr)
        (b ptr)
        (out ptr)
      ) ;; params
      (returns void)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let j i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (lt_i32
                  (local_get j)
                  (const_i32 4)
                ) ;; lt_i32
              ) ;; condition
              (do
                (let sum i32
                  (const_i32 0)
                ) ;; let

                (let k i32
                  (const_i32 0)
                ) ;; let

                (while
                  (condition
                    (lt_i32
                      (local_get k)
                      (const_i32 4)
                    ) ;; lt_i32
                  ) ;; condition
                  (do
                    (set sum
                      (add_i32
                        (local_get sum)
                        (mul_i32
                          (load_i32
                            (call_ptr at
                              (param_get a)
                              (local_get i)
                              (local_get k)
                            ) ;; call_ptr
                          ) ;; load_i32
                          (load_i32
                            (call_ptr at
                              (param_get b)
                              (local_get k)
                              (local_get j)
                            ) ;; call_ptr
                          ) ;; load_i32
                        ) ;; mul_i32
                      ) ;; add_i32
                    ) ;; set

                    (set k
                      (add_i32
                        (local_get k)
                        (const_i32 1)
                      ) ;; add_i32
                    ) ;; set
                  ) ;; do
                ) ;; while

                (store_i32
                  (call_ptr at
                    (param_get out)
                    (local_get i)
                    (local_get j)
                  ) ;; call_ptr
                  (local_get sum)
                ) ;; store_i32

                (set j
                  (add_i32
                    (local_get j)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let a ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (let b ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (let out ptr
          (call_ptr malloc
            (const_i64 64)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (or_bool
              (eq_ptr
                (local_get a)
                (const_null)
              ) ;; eq_ptr
              (or_bool
                (eq_ptr
                  (local_get b)
                  (const_null)
                ) ;; eq_ptr
                (eq_ptr
                  (local_get out)
                  (const_null)
                ) ;; eq_ptr
              ) ;; or_bool
            ) ;; or_bool
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let n i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get n)
              (const_i32 16)
            ) ;; lt_i32
          ) ;; condition
          (do
            (store_i32
              (array_i32_at
                (local_get a)
                (cast_i32_to_i64
                  (local_get n)
                ) ;; cast_i32_to_i64
              ) ;; array_i32_at
              (add_i32
                (local_get n)
                (const_i32 1)
              ) ;; add_i32
            ) ;; store_i32

            (store_i32
              (array_i32_at
                (local_get b)
                (cast_i32_to_i64
                  (local_get n)
                ) ;; cast_i32_to_i64
              ) ;; array_i32_at
              (mod_i32
                (add_i32
                  (local_get n)
                  (const_i32 2)
                ) ;; add_i32
                (const_i32 4)
              ) ;; mod_i32
            ) ;; store_i32

            (set n
              (add_i32
                (local_get n)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (call_void matmul4
          (local_get a)
          (local_get b)
          (local_get out)
        ) ;; call_void

        (let ans i32
          (load_i32
            (call_ptr at
              (local_get out)
              (const_i32 3)
              (const_i32 3)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; let

        (call_void free
          (local_get a)
        ) ;; call_void

        (call_void free
          (local_get b)
        ) ;; call_void

        (call_void free
          (local_get out)
        ) ;; call_void

        (return
          (local_get ans)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
