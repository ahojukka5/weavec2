; Performance: 0166_sum_range_f32
; tags = f32, float, loop, stress
; Why hard: f32 sum 1..120; acc on stack (no f32 loop phis).
; Reveals: add_f32, cast_i32_to_f32, i32 loop index.
; Expected: main returns 7260 (float sum 1..120, fptosi). llvm-as accepts
;   emitted IR;
;   opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Accumulator widened to double; fadd uses i32 operands.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let sum f32
          (const_f32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 120)
            ) ;; le_i32
          ) ;; condition
          (do
            (set sum
              (add_f32
                (local_get sum)
                (cast_i32_to_f32
                  (local_get i)
                ) ;; cast_i32_to_f32
              ) ;; add_f32
            ) ;; set

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (cast_f32_to_i32
            (local_get sum)
          ) ;; cast_f32_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
