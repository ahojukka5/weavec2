; Performance: 0142_heap_sift_down4_i32
; Why hard: Sift-down on four-element max-heap.
; Reveals: While with parent/child index compares and swaps.
; If LLVM regresses: Child index 2i+1/2i+2 wrong; sift stops early.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem
      (params
        (h ptr)
        (idx i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get h)
            (cast_i32_to_i64
              (param_get idx)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn sift_down
      (params
        (h ptr)
        (start i32)
      ) ;; params
      (returns void)
      (do
        (let i i32
          (param_get start)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let left i32
              (add_i32
                (mul_i32
                  (local_get i)
                  (const_i32 2)
                ) ;; mul_i32
                (const_i32 1)
              ) ;; add_i32
            ) ;; let

            (let right i32
              (add_i32
                (local_get left)
                (const_i32 1)
              ) ;; add_i32
            ) ;; let

            (let largest i32
              (local_get i)
            ) ;; let

            (if
              (condition
                (and_bool
                  (lt_i32
                    (local_get left)
                    (const_i32 4)
                  ) ;; lt_i32
                  (gt_i32
                    (load_i32
                      (call_ptr elem
                        (param_get h)
                        (local_get left)
                      ) ;; call_ptr
                    ) ;; load_i32
                    (load_i32
                      (call_ptr elem
                        (param_get h)
                        (local_get largest)
                      ) ;; call_ptr
                    ) ;; load_i32
                  ) ;; gt_i32
                ) ;; and_bool
              ) ;; condition
              (then
                (do
                  (let largest i32
                    (local_get left)
                  ) ;; let
                ) ;; do
              ) ;; then
              (else
                (do
                  (if
                    (condition
                      (and_bool
                        (lt_i32
                          (local_get right)
                          (const_i32 4)
                        ) ;; lt_i32
                        (gt_i32
                          (load_i32
                            (call_ptr elem
                              (param_get h)
                              (local_get right)
                            ) ;; call_ptr
                          ) ;; load_i32
                          (load_i32
                            (call_ptr elem
                              (param_get h)
                              (local_get largest)
                            ) ;; call_ptr
                          ) ;; load_i32
                        ) ;; gt_i32
                      ) ;; and_bool
                    ) ;; condition
                    (then
                      (do
                        (let largest i32
                          (local_get right)
                        ) ;; let
                      ) ;; do
                    ) ;; then
                    (else
                      (do)
                    ) ;; else
                  ) ;; if
                ) ;; do
              ) ;; else
            ) ;; if

            (if
              (condition
                (eq_i32
                  (local_get largest)
                  (local_get i)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set i
                    (const_i32 4)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (let tmp i32
                    (load_i32
                      (call_ptr elem
                        (param_get h)
                        (local_get i)
                      ) ;; call_ptr
                    ) ;; load_i32
                  ) ;; let

                  (store_i32
                    (call_ptr elem
                      (param_get h)
                      (local_get i)
                    ) ;; call_ptr
                    (load_i32
                      (call_ptr elem
                        (param_get h)
                        (local_get largest)
                      ) ;; call_ptr
                    ) ;; load_i32
                  ) ;; store_i32

                  (store_i32
                    (call_ptr elem
                      (param_get h)
                      (local_get largest)
                    ) ;; call_ptr
                    (local_get tmp)
                  ) ;; store_i32

                  (set i
                    (local_get largest)
                  ) ;; set
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return_void)
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let h ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get h)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem (local_get h) (const_i32 0)) (const_i32 4))
        (store_i32 (call_ptr elem (local_get h) (const_i32 1)) (const_i32 10))
        (store_i32 (call_ptr elem (local_get h) (const_i32 2)) (const_i32 3))
        (store_i32 (call_ptr elem (local_get h) (const_i32 3)) (const_i32 7))

        (call_void sift_down
          (local_get h)
          (const_i32 0)
        ) ;; call_void

        (let root i32
          (load_i32
            (call_ptr elem
              (local_get h)
              (const_i32 0)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; let

        (call_void free
          (local_get h)
        ) ;; call_void

        (return
          (local_get root)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
