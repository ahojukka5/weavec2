; Performance: 0172_horner_poly_f32
; tags = f32, float, stress
; Why hard: Horner-style f32 recurrence acc*3+i for eight steps.
; Reveals: fmul/fadd, f32 acc on stack in loop.
; Expected: main returns 1636 (f32 Horner acc*3+i for i=0..7, fptosi). llvm-as
;   accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Uses i32 mul for f32 acc; sitofp each step.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32 (const_i32 0))
        (let acc f32 (const_f32 0))
        (while
          (condition (lt_i32 (local_get i) (const_i32 8)))
          (do
            (set acc
              (add_f32
                (mul_f32 (local_get acc) (const_f32 3))
                (cast_i32_to_f32 (local_get i))
              )
            )
            (set i (add_i32 (local_get i) (const_i32 1)))
          )
        )
        (return (cast_f32_to_i32 (local_get acc)))
      )
    )
  )
)
