; Performance: 0099_is_perfect_i32
; tags = algorithm, i32
; Why hard: Perfect number test. Divisor sum loop then compare.
; Reveals: Inner divisor loop + outer compare.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0099_is_perfect_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Sum includes n itself; wrong equality.
(core-module
  (core-version 1)
  (decls
    (fn is_perfect
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let d i32
          (const_i32 1)
        ) ;; let

        (let sum i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get d)
              (param_get n)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (param_get n)
                    (local_get d)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set sum
                    (add_i32
                      (local_get sum)
                      (local_get d)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set d
              (add_i32
                (local_get d)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (if
          (condition
            (eq_i32
              (local_get sum)
              (param_get n)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 1)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 is_perfect
            (const_i32 28)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
