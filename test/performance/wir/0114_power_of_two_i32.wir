; Algorithm: return 1 if n is a power of two, else 0
; Tests: shift loop and equality check
(core-module
  (core-version 1)
  (decls
    (fn is_pow2
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (le_i32
              (param_get n)
              (const_i32 0)
            ) ;; le_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let v i32
          (param_get n)
        ) ;; let

        (while
          (condition
            (and_bool
              (gt_i32
                (local_get v)
                (const_i32 1)
              ) ;; gt_i32
              (eq_i32
                (mod_i32
                  (local_get v)
                  (const_i32 2)
                ) ;; mod_i32
                (const_i32 0)
              ) ;; eq_i32
            ) ;; and_bool
          ) ;; condition
          (do
            (set v
              (div_i32
                (local_get v)
                (const_i32 2)
              ) ;; div_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (if
          (condition
            (eq_i32
              (local_get v)
              (const_i32 1)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 1)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; else
        ) ;; if
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 is_pow2
            (const_i32 64)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
