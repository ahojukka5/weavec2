; Performance: 0010_string_literal
; tags = i32, loop, smoke
; Why hard: Smoke baseline for string symbol. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: const_string_ptr in IR
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0010_string_literal.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Missing private constant or bad pointer type for string
;   data.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (print
          (const_string "hello from weave")
        ) ;; print
        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
