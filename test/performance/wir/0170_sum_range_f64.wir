; Performance: 0170_sum_range_f64
; tags = float, i32, loop, stress
; Why hard: f64 sum 1..120; i64/f64 acc on stack like f32 batch.
; Reveals: add_f64, cast_i32_to_f64, i32 loop index.
; Expected: main returns 7260 (f64 sum 1..120, fptosi). llvm-as accepts emitted
;   IR; opt
;   -passes=mem2reg is an optional extra check.
; If LLVM regresses: Double-width accumulator; per-iteration sitofp of index.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let i i32 (const_i32 1))
        (let sum f64 (const_f64 0))
        (while
          (condition (le_i32 (local_get i) (const_i32 120)))
          (do
            (set sum
              (add_f64
                (local_get sum)
                (cast_i32_to_f64 (local_get i))
              )
            )
            (set i (add_i32 (local_get i) (const_i32 1)))
          )
        )
        (return (cast_f64_to_i32 (local_get sum)))
      )
    )
  )
)
