; Performance: 0032_codegen_join_and_i64_arg
; tags = i64, smoke
; Why hard: Smoke baseline for malloc size i64. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: mul_i64 in call arg position
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0032_codegen_join_and_i64_arg.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Size computation widened/narrowed wrong; malloc gets i32.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr malloc
            (mul_i64
              (const_i64 2)
              (const_i64 4)
            ) ;; mul_i64
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do
              (call_void free
                (local_get p)
              ) ;; call_void
            ) ;; do
          ) ;; else
        ) ;; if
        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
