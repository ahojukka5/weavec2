; Performance: 0136_knapsack01_i32
; Why hard: 0/1 knapsack DP table 5x11—2D recurrence.
; Reveals: 2D heap table, max of take/skip, triple structure.
; If LLVM regresses: DP recurrence uses wrong index; table row stride wrong; max path broken.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn dp_at
      (params
        (dp ptr)
        (i i32)
        (w i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get dp)
            (cast_i32_to_i64
              (add_i32
                (mul_i32
                  (param_get i)
                  (const_i32 12)
                ) ;; mul_i32
                (param_get w)
              ) ;; add_i32
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn weight_of
      (params
        (item i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 0)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 2)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 1)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 3)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 2)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 4)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 3)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 5)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (const_i32 9)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn value_of
      (params
        (item i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 0)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 3)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 1)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 4)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 2)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 5)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (eq_i32
              (param_get item)
              (const_i32 3)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 7)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (const_i32 10)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn knapsack5
      (params
        (dp ptr)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get i)
              (const_i32 5)
            ) ;; le_i32
          ) ;; condition
          (do
            (let w i32
              (const_i32 0)
            ) ;; let

            (while
              (condition
                (le_i32
                  (local_get w)
                  (const_i32 11)
                ) ;; le_i32
              ) ;; condition
              (do
                (if
                  (condition
                    (eq_i32
                      (local_get i)
                      (const_i32 0)
                    ) ;; eq_i32
                  ) ;; condition
                  (then
                    (do
                      (store_i32
                        (call_ptr dp_at
                          (param_get dp)
                          (local_get i)
                          (local_get w)
                        ) ;; call_ptr
                        (const_i32 0)
                      ) ;; store_i32
                    ) ;; do
                  ) ;; then
                  (else
                    (do
                      (let wt i32
                        (call_i32 weight_of
                          (sub_i32
                            (local_get i)
                            (const_i32 1)
                          ) ;; sub_i32
                        ) ;; call_i32
                      ) ;; let

                      (let skip i32
                        (load_i32
                          (call_ptr dp_at
                            (param_get dp)
                            (sub_i32
                              (local_get i)
                              (const_i32 1)
                            ) ;; sub_i32
                            (local_get w)
                          ) ;; call_ptr
                        ) ;; load_i32
                      ) ;; let

                      (let take i32
                        (const_i32 0)
                      ) ;; let

                      (if
                        (condition
                          (ge_i32
                            (local_get w)
                            (local_get wt)
                          ) ;; ge_i32
                        ) ;; condition
                        (then
                          (do
                            (let take i32
                              (add_i32
                                (call_i32 value_of
                                  (sub_i32
                                    (local_get i)
                                    (const_i32 1)
                                  ) ;; sub_i32
                                ) ;; call_i32
                                (load_i32
                                  (call_ptr dp_at
                                    (param_get dp)
                                    (sub_i32
                                      (local_get i)
                                      (const_i32 1)
                                    ) ;; sub_i32
                                    (sub_i32
                                      (local_get w)
                                      (local_get wt)
                                    ) ;; sub_i32
                                  ) ;; call_ptr
                                ) ;; load_i32
                              ) ;; add_i32
                            ) ;; let
                          ) ;; do
                        ) ;; then
                        (else
                          (do)
                        ) ;; else
                      ) ;; if

                      (if
                        (condition
                          (gt_i32
                            (local_get take)
                            (local_get skip)
                          ) ;; gt_i32
                        ) ;; condition
                        (then
                          (do
                            (store_i32
                              (call_ptr dp_at
                                (param_get dp)
                                (local_get i)
                                (local_get w)
                              ) ;; call_ptr
                              (local_get take)
                            ) ;; store_i32
                          ) ;; do
                        ) ;; then
                        (else
                          (do
                            (store_i32
                              (call_ptr dp_at
                                (param_get dp)
                                (local_get i)
                                (local_get w)
                              ) ;; call_ptr
                              (local_get skip)
                            ) ;; store_i32
                          ) ;; do
                        ) ;; else
                      ) ;; if
                    ) ;; do
                  ) ;; else
                ) ;; if

                (set w
                  (add_i32
                    (local_get w)
                    (const_i32 1)
                  ) ;; add_i32
                ) ;; set
              ) ;; do
            ) ;; while

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (load_i32
            (call_ptr dp_at
              (param_get dp)
              (const_i32 5)
              (const_i32 11)
            ) ;; call_ptr
          ) ;; load_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let dp ptr
          (call_ptr malloc
            (const_i64 288)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get dp)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let best i32
          (call_i32 knapsack5
            (local_get dp)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get dp)
        ) ;; call_void

        (return
          (local_get best)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
