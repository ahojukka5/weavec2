; Performance: 0020_call_i64
; tags = call, i64, smoke
; Why hard: Smoke baseline for i64 return call. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: call_i64 across function
; Expected: Golden LLVM matches test/performance/expected-llvm/0020_call_i64.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Return value in wrong register; caller uses i32 ops.
(core-module
  (core-version 1)
  (decls
    (fn answer64
      (params)
      (returns i64)
      (do
        (return
          (const_i64 42)
        ) ;; return
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (cast_i64_to_i32
            (call_i64 answer64)
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
