; Stress: batch Euclidean GCD over twelve (a,b) pairs
; Reveals: nested while with mod, loop-carried x/y, outer accumulator
(core-module
  (core-version 1)
  (decls
    (fn gcd_pair
      (params
        (a i32)
        (b i32)
      ) ;; params
      (returns i32)
      (do
        (let x i32
          (param_get a)
        ) ;; let

        (let y i32
          (param_get b)
        ) ;; let

        (while
          (condition
            (ne_i32
              (local_get y)
              (const_i32 0)
            ) ;; ne_i32
          ) ;; condition
          (do
            (let r i32
              (mod_i32
                (local_get x)
                (local_get y)
              ) ;; mod_i32
            ) ;; let

            (set x
              (local_get y)
            ) ;; set

            (set y
              (local_get r)
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let k i32
          (const_i32 0)
        ) ;; let

        (let acc i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get k)
              (const_i32 12)
            ) ;; lt_i32
          ) ;; condition
          (do
            (let a i32
              (add_i32
                (mul_i32
                  (local_get k)
                  (const_i32 37)
                ) ;; mul_i32
                (const_i32 100)
              ) ;; add_i32
            ) ;; let

            (let b i32
              (add_i32
                (mul_i32
                  (local_get k)
                  (const_i32 53)
                ) ;; mul_i32
                (const_i32 200)
              ) ;; add_i32
            ) ;; let

            (let g i32
              (call_i32 gcd_pair
                (local_get a)
                (local_get b)
              ) ;; call_i32
            ) ;; let

            (set acc
              (add_i32
                (local_get acc)
                (local_get g)
              ) ;; add_i32
            ) ;; set

            (set k
              (add_i32
                (local_get k)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get acc)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
