; Performance: 0102_count_primes_to_n_i32
; tags = algorithm, i32
; Why hard: Count primes <= n. Nested primality loops.
; Reveals: Outer candidate, inner trial division.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0102_count_primes_to_n_i32.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Overcounts 1 or composites.
(core-module
  (core-version 1)
  (decls
    (fn is_prime
      (params
        (v i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (le_i32
              (param_get v)
              (const_i32 1)
            ) ;; le_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let d i32
          (const_i32 2)
        ) ;; let

        (let ok i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (and_bool
              (le_i32
                (mul_i32
                  (local_get d)
                  (local_get d)
                ) ;; mul_i32
                (param_get v)
              ) ;; le_i32
              (ne_i32
                (local_get ok)
                (const_i32 0)
              ) ;; ne_i32
            ) ;; and_bool
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (param_get v)
                    (local_get d)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set ok
                    (const_i32 0)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set d
              (add_i32
                (local_get d)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get ok)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn count_primes_to
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let v i32
          (const_i32 2)
        ) ;; let

        (let count i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (le_i32
              (local_get v)
              (param_get n)
            ) ;; le_i32
          ) ;; condition
          (do
            (if
              (condition
                (ne_i32
                  (call_i32 is_prime
                    (local_get v)
                  ) ;; call_i32
                  (const_i32 0)
                ) ;; ne_i32
              ) ;; condition
              (then
                (do
                  (set count
                    (add_i32
                      (local_get count)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set v
              (add_i32
                (local_get v)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get count)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 count_primes_to
            (const_i32 30)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
