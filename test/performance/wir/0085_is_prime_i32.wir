; Algorithm: primality test by trial division up to sqrt(n)
; Tests: loop with square bound and early exit flag
(core-module
  (core-version 1)
  (decls
    (fn is_prime
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (if
          (condition
            (le_i32
              (param_get n)
              (const_i32 1)
            ) ;; le_i32
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (let d i32
          (const_i32 2)
        ) ;; let

        (let prime i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (and_bool
              (le_i32
                (mul_i32
                  (local_get d)
                  (local_get d)
                ) ;; mul_i32
                (param_get n)
              ) ;; le_i32
              (ne_i32
                (local_get prime)
                (const_i32 0)
              ) ;; ne_i32
            ) ;; and_bool
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (param_get n)
                    (local_get d)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set prime
                    (const_i32 0)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set d
              (add_i32
                (local_get d)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get prime)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 is_prime
            (const_i32 97)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
