; Performance: 0042_empty_do
; tags = i32, smoke
; Why hard: Smoke baseline for empty block. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: do with no statements
; Expected: Golden LLVM matches test/performance/expected-llvm/0042_empty_do.ll.
;   llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Empty block eliminated incorrectly breaking join.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (if
          (condition
            (eq_i32
              (const_i32 1)
              (const_i32 2)
            ) ;; eq_i32
          ) ;; condition
          (then
            (do)
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
