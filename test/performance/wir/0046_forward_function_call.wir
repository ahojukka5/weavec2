; Performance: 0046_forward_function_call
; tags = call, i32, smoke
; Why hard: Smoke baseline for forward ref call. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: call before callee in module
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0046_forward_function_call.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Callee not emitted or wrong linkage order.
(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 answer)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn answer
      (params)
      (returns i32)
      (do
        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
