; Performance: 0066_typed_array_at
; tags = algorithm, heap, i32
; Why hard: Typed array element address computation.
; Reveals: array_i32_at GEP lowering.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0066_typed_array_at.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: GEP uses wrong element size; pointers not i64-scaled.
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      )
      (returns ptr)
    )

    (extern free
      (params
        (p ptr)
      )
      (returns void)
    )

    (fn main
      (params)
      (returns i32)
      (do
        (let values ptr
          (call_ptr malloc
            (const_i64 4)
          )
        )
        (if
          (condition
            (eq_ptr
              (local_get values)
              (const_null)
            )
          )
          (then (do (return (const_i32 0))))
          (else (do))
        )

        (let wide ptr
          (call_ptr malloc
            (const_i64 8)
          )
        )
        (if
          (condition
            (eq_ptr
              (local_get wide)
              (const_null)
            )
          )
          (then (do
            (call_void free
              (local_get values)
            )
            (return (const_i32 0))
          ))
          (else (do))
        )

        (let slots ptr
          (call_ptr malloc
            (const_i64 8)
          )
        )
        (if
          (condition
            (eq_ptr
              (local_get slots)
              (const_null)
            )
          )
          (then (do
            (call_void free
              (local_get wide)
            )
            (call_void free
              (local_get values)
            )
            (return (const_i32 0))
          ))
          (else (do))
        )

        (store_i32
          (array_i32_at
            (local_get values)
            (const_i64 0)
          )
          (const_i32 40)
        )
        (store_i64
          (array_i64_at
            (local_get wide)
            (const_i64 0)
          )
          (const_i64 2)
        )
        (store_ptr
          (array_ptr_at
            (local_get slots)
            (const_i64 0)
          )
          (local_get values)
        )

        (let loaded_values ptr
          (load_ptr
            (array_ptr_at
              (local_get slots)
              (const_i64 0)
            )
          )
        )
        (let a i32
          (load_i32
            (array_i32_at
              (local_get loaded_values)
              (const_i64 0)
            )
          )
        )
        (let b i64
          (load_i64
            (array_i64_at
              (local_get wide)
              (const_i64 0)
            )
          )
        )
        (call_void free
          (local_get slots)
        )
        (call_void free
          (local_get wide)
        )
        (call_void free
          (local_get values)
        )
        (return
          (add_i32
            (local_get a)
            (cast_i64_to_i32
              (local_get b)
            )
          )
        )
      )
    )
  )
)
