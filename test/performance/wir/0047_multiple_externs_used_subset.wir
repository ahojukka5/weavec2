; Performance: 0047_multiple_externs_used_subset
; tags = call, i32, smoke
; Why hard: Smoke baseline for multiple extern. Failures here usually indicate
;   broken
;   lowering shared by every later fixture.
; Reveals: subset of externs used
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0047_multiple_externs_used_subset.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Unused declare removed but wrong one kept.
(core-module
  (core-version 1)
  (decls
    (extern puts
      (params
        (text ptr)
      ) ;; params
      (returns i32)
    ) ;; extern

    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr malloc
            (const_i64 8)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (call_void free
          (local_get p)
        ) ;; call_void

        (return
          (const_i32 42)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
