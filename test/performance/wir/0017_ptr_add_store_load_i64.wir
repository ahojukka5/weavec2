(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern
    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern
    (fn main
      (params)
      (returns i32)
      (do
        (let p ptr
          (call_ptr malloc
            (const_i64 16)
          ) ;; call_ptr
        ) ;; let
        (if
          (condition
            (eq_ptr
              (local_get p)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if
        (store_i64
          (local_get p)
          (const_i64 20)
        ) ;; store_i64
        (store_i64
          (ptr_add
            (local_get p)
            (const_i64 8)
          ) ;; ptr_add
          (const_i64 22)
        ) ;; store_i64
        (let a i64
          (load_i64
            (local_get p)
          ) ;; load_i64
        ) ;; let
        (let b i64
          (load_i64
            (ptr_add
              (local_get p)
              (const_i64 8)
            ) ;; ptr_add
          ) ;; load_i64
        ) ;; let
        (call_void free
          (local_get p)
        ) ;; call_void
        (return
          (cast_i64_to_i32
            (add_i64
              (local_get a)
              (local_get b)
            ) ;; add_i64
          ) ;; cast_i64_to_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
