; Performance: 0080_loop_twin_if_i32
; tags = algorithm, i32, if-merge, loop, loop-phi, memory
; Why hard: Two sibling ifs updating same carried local in one iteration.
; Reveals: Twin if merges, loop-carried x, merge suffix allocation.
; Expected: main returns 3 (x=0+1 then +2 on i=0,1). llvm-as accepts emitted IR;
;   opt
;   -passes=mem2reg is an optional extra check.
; If LLVM regresses: Missing .merge block or wrong backedge to phi; second if
;   clobbers first
;   update.
(core-module
  (core-version 1)
  (decls
    (fn run
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 0)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 3)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (local_get i)
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (add_i32
                      (local_get x)
                      (const_i32 1)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (if
              (condition
                (eq_i32
                  (local_get i)
                  (const_i32 1)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set x
                    (add_i32
                      (local_get x)
                      (const_i32 2)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 run
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
