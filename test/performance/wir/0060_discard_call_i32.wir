; Performance: 0060_discard_call_i32
; tags = call, control-flow, i32, integration
; Why hard: Return value intentionally unused; must not keep bogus uses alive.
; Reveals: call_i32 result discarded.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0060_discard_call_i32.ll.
;   llvm-as accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Dead code keeps alloca for unused return; extra stores to
;   dead slots.
(core-module
  (core-version 1)
  (decls
    (extern malloc (params (size i64)) (returns ptr))
    (fn touch (params (p ptr)) (returns i32)
      (do
        (store_i32 (param_get p) (const_i32 42))
        (return (const_i32 0))))
    (fn main (params) (returns i32)
      (do
        (let p ptr (call_ptr malloc (const_i64 4)))
        (call_i32 touch (local_get p))
        (return (load_i32 (local_get p))))))
  )
)
