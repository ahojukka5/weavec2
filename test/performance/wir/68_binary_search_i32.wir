; Algorithm: binary search over seven heap-backed i32 values
; Tests: branch-heavy loop state, typed array addressing, and early exit flag
(core-module
  (core-version 1)
  (decls
    (extern malloc
      (params
        (size i64)
      ) ;; params
      (returns ptr)
    ) ;; extern

    (extern free
      (params
        (p ptr)
      ) ;; params
      (returns void)
    ) ;; extern

    (fn elem_ptr
      (params
        (base ptr)
        (index i32)
      ) ;; params
      (returns ptr)
      (do
        (return
          (array_i32_at
            (param_get base)
            (cast_i32_to_i64
              (param_get index)
            ) ;; cast_i32_to_i64
          ) ;; array_i32_at
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn search7
      (params
        (items ptr)
        (target i32)
      ) ;; params
      (returns i32)
      (do
        (let low i32
          (const_i32 0)
        ) ;; let

        (let high i32
          (const_i32 6)
        ) ;; let

        (let result i32
          (const_i32 -1)
        ) ;; let

        (let active i32
          (const_i32 1)
        ) ;; let

        (while
          (condition
            (and_bool
              (le_i32
                (local_get low)
                (local_get high)
              ) ;; le_i32
              (ne_i32
                (local_get active)
                (const_i32 0)
              ) ;; ne_i32
            ) ;; and_bool
          ) ;; condition
          (do
            (let mid i32
              (div_i32
                (add_i32
                  (local_get low)
                  (local_get high)
                ) ;; add_i32
                (const_i32 2)
              ) ;; div_i32
            ) ;; let

            (let value i32
              (load_i32
                (call_ptr elem_ptr
                  (param_get items)
                  (local_get mid)
                ) ;; call_ptr
              ) ;; load_i32
            ) ;; let

            (if
              (condition
                (eq_i32
                  (local_get value)
                  (param_get target)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set result
                    (local_get mid)
                  ) ;; set

                  (set active
                    (const_i32 0)
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do
                  (if
                    (condition
                      (lt_i32
                        (local_get value)
                        (param_get target)
                      ) ;; lt_i32
                    ) ;; condition
                    (then
                      (do
                        (set low
                          (add_i32
                            (local_get mid)
                            (const_i32 1)
                          ) ;; add_i32
                        ) ;; set
                      ) ;; do
                    ) ;; then
                    (else
                      (do
                        (set high
                          (sub_i32
                            (local_get mid)
                            (const_i32 1)
                          ) ;; sub_i32
                        ) ;; set
                      ) ;; do
                    ) ;; else
                  ) ;; if
                ) ;; do
              ) ;; else
            ) ;; if
          ) ;; do
        ) ;; while

        (return
          (local_get result)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (let items ptr
          (call_ptr malloc
            (const_i64 28)
          ) ;; call_ptr
        ) ;; let

        (if
          (condition
            (eq_ptr
              (local_get items)
              (const_null)
            ) ;; eq_ptr
          ) ;; condition
          (then
            (do
              (return
                (const_i32 0)
              ) ;; return
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 0)) (const_i32 1))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 1)) (const_i32 3))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 2)) (const_i32 5))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 3)) (const_i32 7))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 4)) (const_i32 9))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 5)) (const_i32 11))
        (store_i32 (call_ptr elem_ptr (local_get items) (const_i32 6)) (const_i32 13))

        (let index i32
          (call_i32 search7
            (local_get items)
            (const_i32 9)
          ) ;; call_i32
        ) ;; let

        (call_void free
          (local_get items)
        ) ;; call_void

        (return
          (add_i32
            (local_get index)
            (const_i32 38)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
