; Performance: 0079_loop_if_else_passthrough_i32
; tags = algorithm, i32, loop, loop-phi
; Why hard: Loop with if/else that must merge before next iteration.
; Reveals: if inside while on carried acc.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0079_loop_if_else_passthrough_i32.ll. llvm-as
;   accepts emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Broken loop header phis or missing .merge blocks: carried
;   locals reload from
;   stack every iteration, wrong backedge operands, or SSA violations after
;   llvm-as.
(core-module
  (core-version 1)
  (decls
    (fn run
      (params)
      (returns i32)
      (do
        (let acc i32
          (const_i32 0)
        ) ;; let

        (let i i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (const_i32 4)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (eq_i32
                  (mod_i32
                    (local_get i)
                    (const_i32 2)
                  ) ;; mod_i32
                  (const_i32 0)
                ) ;; eq_i32
              ) ;; condition
              (then
                (do
                  (set acc
                    (add_i32
                      (local_get acc)
                      (const_i32 10)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get acc)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 run
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
