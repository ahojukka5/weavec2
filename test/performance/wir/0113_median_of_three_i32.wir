; Performance: 0113_median_of_three_i32
; tags = algorithm, i32
; Why hard: Median of three. Multiple calls/min-max logic.
; Reveals: function calls + compares.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0113_median_of_three_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Returns mean not median.
(core-module
  (core-version 1)
  (decls
    (fn min3
      (params
        (a i32)
        (b i32)
        (c i32)
      ) ;; params
      (returns i32)
      (do
        (let m i32
          (param_get a)
        ) ;; let

        (if
          (condition
            (lt_i32
              (param_get b)
              (local_get m)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get b)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (lt_i32
              (param_get c)
              (local_get m)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get c)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (local_get m)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn max3
      (params
        (a i32)
        (b i32)
        (c i32)
      ) ;; params
      (returns i32)
      (do
        (let m i32
          (param_get a)
        ) ;; let

        (if
          (condition
            (gt_i32
              (param_get b)
              (local_get m)
            ) ;; gt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get b)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (if
          (condition
            (gt_i32
              (param_get c)
              (local_get m)
            ) ;; gt_i32
          ) ;; condition
          (then
            (do
              (set m
                (param_get c)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do)
          ) ;; else
        ) ;; if

        (return
          (local_get m)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn median3
      (params
        (a i32)
        (b i32)
        (c i32)
      ) ;; params
      (returns i32)
      (do
        (return
          (sub_i32
            (sub_i32
              (add_i32
                (add_i32
                  (param_get a)
                  (param_get b)
                ) ;; add_i32
                (param_get c)
              ) ;; add_i32
              (call_i32 min3
                (param_get a)
                (param_get b)
                (param_get c)
              ) ;; call_i32
            ) ;; sub_i32
            (call_i32 max3
              (param_get a)
              (param_get b)
              (param_get c)
            ) ;; call_i32
          ) ;; sub_i32
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 median3
            (const_i32 30)
            (const_i32 10)
            (const_i32 20)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
