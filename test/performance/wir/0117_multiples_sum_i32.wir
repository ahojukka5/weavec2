; Performance: 0117_multiples_sum_i32
; tags = algorithm, i32
; Why hard: Sum multiples of 3 or 5. Mod in conditional add.
; Reveals: mod, branch, add acc.
; Expected: Golden LLVM matches
;   test/performance/expected-llvm/0117_multiples_sum_i32.ll. llvm-as accepts
;   emitted IR; opt -passes=mem2reg is an optional extra check.
; If LLVM regresses: Double-counts lcm(3,5); mod wrong sign.
(core-module
  (core-version 1)
  (decls
    (fn sum_multiples_below
      (params
        (n i32)
      ) ;; params
      (returns i32)
      (do
        (let i i32
          (const_i32 1)
        ) ;; let

        (let total i32
          (const_i32 0)
        ) ;; let

        (while
          (condition
            (lt_i32
              (local_get i)
              (param_get n)
            ) ;; lt_i32
          ) ;; condition
          (do
            (if
              (condition
                (or_bool
                  (eq_i32
                    (mod_i32
                      (local_get i)
                      (const_i32 3)
                    ) ;; mod_i32
                    (const_i32 0)
                  ) ;; eq_i32
                  (eq_i32
                    (mod_i32
                      (local_get i)
                      (const_i32 5)
                    ) ;; mod_i32
                    (const_i32 0)
                  ) ;; eq_i32
                ) ;; or_bool
              ) ;; condition
              (then
                (do
                  (set total
                    (add_i32
                      (local_get total)
                      (local_get i)
                    ) ;; add_i32
                  ) ;; set
                ) ;; do
              ) ;; then
              (else
                (do)
              ) ;; else
            ) ;; if

            (set i
              (add_i32
                (local_get i)
                (const_i32 1)
              ) ;; add_i32
            ) ;; set
          ) ;; do
        ) ;; while

        (return
          (local_get total)
        ) ;; return
      ) ;; do
    ) ;; fn

    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 sum_multiples_below
            (const_i32 20)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
