; Hadamard on one qubit handle; frontend nativizes H to qrt_ry + qrt_rz.
(program
  (name "test-hadamard-single")
  (version "0.1")
  (extern qrt_ry (params (q i64) (theta_nr i64)) (returns void))
  (extern qrt_rz (params (q i64) (phi_nr i64)) (returns void))
  (entry main
    (params)
    (returns i32)
    (do
      (let q0 i64 (const_i64 0))
      (qgate H q0)
      (return (const_i32 42)))))
