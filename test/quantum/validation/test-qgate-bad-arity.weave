; H requires exactly one qubit operand.
(program
  (name "test-qgate-bad-arity")
  (version "0.1")
  (extern qrt_ry (params (q i64) (theta_nr i64)) (returns void))
  (extern qrt_rz (params (q i64) (phi_nr i64)) (returns void))
  (entry main
    (params)
    (returns i32)
    (do
      (let q0 Qubit (const_i64 0))
      (let q1 Qubit (const_i64 1))
      (qgate H q0 q1)
      (return (const_i32 42)))))
