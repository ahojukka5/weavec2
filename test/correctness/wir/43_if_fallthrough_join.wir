(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let x i32
          (const_i32 0)
        ) ;; let

        (if
          (condition
            (lt_i32
              (const_i32 1)
              (const_i32 2)
            ) ;; lt_i32
          ) ;; condition
          (then
            (do
              (set x
                (const_i32 42)
              ) ;; set
            ) ;; do
          ) ;; then
          (else
            (do
              (set x
                (const_i32 0)
              ) ;; set
            ) ;; do
          ) ;; else
        ) ;; if

        (return
          (local_get x)
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
