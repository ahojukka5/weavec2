(core-module
  (core-version 1)
  (decls
    (fn add
      (params
        (a i32)
        (b i32)
      ) ;; params
      (returns i32)
      (do
        (return
          (add_i32
            (param_get a)
            (param_get b)
          ) ;; add_i32
        ) ;; return
      ) ;; do
    ) ;; fn
    (fn main
      (params)
      (returns i32)
      (do
        (return
          (call_i32 add
            (const_i32 20)
            (const_i32 22)
          ) ;; call_i32
        ) ;; return
      ) ;; do
    ) ;; fn
  ) ;; decls
) ;; core-module
