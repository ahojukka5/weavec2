; Integration test: nested control flow with mixed arithmetic
; Tests: nested if + while + i64 arithmetic + mutable locals in loops

(core-module
  (core-version 1)
  (decls
    (fn main
      (params)
      (returns i32)
      (do
        (let
          sum
          i64
          (const_i64 0))
        (let
          i
          i64
          (const_i64 0))
        (while
          (condition
            (lt_i64
              (local_get i)
              (const_i64 10)))
          (do
            (if
              (condition
                (gt_i64
                  (local_get i)
                  (const_i64 5)))
              (then
                (do
                  (set
                    sum
                    (add_i64
                      (local_get sum)
                      (mul_i64
                        (local_get i)
                        (const_i64 2))))))
              (else
                (do
                  (set
                    sum
                    (add_i64
                      (local_get sum)
                      (local_get i))))))
            (set
              i
              (add_i64
                (local_get i)
                (const_i64 1)))))
        (return
          (cast_i64_to_i32
            (local_get sum)))))))
