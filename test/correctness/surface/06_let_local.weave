; 06_let_local.weave
; purpose: verify that a local variable can be introduced with let and read back.
; verifies: let lowering, local_get, add_i32 combining a local and a constant.
; expected runtime behavior: process exits with code 42 (x=40, returns x+2).
; tags: let, local_get, add_i32, smoke

(program
  (name "let-local")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let x i32
        (const_i32 40))
      (return
        (add_i32
          (local_get x)
          (const_i32 2))))))
