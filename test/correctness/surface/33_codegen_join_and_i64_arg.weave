; 33_codegen_join_and_i64_arg.weave
; purpose: verify if/else that joins after the block, with an i64 expression as call arg.
; verifies: mul_i64 as malloc argument, else-branch with call_void, join after if.
; expected runtime behavior: process exits with code 42.
; tags: mul_i64, call_ptr, call_void, if, join, smoke

(program
  (name "codegen_join_and_i64_arg")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr malloc
          (mul_i64
            (const_i64 2)
            (const_i64 4))))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do
            (call_void free
              (local_get p)))))
      (return
        (const_i32 42)))))
