; 45_while_zero_iterations.weave
; purpose: verify that a while loop whose condition is false from the start runs zero times.
; verifies: while body never executes when i=10 and condition is i<5; sum stays at 42.
; expected runtime behavior: process exits with code 42.
; tags: while, condition, zero_iterations, smoke

(program
  (name "while_zero_iterations")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let i i32
        (const_i32 10))
      (let sum i32
        (const_i32 42))
      (while
        (condition
          (lt_i32
            (local_get i)
            (const_i32 5)))
        (do
          (set sum
            (const_i32 0))
          (set i
            (add_i32
              (local_get i)
              (const_i32 1)))))
      (return
        (local_get sum)))))
