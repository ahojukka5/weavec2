; 51_debug_marker.weave
; purpose: verify that debug blocks execute their body and pass through to WIR.
; verifies: debug with message string, body with set, result read after debug block.
; expected runtime behavior: process exits with code 42 (x=40, debug sets x=42).
; tags: debug, set, local_get, add_i32, smoke

(program
  (name "debug_marker")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let x i32
        (const_i32 40))
      (debug "this is my debug zone"
        (do
          (set x
            (add_i32
              (local_get x)
              (const_i32 2)))))
      (return
        (local_get x)))))
