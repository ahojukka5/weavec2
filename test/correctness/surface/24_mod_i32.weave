; 24_mod_i32.weave
; purpose: verify i32 modulo operator.
; verifies: mod_i32 with constant operands in return position.
; expected runtime behavior: process exits with code 2 (42 mod 10 = 2).
; tags: mod_i32, arithmetic, const_i32, smoke

(program
  (name "mod-i32")
  (version "0.1")
  (entry main)
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (mod_i32
          (const_i32 42)
          (const_i32 10))))))
