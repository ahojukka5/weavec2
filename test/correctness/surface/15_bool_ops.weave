; 15_bool_ops.weave
; purpose: verify boolean logic operators: and_bool, or_bool, const_bool.
; verifies: and_bool short-circuits correctly; or_bool selects true branch.
; expected runtime behavior: process exits with code 42 (true && (false || true)).
; tags: and_bool, or_bool, const_bool, if, condition, smoke

(program
  (name "bool-ops")
  (version "0.1")
  (entry main)
  (fn main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (and_bool
            (const_bool true)
            (or_bool
              (const_bool false)
              (const_bool true))))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
