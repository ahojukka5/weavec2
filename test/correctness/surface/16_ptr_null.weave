; 16_ptr_null.weave
; purpose: verify pointer equality comparisons against null: eq_ptr and ne_ptr.
; verifies: const_null, eq_ptr (null==null is true), ne_ptr (null!=null is false).
; expected runtime behavior: process exits with code 42.
; tags: const_null, eq_ptr, ne_ptr, ptr, if, condition, smoke

(program
  (name "ptr-null")
  (version "0.1")
  (entry main)
  (fn main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (eq_ptr
            (const_null)
            (const_null)))
        (then
          (do
            (if
              (condition
                (ne_ptr
                  (const_null)
                  (const_null)))
              (then
                (do
                  (return
                    (const_i32 0))))
              (else
                (do
                  (return
                    (const_i32 42)))))))
        (else
          (do
            (return
              (const_i32 0))))))))
