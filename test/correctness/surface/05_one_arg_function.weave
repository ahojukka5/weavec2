; 05_one_arg_function.weave
; purpose: verify that a function with one parameter can be defined and called.
; verifies: fn lowering with params, param_get, call_i32, entry-as-reference form.
; expected runtime behavior: process exits with code 43 (inc(42) = 42 + 1).
; tags: fn, params, param_get, call_i32, smoke

(program
  (name "one-arg-function")
  (version "0.1")
  (entry main)
  (fn inc
    (params
      (x i32))
    (returns i32)
    (do
      (return
        (add_i32
          (param_get x)
          (const_i32 1)))))
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (call_i32 inc
          (const_i32 42))))))
