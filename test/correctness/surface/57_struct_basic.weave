; 57_struct_basic.weave
; purpose: verify that (struct ...) declarations are lowered to getter/setter WIR fns.
; verifies: Buffer_get_len, Buffer_set_len, Buffer_get_cap, Buffer_set_cap,
;           Buffer_get_data, Buffer_set_data are generated.
; expected runtime behavior: allocates a pseudo-Buffer, writes fields, reads back, exits 42.
; tags: struct, getter, setter, smoke

(program
  (name "struct_basic")
  (version "0.1")
  (extern malloc (params (size i64)) (returns ptr))
  (struct Buffer
    (field data ptr)
    (field len  i64)
    (field cap  i64))
  (entry main
    (params)
    (returns i32)
    (do
      ; allocate 24 bytes (3 × 8-byte fields)
      (let buf ptr (call_ptr malloc (const_i64 24)))
      ; set fields via generated setters
      (call_void Buffer_set_data buf (const_null))
      (call_void Buffer_set_len  buf (const_i64 42))
      (call_void Buffer_set_cap  buf (const_i64 100))
      ; read back len via generated getter
      (let result i64 (call_i64 Buffer_get_len buf))
      (return (cast_i64_to_i32 (local_get result))))))
