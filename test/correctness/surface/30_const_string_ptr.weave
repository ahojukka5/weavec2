; 30_const_string_ptr.weave
; purpose: verify const_string_ptr — a compile-time pointer to a string literal.
; verifies: const_string_ptr passed to puts via call_i32, return after void-result call.
; expected runtime behavior: prints "hello from const_string_ptr", exits with code 42.
; tags: const_string_ptr, call_i32, puts, string, smoke

(program
  (name "const_string_ptr")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (call_i32 puts
        (const_string_ptr "hello from const_string_ptr"))
      (return
        (const_i32 42)))))
