(core-module
  (core-version 1)
  (decls
    (fn add_two (params (left i32) (right i32)) (returns i32) (do (return (add_i32 left right))))
    (fn add_answer (params (base i32)) (returns i32) (do (let extra i32 (const_i32 2)) (return (call_i32 add_two base extra))))
    (fn main (params) (returns i32) (do (let start i32 (const_i32 40)) (return (call_i32 add_answer start))))
  )
)
