; 29_i32_memory_and_cast.weave
; purpose: verify store_i32/load_i32, div_i32/mul_i32, and cast_i32_to_i64/cast_i64_to_i32.
; verifies: i32 heap write/read, arithmetic chain, signed cast roundtrip, and_bool with eq_i32/le_i32.
; expected runtime behavior: process exits with code 42 (21*4/2=42 stored/loaded, cast check passes).
; tags: store_i32, load_i32, div_i32, mul_i32, cast_i32_to_i64, cast_i64_to_i32, and_bool, smoke

(program
  (name "i32_memory_and_cast")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr malloc
          (const_i64 4)))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do)))
      (store_i32
        (local_get p)
        (div_i32
          (mul_i32
            (const_i32 21)
            (const_i32 4))
          (const_i32 2)))
      (let x i32
        (load_i32
          (local_get p)))
      (call_void free
        (local_get p))
      (if
        (condition
          (and_bool
            (eq_i32
              (local_get x)
              (const_i32 42))
            (le_i32
              (cast_i64_to_i32
                (cast_i32_to_i64
                  (const_i32 -1)))
              (const_i32 0))))
        (then
          (do
            (return
              (local_get x))))
        (else
          (do
            (return
              (const_i32 0))))))))
