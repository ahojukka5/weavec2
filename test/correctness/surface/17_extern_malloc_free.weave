; 17_extern_malloc_free.weave
; purpose: verify extern declarations, call_ptr, call_void with malloc and free.
; verifies: extern with params and return types, call_ptr returning ptr, call_void.
; expected runtime behavior: process exits with code 42 (allocation succeeds, freed).
; tags: extern, call_ptr, call_void, malloc, free, ptr, smoke

(program
  (name "extern-malloc-free")
  (version "0.1")
  (entry main)
  (extern malloc
    (params
      (size i64))
    (returns ptr))
  (extern free
    (params
      (p ptr))
    (returns void))
  (fn main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr malloc
          (const_i64 8)))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do
            (call_void free
              (local_get p))
            (return
              (const_i32 42))))))))
