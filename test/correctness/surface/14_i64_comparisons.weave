; 14_i64_comparisons.weave
; purpose: verify i64 comparison operators: lt_i64, le_i64, ne_i64.
; verifies: nested if conditions using i64 comparisons, all three branches must pass.
; expected runtime behavior: process exits with code 42 (1<2, 2<=2, 3!=4 all true).
; tags: lt_i64, le_i64, ne_i64, if, condition, i64, smoke

(program
  (name "i64-comparisons")
  (version "0.1")
  (entry main)
  (fn main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (lt_i64
            (const_i64 1)
            (const_i64 2)))
        (then
          (do
            (if
              (condition
                (le_i64
                  (const_i64 2)
                  (const_i64 2)))
              (then
                (do
                  (if
                    (condition
                      (ne_i64
                        (const_i64 3)
                        (const_i64 4)))
                    (then
                      (do
                        (return
                          (const_i32 42))))
                    (else
                      (do
                        (return
                          (const_i32 0)))))))
              (else
                (do
                  (return
                    (const_i32 0)))))))
        (else
          (do
            (return
              (const_i32 0))))))))
