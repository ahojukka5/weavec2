; 22_call_ptr.weave
; purpose: verify call_ptr — calling a user-defined function that returns a pointer.
; verifies: fn returning ptr, call_ptr at call site, null-check and cleanup.
; expected runtime behavior: process exits with code 42 (allocation succeeds, freed).
; tags: call_ptr, fn, ptr, malloc, free, smoke

(program
  (name "call-ptr")
  (version "0.1")
  (entry main)
  (extern malloc
    (params
      (size i64))
    (returns ptr))
  (extern free
    (params
      (p ptr))
    (returns void))
  (fn make_ptr
    (params)
    (returns ptr)
    (do
      (return
        (call_ptr malloc
          (const_i64 8)))))
  (fn main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr make_ptr))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do
            (call_void free
              (local_get p))
            (return
              (const_i32 42))))))))
