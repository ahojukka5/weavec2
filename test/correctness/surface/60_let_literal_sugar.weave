; 60_let_literal_sugar.weave
; purpose: verify that typed let statements accept integer literal sugar.
; verifies: (let x i32 40) and (let y i64 2) lower to typed WIR constants.
; expected-exit: 42
; tags: let, literal_sugar, i32, i64, smoke

(program
  (name "let-literal-sugar")
  (version "0.1")

  (entry main
    (params)
    (returns i32)
    (do
      (let x i32 40)
      (let y i64 2)
      (return
        (add_i32
          (local_get x)
          (cast_i64_to_i32 (local_get y)))))))
