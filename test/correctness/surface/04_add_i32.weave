; 04_add_i32.weave
; purpose: verify that two i32 constants can be added and the result returned.
; verifies: add_i32 lowering, binary expression in return position, entry-with-body format.
; expected runtime behavior: process exits with code 42 (20 + 22).
; tags: add_i32, arithmetic, const_i32, return, smoke

(program
  (name "add")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (return
        (add_i32
          (const_i32 20)
          (const_i32 22))))))
