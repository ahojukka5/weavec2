; 36_sub_i32.weave
; purpose: verify sub_i32 subtraction operator.
; verifies: sub_i32 with constant operands in return position.
; expected runtime behavior: process exits with code 42 (50 - 8 = 42).
; tags: sub_i32, arithmetic, const_i32, smoke

(program
  (name "sub_i32")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (return
        (sub_i32
          (const_i32 50)
          (const_i32 8))))))
