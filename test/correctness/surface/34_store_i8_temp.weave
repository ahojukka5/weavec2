; 34_store_i8_temp.weave
; purpose: verify store_i8 with a let-bound local value rather than an inline constant.
; verifies: let-bound i32 used in store_i8, load_u8 after store, result passed to return.
; expected runtime behavior: process exits with code 42.
; tags: store_i8, load_u8, let, local_get, malloc, free, smoke

(program
  (name "store_i8_temp")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr malloc
          (const_i64 1)))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do)))
      (let value i32
        (const_i32 42))
      (store_i8
        (local_get p)
        (local_get value))
      (let loaded i32
        (load_u8
          (local_get p)))
      (call_void free
        (local_get p))
      (return
        (local_get loaded)))))
