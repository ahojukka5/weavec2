; 54_integration_memory_flow.weave
; purpose: integration test — write array via ptr arithmetic, sum values via separate fn.
; verifies: write_values stores i*10 for i in 0..5; sum_values reads back; sum=0+10+20+30+40=100.
; expected runtime behavior: process exits with code 100.
; tags: store_i32, load_i32, ptr_add, mul_i64, cast_i32_to_i64, while, call_void, call_i32, integration

(program
  (name "integration_memory_flow")
  (version "0.1")
  (entry main)
  (fn write_values
    (params
      (buffer ptr)
      (count i32))
    (returns void)
    (do
      (let i i32 (const_i32 0))
      (while
        (condition (lt_i32 (local_get i) (param_get count)))
        (do
          (store_i32
            (ptr_add
              (param_get buffer)
              (mul_i64
                (cast_i32_to_i64 (local_get i))
                (const_i64 4)))
            (mul_i32 (local_get i) (const_i32 10)))
          (set i (add_i32 (local_get i) (const_i32 1)))))
      (return_void)))
  (fn sum_values
    (params
      (buffer ptr)
      (count i32))
    (returns i32)
    (do
      (let sum i32 (const_i32 0))
      (let i i32 (const_i32 0))
      (while
        (condition (lt_i32 (local_get i) (param_get count)))
        (do
          (set sum
            (add_i32
              (local_get sum)
              (load_i32
                (ptr_add
                  (param_get buffer)
                  (mul_i64
                    (cast_i32_to_i64 (local_get i))
                    (const_i64 4))))))
          (set i (add_i32 (local_get i) (const_i32 1)))))
      (return (local_get sum))))
  (fn main
    (params)
    (returns i32)
    (do
      (let buffer ptr (call_ptr malloc (const_i64 20)))
      (call_void write_values (local_get buffer) (const_i32 5))
      (let result i32 (call_i32 sum_values (local_get buffer) (const_i32 5)))
      (call_void free (local_get buffer))
      (return (local_get result)))))
