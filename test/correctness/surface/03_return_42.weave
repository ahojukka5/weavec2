; 03_return_42.weave
; purpose: verify that a non-zero constant integer can be returned from main.
; verifies: const_i32 lowering with value 42, entry-with-body format, i32 return type.
; expected runtime behavior: process exits with code 42.
; tags: const_i32, return, entry, smoke

(program
  (name "return-42")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (return
        (const_i32 42)))))
