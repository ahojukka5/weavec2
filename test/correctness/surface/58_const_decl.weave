; 58_const_decl.weave
; purpose: verify that (const NAME TYPE VALUE) declarations lower to zero-arg WIR fns.
; verifies: ANSWER() → i64 returns 42, LIMIT() → i32 returns 100.
; expected runtime behavior: calls ANSWER(), casts to i32, exits 42.
; tags: const, named-constant, smoke

(program
  (name "const_decl")
  (version "0.1")
  (const ANSWER i64 42)
  (const LIMIT  i32 100)
  (entry main
    (params)
    (returns i32)
    (do
      (return (cast_i64_to_i32 (call_i64 ANSWER))))))
