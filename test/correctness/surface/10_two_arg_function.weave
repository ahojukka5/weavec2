; 10_two_arg_function.weave
; purpose: verify that a function with two parameters can be defined and called.
; verifies: fn with two params, param_get for each, call_i32 with two arguments.
; expected runtime behavior: process exits with code 42 (add(20, 22) = 42).
; tags: fn, params, param_get, call_i32, multi-arg, smoke

(program
  (name "two-arg-function")
  (version "0.1")
  (entry main)
  (fn add
    (params
      (a i32)
      (b i32))
    (returns i32)
    (do
      (return
        (add_i32
          (param_get a)
          (param_get b)))))
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (call_i32 add
          (const_i32 20)
          (const_i32 22))))))
