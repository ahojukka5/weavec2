; 40_i64_ge_gt.weave
; purpose: verify gt_i64 and ge_i64 comparison operators.
; verifies: gt_i64 (10 > 9) passes, ge_i64 (10 >= 10) passes, returns 42.
; expected runtime behavior: process exits with code 42.
; tags: gt_i64, ge_i64, if, condition, const_i64, smoke

(program
  (name "i64_ge_gt")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (gt_i64
            (const_i64 10)
            (const_i64 9)))
        (then
          (do))
        (else
          (do
            (return
              (const_i32 0)))))
      (if
        (condition
          (ge_i64
            (const_i64 10)
            (const_i64 10)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
