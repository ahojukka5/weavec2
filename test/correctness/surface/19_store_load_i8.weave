; 19_store_load_i8.weave
; purpose: verify byte-level memory: store_i8 writes one byte, load_u8 reads it back.
; verifies: store_i8, load_u8, malloc/free for 1-byte allocation.
; expected runtime behavior: process exits with code 42 (stores 42 as i8, loads as u8).
; tags: store_i8, load_u8, malloc, free, ptr, smoke

(program
  (name "store-load-i8")
  (version "0.1")
  (entry main)
  (extern malloc
    (params
      (size i64))
    (returns ptr))
  (extern free
    (params
      (p ptr))
    (returns void))
  (fn main
    (params)
    (returns i32)
    (do
      (let p ptr
        (call_ptr malloc
          (const_i64 1)))
      (if
        (condition
          (eq_ptr
            (local_get p)
            (const_null)))
        (then
          (do
            (return
              (const_i32 0))))
        (else
          (do)))
      (store_i8
        (local_get p)
        (const_i32 42))
      (let x i32
        (load_u8
          (local_get p)))
      (call_void free
        (local_get p))
      (return
        (local_get x)))))
