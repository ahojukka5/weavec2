; 32_not_bool.weave
; purpose: verify not_bool logical negation operator.
; verifies: not_bool applied to const_bool false yields true, taken in if condition.
; expected runtime behavior: process exits with code 42.
; tags: not_bool, const_bool, if, condition, smoke

(program
  (name "not_bool")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (not_bool
            (const_bool false)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
