; 26_ptr_params_call_i32.weave
; purpose: verify ptr-typed function parameters and call_i32 with ptr arguments.
; verifies: fn with two ptr params, param_get returning ptr, eq_ptr comparison.
; expected runtime behavior: process exits with code 42 (null == null).
; tags: fn, params, ptr, param_get, eq_ptr, call_i32, smoke

(program
  (name "ptr-params-call-i32")
  (version "0.1")
  (entry main)
  (fn same_ptr
    (params
      (a ptr)
      (b ptr))
    (returns i32)
    (do
      (if
        (condition
          (eq_ptr
            (param_get a)
            (param_get b)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0)))))))
  (fn main
    (params)
    (returns i32)
    (do
      (return
        (call_i32 same_ptr
          (const_null)
          (const_null))))))
