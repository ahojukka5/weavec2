; 11_string_literal.weave
; purpose: verify that a string literal can be printed and a non-zero code returned.
; verifies: print lowering to puts call, const_string lowering, extern puts declaration.
; expected runtime behavior: prints "hello from weave", exits with code 42.
; tags: print, const_string, extern, call_void, smoke

(program
  (name "string-literal")
  (version "0.1")
  (entry main)
  (fn main
    (params)
    (returns i32)
    (do
      (print
        (const_string "hello from weave"))
      (return
        (const_i32 42)))))
