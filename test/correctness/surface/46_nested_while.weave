; 46_nested_while.weave
; purpose: verify nested while loops accumulate correctly.
; verifies: inner while with let-bound counter, outer while, total = 2 * 3 * 7 = 42.
; expected runtime behavior: process exits with code 42.
; tags: while, nested, let, set, local_get, add_i32, smoke

(program
  (name "nested_while")
  (version "0.1")
  (entry main
    (params)
    (returns i32)
    (do
      (let outer i32
        (const_i32 0))
      (let total i32
        (const_i32 0))
      (while
        (condition
          (lt_i32
            (local_get outer)
            (const_i32 2)))
        (do
          (let inner i32
            (const_i32 0))
          (while
            (condition
              (lt_i32
                (local_get inner)
                (const_i32 3)))
            (do
              (set total
                (add_i32
                  (local_get total)
                  (const_i32 7)))
              (set inner
                (add_i32
                  (local_get inner)
                  (const_i32 1)))))
          (set outer
            (add_i32
              (local_get outer)
              (const_i32 1)))))
      (return
        (local_get total)))))
