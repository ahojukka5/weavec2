; 27_bool_return.weave
; purpose: verify bool-typed parameters, return, and call_bool.
; verifies: fn with bool param, param_get returning bool, call_bool, bool in condition.
; expected runtime behavior: process exits with code 42 (same(true) returns true).
; tags: fn, bool, param_get, call_bool, condition, smoke

(program
  (name "bool_return")
  (version "0.1")
  (entry main)
  (fn same
    (params
      (x bool))
    (returns bool)
    (do
      (return
        (param_get x))))
  (fn main
    (params)
    (returns i32)
    (do
      (if
        (condition
          (call_bool same
            (const_bool true)))
        (then
          (do
            (return
              (const_i32 42))))
        (else
          (do
            (return
              (const_i32 0))))))))
