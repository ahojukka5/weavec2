            (else (do)))
          (set child (call_i64 node_next_sibling (local_get tree) (local_get child)))))
      (return (const_i32 0))))

  ; Emit the loop-backedge operand for a direct set in a phi loop.
  (fn emit_loop_phi_backedge_operand
    (params (ctx ptr) (body_do i64) (set_node i64) (name_node i64) (blk i64) (merge_if_blk i64))
    (returns void)
    (do
      (let fd i32 (call_i32 ctx_get_fd (param_get ctx)))
      (let tree ptr (call_ptr ctx_get_tree (param_get ctx)))
      (let source ptr (call_ptr ctx_get_source (param_get ctx)))
      (let name_node i64 (call_i64 nth_child (local_get tree) (param_get set_node) (const_i64 1)))
      (let ns i64 (call_i64 node_text_start (local_get tree) (local_get name_node)))
      (let nl i64 (call_i64 node_text_len (local_get tree) (local_get name_node)))
      (let predicted_merge i64 (call_i64 find_loop_header_merge_if_blk
        (param_get ctx) (param_get body_do) (local_get ns) (local_get nl) (add_i64 (param_get blk) (const_i64 1))))
      (if
        (condition (or_bool
          (ne_i32 (call_i32 local_is_loop_merge (param_get ctx) (local_get ns) (local_get nl)) (const_i32 0))
          (or_bool
            (ge_i64 (local_get predicted_merge) (const_i64 0))
            (or_bool
              (ge_i64 (param_get merge_if_blk) (const_i64 0))
              (ne_i32 (call_i32 local_updated_in_loop_if_do (param_get ctx) (param_get body_do) (local_get ns) (local_get nl)) (const_i32 0))))))
        (then (do
          (let merge_suffix i64 (call_i64 local_loop_merge_suffix (param_get ctx) (local_get ns) (local_get nl)))
          (if
            (condition (ne_i32 (call_i32 local_is_loop_merge (param_get ctx) (local_get ns) (local_get nl)) (const_i32 0)))
            (then (do))
            (else (do
              (if
                (condition (ge_i64 (local_get predicted_merge) (const_i64 0)))
                (then (do (set merge_suffix (local_get predicted_merge))))
                (else (do
                  (if
                    (condition (ge_i64 (param_get merge_if_blk) (const_i64 0)))
                    (then (do (set merge_suffix (param_get merge_if_blk))))
                    (else (do
                      (set merge_suffix (add_i64 (call_i64 ctx_get_loop_phi_blk (param_get ctx)) (const_i64 1))))))))))))
          (call_void write_byte (local_get fd) (const_i32 37))
          (call_void emit_slice_text (local_get fd) (local_get source) (local_get ns) (local_get nl))
          (call_void write_cstr (local_get fd) (const_string_ptr ".merge"))
          (call_void write_i64_dec (local_get fd) (local_get merge_suffix))
          (return_void)))
        (else (do)))
      (let expr_node i64 (call_i64 nth_child (local_get tree) (param_get set_node) (const_i64 2)))
      (if
        (condition (or_bool
          (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get expr_node)
            (const_string_ptr "const_i32") (const_i64 9)) (const_i32 0))
          (or_bool
            (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get expr_node)
              (const_string_ptr "const_i64") (const_i64 9)) (const_i32 0))
            (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get expr_node)
              (const_string_ptr "param_get") (const_i64 9)) (const_i32 0)))))
        (then (do
          (call_void emit_operand (param_get ctx) (local_get expr_node) (const_i64 -2))
          (return_void)))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get expr_node)
          (const_string_ptr "local_get") (const_i64 9)) (const_i32 0)))
        (then (do
          (let get_name i64 (call_i64 nth_child (local_get tree) (local_get expr_node) (const_i64 1)))
          (let gs i64 (call_i64 node_text_start (local_get tree) (local_get get_name)))
          (let gl i64 (call_i64 node_text_len (local_get tree) (local_get get_name)))
          (if
            (condition (and_bool
              (ne_i32 (call_i32 local_is_loop_phi (param_get ctx) (local_get gs) (local_get gl)) (const_i32 0))
              (eq_i64 (call_i64 local_loop_phi_suffix (param_get ctx) (local_get gs) (local_get gl)) (param_get blk))))
            (then (do
              (call_void write_byte (local_get fd) (const_i32 37))
