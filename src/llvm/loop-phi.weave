; loop-phi.weave — loop-carried SSA (phi, merge, latch) for weavec2

(program
  (name "loop_phi")
  (version "0.1")

  (fn emit_named_binary_expr
    (params (ctx ptr) (node i64) (name_node i64) (blk i64) (llvm_op ptr) (type_id i32))
    (returns i32)
    (do
      (let fd i32 (call_i32 ctx_get_fd (param_get ctx)))
      (let tree ptr (call_ptr ctx_get_tree (param_get ctx)))
      (let source ptr (call_ptr ctx_get_source (param_get ctx)))
      (let actual_args i64 (sub_i64 (call_i64 count_children (local_get tree) (param_get node)) (const_i64 1)))
      (if
        (condition (ne_i64 (local_get actual_args) (const_i64 2)))
        (then (do
          (call_void diag_wrong_arity (param_get ctx) (param_get node) (const_i64 2) (local_get actual_args))
          (return (const_i32 -1))))
        (else (do)))
      (let left i64 (call_i64 nth_child (local_get tree) (param_get node) (const_i64 1)))
      (let right i64 (call_i64 nth_child (local_get tree) (param_get node) (const_i64 2)))
      (let lv i64 (call_i64 emit_expr (param_get ctx) (local_get left)))
      (let rv i64 (call_i64 emit_expr (param_get ctx) (local_get right)))
      (if
        (condition (or_bool
          (eq_i64 (local_get lv) (const_i64 -1))
          (eq_i64 (local_get rv) (const_i64 -1))))
        (then (do (return (const_i32 -1))))
        (else (do)))
      (call_void write_cstr (local_get fd) (const_string_ptr "  %"))
      (call_void emit_node_text (local_get fd) (local_get source) (local_get tree) (param_get name_node))
      (call_void write_cstr (local_get fd) (const_string_ptr ".next"))
      (call_void write_i64_dec (local_get fd) (call_i64 ctx_phi_next_tag (param_get ctx)))
      (call_void write_cstr (local_get fd) (const_string_ptr " = "))
      (call_void write_cstr (local_get fd) (param_get llvm_op))
      (call_void write_byte (local_get fd) (const_i32 32))
      (call_void emit_type (local_get fd) (param_get type_id))
      (call_void write_byte (local_get fd) (const_i32 32))
      (call_void emit_operand (param_get ctx) (local_get left) (local_get lv))
      (call_void write_cstr (local_get fd) (const_string_ptr ", "))
      (call_void emit_operand (param_get ctx) (local_get right) (local_get rv))
      (call_void write_byte (local_get fd) (const_i32 10))
      (return (const_i32 1))))

  ; Non-zero when type_id is a loop-phi scalar (i32 or i64).
  (fn type_id_loop_phi_scalar
    (params (type_id i32))
    (returns i32)
    (do
      (if
        (condition (or_bool
          (eq_i32 (param_get type_id) (const_i32 1))
          (eq_i32 (param_get type_id) (const_i32 2))))
        (then (do (return (const_i32 1))))
        (else (do)))
      (return (const_i32 0))))

  ; Return the value-expression node for (let name ...) in body_do, or -1.
  (fn loop_do_find_let_value_node
    (params (ctx ptr) (body_do i64) (ns i64) (nl i64))
    (returns i64)
    (do
      (let tree ptr (call_ptr ctx_get_tree (param_get ctx)))
      (let source ptr (call_ptr ctx_get_source (param_get ctx)))
      (if
        (condition (lt_i64 (param_get body_do) (const_i64 0)))
        (then (do (return (const_i64 -1))))
        (else (do)))
      (let child i64 (call_i64 node_first_child (local_get tree) (param_get body_do)))
      (while
        (condition (ne_i64 (local_get child) (const_i64 -1)))
        (do
          (if
            (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get child)
              (const_string_ptr "let") (const_i64 3)) (const_i32 0)))
            (then (do
              (let let_name i64 (call_i64 nth_child (local_get tree) (local_get child) (const_i64 1)))
              (if
                (condition (ne_i32 (call_i32 slices_equal
                  (local_get source)
                  (param_get ns) (param_get nl)
                  (call_i64 node_text_start (local_get tree) (local_get let_name))
                  (call_i64 node_text_len (local_get tree) (local_get let_name))) (const_i32 0)))
                (then (do
                  (return (call_i64 nth_child (local_get tree) (local_get child) (const_i64 3)))))
                (else (do)))))
            (else (do)))
          (set child (call_i64 node_next_sibling (local_get tree) (local_get child)))))
      (return (const_i64 -1))))

  ; Try to emit a direct %name.nextN expression for loop phi backedges.
  (fn try_emit_loop_phi_next
    (params (ctx ptr) (node i64) (name_node i64) (blk i64) (type_id i32))
    (returns i32)
    (do
      (let tree ptr (call_ptr ctx_get_tree (param_get ctx)))
      (let source ptr (call_ptr ctx_get_source (param_get ctx)))
      (if
        (condition (eq_i32 (call_i32 type_id_loop_phi_scalar (param_get type_id)) (const_i32 0)))
        (then (do (return (const_i32 0))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "local_get") (const_i64 9)) (const_i32 0)))
        (then (do
          (let get_name i64 (call_i64 nth_child (local_get tree) (param_get node) (const_i64 1)))
          (let gs i64 (call_i64 node_text_start (local_get tree) (local_get get_name)))
          (let gl i64 (call_i64 node_text_len (local_get tree) (local_get get_name)))
          (if
            (condition (and_bool
              (ne_i32 (call_i32 local_is_loop_phi (param_get ctx) (local_get gs) (local_get gl)) (const_i32 0))
              (eq_i64 (call_i64 local_loop_phi_suffix (param_get ctx) (local_get gs) (local_get gl)) (param_get blk))))
            (then (do
              (let set_ns i64 (call_i64 node_text_start (local_get tree) (param_get name_node)))
              (let set_nl i64 (call_i64 node_text_len (local_get tree) (param_get name_node)))
              (let loop_body i64 (call_i64 ctx_get_loop_body_do (param_get ctx)))
              (if
                (condition (and_bool
                  (ge_i64 (local_get loop_body) (const_i64 0))
                  (ne_i32 (call_i32 local_updated_in_loop_if_do
                    (param_get ctx) (local_get loop_body) (local_get set_ns) (local_get set_nl)) (const_i32 0))))
                (then (do))
                (else (do (return (const_i32 2)))))))
            (else (do
              (let loop_body2 i64 (call_i64 ctx_get_loop_body_do (param_get ctx)))
              (let let_val i64 (call_i64 loop_do_find_let_value_node
                (param_get ctx) (local_get loop_body2) (local_get gs) (local_get gl)))
              (if
                (condition (ge_i64 (local_get let_val) (const_i64 0)))
                (then (do (return (call_i32 try_emit_loop_phi_next
                  (param_get ctx) (local_get let_val) (param_get name_node) (param_get blk) (param_get type_id)))))
                (else (do))))))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "add_i32") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "add") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "sub_i32") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "sub") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "mul_i32") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "mul") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "div_i32") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "sdiv") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "mod_i32") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "srem") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "add_i64") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "add") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "sub_i64") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "sub") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "mul_i64") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "mul") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "div_i64") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "sdiv") (param_get type_id)))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (param_get node)
          (const_string_ptr "mod_i64") (const_i64 7)) (const_i32 0)))
        (then (do (return (call_i32 emit_named_binary_expr
          (param_get ctx) (param_get node) (param_get name_node) (param_get blk)
          (const_string_ptr "srem") (param_get type_id)))))
        (else (do)))
      (return (const_i32 0))))
  ; Return non-zero when a do block assigns the named local (including nested ifs).
  (fn if_do_sets_local
    (params (ctx ptr) (branch_do i64) (ns i64) (nl i64))
    (returns i32)
    (do
      (let tree ptr (call_ptr ctx_get_tree (param_get ctx)))
      (let source ptr (call_ptr ctx_get_source (param_get ctx)))
      (let child i64 (call_i64 node_first_child (local_get tree) (param_get branch_do)))
      (if
        (condition (ne_i64 (local_get child) (const_i64 -1)))
        (then (do (set child (call_i64 node_next_sibling (local_get tree) (local_get child)))))
        (else (do)))
      (while
        (condition (ne_i64 (local_get child) (const_i64 -1)))
        (do
          (if
            (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get child)
              (const_string_ptr "set") (const_i64 3)) (const_i32 0)))
            (then (do
              (let sn i64 (call_i64 nth_child (local_get tree) (local_get child) (const_i64 1)))
              (if
                (condition (ne_i32 (call_i32 slices_equal
                  (local_get source)
                  (param_get ns) (param_get nl)
                  (call_i64 node_text_start (local_get tree) (local_get sn))
                  (call_i64 node_text_len (local_get tree) (local_get sn))) (const_i32 0)))
                (then (do (return (const_i32 1))))
                (else (do)))))
            (else (do)))
          (if
            (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get child)
              (const_string_ptr "if") (const_i64 2)) (const_i32 0)))
            (then (do
              (let tw i64 (call_i64 nth_child (local_get tree) (local_get child) (const_i64 2)))
              (let td i64 (call_i64 nth_child (local_get tree) (local_get tw) (const_i64 1)))
              (let ew i64 (call_i64 nth_child (local_get tree) (local_get child) (const_i64 3)))
              (let ed i64 (call_i64 nth_child (local_get tree) (local_get ew) (const_i64 1)))
              (if
                (condition (or_bool
                  (ne_i32 (call_i32 if_do_sets_local (param_get ctx) (local_get td) (param_get ns) (param_get nl)) (const_i32 0))
                  (ne_i32 (call_i32 if_do_sets_local (param_get ctx) (local_get ed) (param_get ns) (param_get nl)) (const_i32 0))))
                (then (do (return (const_i32 1))))
                (else (do)))))
            (else (do)))
          (set child (call_i64 node_next_sibling (local_get tree) (local_get child)))))
      (return (const_i32 0))))

  ; If blk suffix for loop header backedge merge (outermost top-level if that assigns name).
  (fn find_loop_header_merge_if_blk
    (params (ctx ptr) (body_do i64) (ns i64) (nl i64) (start_run_blk i64))
    (returns i64)
    (do
      (let tree ptr (call_ptr ctx_get_tree (param_get ctx)))
      (let source ptr (call_ptr ctx_get_source (param_get ctx)))
      (let child i64 (call_i64 node_first_child (local_get tree) (param_get body_do)))
      (if
        (condition (ne_i64 (local_get child) (const_i64 -1)))
        (then (do (set child (call_i64 node_next_sibling (local_get tree) (local_get child)))))
        (else (do)))
      (let run_blk i64 (param_get start_run_blk))
      (while
        (condition (ne_i64 (local_get child) (const_i64 -1)))
        (do
          (if
            (condition (ne_i32 (call_i32 head_equals (local_get tree) (local_get source) (local_get child)
              (const_string_ptr "if") (const_i64 2)) (const_i32 0)))
            (then (do
              (let tw i64 (call_i64 nth_child (local_get tree) (local_get child) (const_i64 2)))
              (let td i64 (call_i64 nth_child (local_get tree) (local_get tw) (const_i64 1)))
              (let ew i64 (call_i64 nth_child (local_get tree) (local_get child) (const_i64 3)))
              (let ed i64 (call_i64 nth_child (local_get tree) (local_get ew) (const_i64 1)))
              (if
                (condition (or_bool
                  (ne_i32 (call_i32 if_do_sets_local (param_get ctx) (local_get td) (param_get ns) (param_get nl)) (const_i32 0))
                  (ne_i32 (call_i32 if_do_sets_local (param_get ctx) (local_get ed) (param_get ns) (param_get nl)) (const_i32 0))))
                (then (do (return (local_get run_blk))))
                (else (do)))
              (set run_blk (add_i64 (local_get run_blk) (const_i64 1)))
              (set run_blk (add_i64 (local_get run_blk)
                (call_i64 count_if_blks_in_do (local_get tree) (local_get source) (local_get td))))
              (set run_blk (add_i64 (local_get run_blk)
                (call_i64 count_if_blks_in_do (local_get tree) (local_get source) (local_get ed))))))
            (else (do)))
          (set child (call_i64 node_next_sibling (local_get tree) (local_get child)))))
      (return (const_i64 -1))))

  ; Return non-zero when a local is assigned inside an if in this loop body.
  (fn local_updated_in_loop_if_do
    (params (ctx ptr) (body_do i64) (ns i64) (nl i64))
    (returns i32)
    (do
