        (then (do (return (const_i32 5))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "call_f32") (const_i64 8)) (const_i32 0)))
        (then (do (return (const_i32 5))))
        (else (do)))
      ; f64 producers
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "const_f64") (const_i64 9)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "add_f64") (const_i64 7)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "sub_f64") (const_i64 7)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "mul_f64") (const_i64 7)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "div_f64") (const_i64 7)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "mod_f64") (const_i64 7)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "cast_i32_to_f64") (const_i64 15)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
          (const_string_ptr "cast_f32_to_f64") (const_i64 15)) (const_i32 0)))
        (then (do (return (const_i32 6))))
        (else (do)))
      (if
        (condition (ne_i32 (call_i32 ident_equals (param_get tree) (param_get source) (param_get op_node)
